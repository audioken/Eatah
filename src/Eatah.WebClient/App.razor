@namespace Eatah.WebClient
@using Microsoft.AspNetCore.Components.Routing
@using Eatah.Client.Shared
@using Eatah.Client.Services
@using Eatah.WebClient.Services
@inject PushNotificationService PushNotifications
@inject AuthState AuthState
@implements IDisposable

<Router AppAssembly="@typeof(App).Assembly"
        AdditionalAssemblies="new[] { typeof(Eatah.Client.Services.ApiClient).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (AuthState.IsInitialized && AuthState.IsAuthenticated)
            await PushNotifications.TryInitializeAsync();
    }

    private async void OnAuthChanged()
    {
        if (AuthState.IsAuthenticated)
            await PushNotifications.TryInitializeAsync();
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthChanged;
    }
}
