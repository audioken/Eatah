@implements IDisposable
@inject LoadingState LoadingState

<div class="fixed top-0 left-0 right-0 z-[100] pointer-events-none" style="@_style">
    <div style="height:4px;background:var(--color-brand);"></div>
</div>

@code {
    private bool _visible;

    private string _style => _visible
        ? "opacity:1;transition:opacity 150ms ease;"
        : "opacity:0;transition:opacity 150ms ease;";

    protected override void OnInitialized()
    {
        LoadingState.Changed += OnChanged;
        _visible = LoadingState.IsLoading;
    }

    private void OnChanged()
    {
        InvokeAsync(() =>
        {
            _visible = LoadingState.IsLoading;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        LoadingState.Changed -= OnChanged;
    }
}
