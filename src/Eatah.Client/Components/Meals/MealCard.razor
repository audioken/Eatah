@namespace Eatah.Client.Components.Meals

<div class="p-4 rounded-lg border border-slate-200 bg-white flex flex-col gap-3">
	<div class="flex items-start justify-between gap-2">
		<div>
			<h3 class="font-semibold text-slate-900">@Meal.Name</h3>
			<div class="flex items-center gap-2 mt-1">
				<CategoryBadge Meal="new MealSummaryResponse(Meal.Id, Meal.Name, Meal.Category)" />
				@if (Meal.CookingTimeMinutes.HasValue)
				{
					<span class="text-xs text-slate-500">~@Meal.CookingTimeMinutes min</span>
				}
			</div>
		</div>
		<div class="flex gap-1">
			<button type="button" class="p-1.5 text-slate-500 hover:text-brand-600 hover:bg-brand-50 rounded"
					title="Redigera" @onclick="() => OnEdit.InvokeAsync(Meal)">
				✏️
			</button>
			<button type="button" class="p-1.5 text-slate-500 hover:text-red-600 hover:bg-red-50 rounded"
					title="Ta bort" @onclick="() => OnDelete.InvokeAsync(Meal)">
				🗑️
			</button>
		</div>
	</div>

	@if (Meal.Ingredients.Count > 0)
	{
		<div>
			<p class="text-xs uppercase tracking-wide text-slate-500 mb-1">Ingredienser</p>
			<div class="flex flex-wrap gap-1">
				@foreach (var ingredient in Meal.Ingredients)
				{
					<span class="text-xs px-2 py-0.5 bg-slate-100 text-slate-700 rounded">@ingredient.Name</span>
				}
			</div>
		</div>
	}
</div>

@code {
	[Parameter, EditorRequired] public MealResponse Meal { get; set; } = default!;
	[Parameter] public EventCallback<MealResponse> OnEdit { get; set; }
	[Parameter] public EventCallback<MealResponse> OnDelete { get; set; }
}
