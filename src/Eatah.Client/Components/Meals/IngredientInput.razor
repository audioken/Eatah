@namespace Eatah.Client.Components.Meals

<div>
	<label class="eatah-ingredient-input__label">Ingredienser</label>

	@for (var i = 0; i < Ingredients.Count; i++)
	{
		var index = i;
		<div class="eatah-ingredient-input__row">
			<input type="text"
				   class="eatah-ingredient-input__field"
				   placeholder="t.ex. Tomater"
				   value="@Ingredients[index]"
				   @oninput="e => Update(index, e.Value?.ToString() ?? string.Empty)" />
			<button type="button"
					class="eatah-ingredient-input__remove"
					disabled="@(Ingredients.Count <= 1)"
					title="Ta bort ingrediens"
					@onclick="() => Remove(index)">
				<Icon Name="close" Size="14" />
			</button>
		</div>
	}

	<button type="button"
			class="eatah-ingredient-input__add-btn"
			@onclick="Add">
		+ Lägg till ingrediens
	</button>
</div>

@code {
	[Parameter] public List<string> Ingredients { get; set; } = [];
	[Parameter] public EventCallback<List<string>> IngredientsChanged { get; set; }

	private async Task Update(int index, string value)
	{
		Ingredients[index] = value;
		await IngredientsChanged.InvokeAsync(Ingredients);
	}

	private async Task Add()
	{
		Ingredients.Add(string.Empty);
		await IngredientsChanged.InvokeAsync(Ingredients);
	}

	private async Task Remove(int index)
	{
		if (Ingredients.Count <= 1)
		{
			return;
		}
		Ingredients.RemoveAt(index);
		await IngredientsChanged.InvokeAsync(Ingredients);
	}
}
