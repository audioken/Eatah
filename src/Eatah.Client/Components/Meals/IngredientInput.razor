@namespace Eatah.Client.Components.Meals

<div class="eatah-ingredient-input">
	<label class="eatah-ingredient-input__label">Ingredienser</label>

	@if (_chips.Any())
	{
		<div class="eatah-ingredient-input__chips">
			@foreach (var name in _chips)
			{
				var capName = name;
				<span class="eatah-ingredient-input__chip">
					@capName
					<button type="button" class="eatah-ingredient-input__chip-remove" @onclick="() => Remove(capName)"
							aria-label="Ta bort @capName">
						<Icon Name="close" Size="10" />
					</button>
				</span>
			}
		</div>
	}

	<IngredientSearch Placeholder="Sök eller lägg till ingrediens…" OnSelected="AddIngredient" />
</div>

@code {
	[Parameter] public List<string> Ingredients { get; set; } = [];
	[Parameter] public EventCallback<List<string>> IngredientsChanged { get; set; }

	private IEnumerable<string> _chips => Ingredients.Where(i => !string.IsNullOrWhiteSpace(i));

	private async Task AddIngredient(IngredientResponse ingredient)
	{
		var name = ingredient.Name.Trim();
		if (!Ingredients.Any(i => i.Equals(name, StringComparison.OrdinalIgnoreCase)))
		{
			Ingredients.RemoveAll(i => string.IsNullOrWhiteSpace(i));
			Ingredients.Add(name);
			await IngredientsChanged.InvokeAsync(Ingredients);
		}
	}

	private async Task Remove(string name)
	{
		Ingredients.RemoveAll(i => i.Equals(name, StringComparison.OrdinalIgnoreCase));
		await IngredientsChanged.InvokeAsync(Ingredients);
	}
}
