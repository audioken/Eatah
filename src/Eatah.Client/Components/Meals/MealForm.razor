@namespace Eatah.Client.Components.Meals

@if (IsOpen)
{
	<div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4" @onclick="HandleBackdrop">
		<div class="bg-white rounded-lg shadow-xl w-full max-w-lg max-h-[90vh] flex flex-col"
			 @onclick:stopPropagation="true">
			<div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
				<h2 class="text-lg font-semibold">@Title</h2>
				<button type="button" class="text-slate-400 hover:text-slate-700" @onclick="Cancel">✕</button>
			</div>

			<div class="p-5 space-y-4 overflow-y-auto">
				@if (UnsavedNotice is not null)
				{
					<div class="p-3 rounded-md bg-amber-50 border border-amber-200 text-amber-800 text-sm">
						@UnsavedNotice
					</div>
				}
				@if (_error is not null)
				{
					<div class="p-3 rounded-md bg-red-50 border border-red-200 text-red-700 text-sm">
						@_error
					</div>
				}

				<div>
					<label for="meal-name" class="block text-sm font-semibold text-slate-700 mb-1">Namn</label>
					<input id="meal-name" type="text"
						   class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-500"
						   @bind="_name" @bind:event="oninput" />
					@if (_nameError is not null)
					{
						<p class="mt-1 text-xs text-red-600">@_nameError</p>
					}
				</div>

				<div>
					<label for="meal-category" class="block text-sm font-semibold text-slate-700 mb-1">Kategori</label>
					<select id="meal-category"
							class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-500"
							@bind="_category">
						<option value="@MealCategory.Meat">Kött</option>
						<option value="@MealCategory.Fish">Fisk</option>
						<option value="@MealCategory.Vegetarian">Vegetariskt</option>
						<option value="@MealCategory.Vegan">Veganskt</option>
					</select>
				</div>

				<div>
					<label for="meal-time" class="block text-sm font-semibold text-slate-700 mb-1">Tillagningstid
						(min)</label>
						<input id="meal-time" type="number" min="1" max="600" placeholder="valfritt"
							   class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-500"
							   @bind="_cookingTimeMinutes" />
						@if (_cookingTimeError is not null)
						{
							<p class="mt-1 text-xs text-red-600">@_cookingTimeError</p>
						}
					</div>

					<IngredientInput Ingredients="_ingredients" IngredientsChanged="OnIngredientsChanged" />
					@if (_ingredientsError is not null)
					{
						<p class="text-xs text-red-600">@_ingredientsError</p>
					}
				</div>

				<div class="px-5 py-4 border-t border-slate-200 flex items-center justify-end gap-2">
					<button type="button" class="px-4 py-2 rounded-md border border-slate-300 text-slate-700 hover:bg-slate-50"
							disabled="@_isSaving" @onclick="Cancel">
						Avbryt
					</button>
					<button type="button"
							class="px-4 py-2 rounded-md bg-brand-600 text-white font-semibold hover:bg-brand-700 disabled:opacity-50"
							disabled="@_isSaving" @onclick="Save">
						@(_isSaving ? "Sparar…" : "Spara")
					</button>
				</div>
			</div>
		</div>
	}

@code {
	[Parameter] public bool IsOpen { get; set; }
	[Parameter] public MealResponse? Meal { get; set; }
	[Parameter] public string? InitialName { get; set; }
	[Parameter] public MealCategory? InitialCategory { get; set; }
	[Parameter] public List<string>? InitialIngredients { get; set; }
	[Parameter] public int? InitialCookingTimeMinutes { get; set; }
	[Parameter] public string? UnsavedNotice { get; set; }
	[Parameter] public EventCallback<MealFormResult> OnSubmit { get; set; }
	[Parameter] public EventCallback OnClose { get; set; }

	private string _name = string.Empty;
	private MealCategory _category = MealCategory.Vegetarian;
	private List<string> _ingredients = [string.Empty];
	private int? _cookingTimeMinutes;
	private string? _nameError;
	private string? _ingredientsError;
	private string? _cookingTimeError;
	private string? _error;
	private bool _isSaving;
	private object? _lastLoadedKey;

	private string Title => Meal is null ? "Ny maträtt" : "Redigera maträtt";

	protected override void OnParametersSet()
	{
		if (!IsOpen)
		{
			return;
		}

		var key = (object?)Meal ?? new { InitialName, InitialCategory, InitialIngredients, InitialCookingTimeMinutes };
		if (!Equals(_lastLoadedKey, key))
		{
			_lastLoadedKey = key;
			if (Meal is not null)
			{
				_name = Meal.Name;
				_category = Meal.Category;
				_ingredients = Meal.Ingredients.Select(i => i.Name).ToList();
				_cookingTimeMinutes = Meal.CookingTimeMinutes;
			}
			else
			{
				_name = InitialName ?? string.Empty;
				_category = InitialCategory ?? MealCategory.Vegetarian;
				_ingredients = InitialIngredients is { Count: > 0 }
					? new List<string>(InitialIngredients)
					: [string.Empty];
				_cookingTimeMinutes = InitialCookingTimeMinutes;
			}

			if (_ingredients.Count == 0)
			{
				_ingredients.Add(string.Empty);
			}

			_nameError = null;
			_ingredientsError = null;
			_cookingTimeError = null;
			_error = null;
		}
	}

	private void OnIngredientsChanged(List<string> next)
	{
		_ingredients = next;
	}

	private bool Validate()
	{
		_nameError = string.IsNullOrWhiteSpace(_name) ? "Namnet är obligatoriskt." : null;

		var cleaned = _ingredients.Select(i => i.Trim()).Where(i => i.Length > 0).ToList();
		_ingredientsError = cleaned.Count == 0 ? "Minst en ingrediens krävs." : null;

		_cookingTimeError = _cookingTimeMinutes.HasValue && (_cookingTimeMinutes.Value < 1 || _cookingTimeMinutes.Value > 600)
			? "Tillagningstiden måste vara mellan 1 och 600 minuter."
			: null;

		return _nameError is null && _ingredientsError is null && _cookingTimeError is null;
	}

	private async Task Save()
	{
		if (!Validate())
		{
			return;
		}

		_isSaving = true;
		_error = null;
		try
		{
			var ingredients = _ingredients.Select(i => i.Trim()).Where(i => i.Length > 0).ToList();
			await OnSubmit.InvokeAsync(new MealFormResult(_name.Trim(), _category, ingredients, _cookingTimeMinutes));
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte spara: {ex.Message}";
		}
		finally
		{
			_isSaving = false;
		}
	}

	private Task Cancel() => OnClose.InvokeAsync();

	private Task HandleBackdrop() => Cancel();

	public record MealFormResult(string Name, MealCategory Category, List<string> Ingredients, int? CookingTimeMinutes);
}
