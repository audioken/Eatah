@* A password input with a show/hide eye toggle and an optional strength meter. *@

<div class="eatah-password-input @CssClass">
    <input class="eatah-password-input__field" type="@(_visible ? "text" : "password")" value="@Value"
           @oninput="OnInput" placeholder="@Placeholder" autocomplete="@Autocomplete" disabled="@Disabled" />
    <button type="button" class="eatah-password-input__toggle" @onclick="ToggleVisibility"
            aria-label="@(_visible ? "Dölj lösenord" : "Visa lösenord")" tabindex="-1">
        <Icon Name="@(_visible ? "eye-off" : "eye")" Size="20" />
    </button>
</div>

@if (ShowStrength && !string.IsNullOrEmpty(Value))
{
    var checks = ComputeChecks(Value);
    <ul class="eatah-strength-meter">
        @foreach (var check in checks)
        {
            <li class="eatah-strength-meter__item @(check.Met ? "is-met" : "")">
                <Icon Name="@(check.Met ? "check" : "circle")" Size="14" />
                <span>@check.Label</span>
            </li>
        }
    </ul>
}

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; } = "Lösenord";
    [Parameter] public string Autocomplete { get; set; } = "current-password";
    [Parameter] public bool ShowStrength { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? CssClass { get; set; }

    private bool _visible;

    private void ToggleVisibility() => _visible = !_visible;

    private Task OnInput(ChangeEventArgs e)
        => ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);

    private record StrengthCheck(string Label, bool Met);

    private static IReadOnlyList<StrengthCheck> ComputeChecks(string pwd) =>
    [
        new("Minst 8 tecken", pwd.Length >= 8),
        new("En stor bokstav", pwd.Any(char.IsUpper)),
        new("En liten bokstav", pwd.Any(char.IsLower)),
        new("En siffra", pwd.Any(char.IsDigit)),
        new("Ett specialtecken", pwd.Any(c => !char.IsLetterOrDigit(c)))
    ];
}
