@* ============================================================
   <Icon Name="dice" Size="24" CssClass="..." />
   Renders a Font Awesome solid icon. currentColor controls the colour.
   Add new icons by mapping a semantic name to an FA icon name in IconMap below.
   ============================================================ *@

<i class="fa-solid fa-@FaName eatah-icon @CssClass" style="@SizeStyle" role="img" aria-label="@(AriaLabel ?? Name)"></i>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = string.Empty;

    /// <summary>Pixel size; if null the icon inherits font-size (1em).</summary>
    [Parameter] public int? Size { get; set; }

    [Parameter] public string? CssClass { get; set; }

    [Parameter] public string? AriaLabel { get; set; }

    private string FaName
    {
        get
        {
            var mapped = IconMap.TryGetValue(Name, out var m) ? m : Name;
            // FA class is fa-{name}; strip the trailing -solid suffix used in the old file names.
            return mapped.EndsWith("-solid") ? mapped[..^"-solid".Length] : mapped;
        }
    }

    private string SizeStyle => Size.HasValue ? $"font-size:{Size}px;" : string.Empty;

    private static readonly IReadOnlyDictionary<string, string> IconMap = new Dictionary<string,
string>(StringComparer.OrdinalIgnoreCase)
    {
        // Categories
        ["vegan"] = "seedling-solid",
        ["vegetarian"] = "carrot-solid",
        ["fish"] = "fish-solid",
        ["poultry"] = "drumstick-bite-solid",
        ["meat"] = "bacon-solid",

        // Actions / UI
        ["dice"] = "dice-solid",
        ["magic"] = "wand-magic-sparkles-solid",
        ["bell"] = "bell-solid",
        ["basket"] = "basket-shopping-solid",
        ["chat"] = "comments-solid",
        ["profile"] = "circle-user-solid",
        ["calendar"] = "calendar-days-solid",
        ["list"] = "list-solid",
        ["trash"] = "trash-solid",
        ["edit"] = "pen-to-square-solid",
        ["eye"] = "eye-solid",
        ["eye-off"] = "eye-slash-solid",
        ["close"] = "xmark-solid",
        ["plus"] = "plus-solid",
        ["house"] = "house-solid",
        ["user"] = "user-solid",
        ["check"] = "check-solid",
        ["chevron-down"] = "angle-down-solid",
        ["chevron-up"] = "angle-up-solid",
        ["chevron-right"] = "angle-right-solid",
        ["chevron-left"] = "angle-left-solid",
        ["arrow-left"] = "arrow-left-solid",
        ["question"] = "question-solid",
        ["warning"] = "exclamation-solid",
        ["logout"] = "right-from-bracket-solid",
        ["send"] = "paper-plane-solid",
        ["thumbs-up"] = "thumbs-up-solid",
        ["thumbs-down"] = "thumbs-down-solid",
        ["face-laugh"] = "face-laugh-solid",
        ["face-sad"] = "face-sad-tear-solid",
        ["heart"] = "heart-solid",
        ["angle-down-solid"] = "angle-down-solid",
        ["angle-right-solid"] = "angle-right-solid",
    };
}
