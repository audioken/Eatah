@*
    Three-slot header rendered once by MainLayout. Pages set the slots
    through HeaderState (DI singleton) in OnInitialized and clear them
    on dispose. Falling back to Parameter-bound RenderFragments lets
    consumers also render their own AppHeader inline if preferred.
*@
@implements IDisposable
@inject HeaderState State

<header class="eatah-header">
    <div class="eatah-header__left">
        @if (LeftFragment is not null)
        {
            @LeftFragment
        }
        else
        {
            <span>@LeftPlaceholder</span>
        }
    </div>
    <div class="eatah-header__center">
        @if (CenterFragment is not null)
        {
            @CenterFragment
        }
        else
        {
            <span>@CenterPlaceholder</span>
        }
    </div>
    <div class="eatah-header__right">
        @if (RightFragment is not null)
        {
            @RightFragment
        }
        else
        {
            <button type="button" class="eatah-header__placeholder-bell"
                    style="background:transparent;border:none;color:inherit;padding:6px;cursor:pointer;" aria-label="Notiser"
                    @onclick="OnPlaceholderBellClick">
                <Icon Name="bell" Size="22" />
            </button>
        }
    </div>
</header>

@code {
    [Parameter] public RenderFragment? Left { get; set; }
    [Parameter] public RenderFragment? Center { get; set; }
    [Parameter] public RenderFragment? Right { get; set; }

    [Parameter] public string LeftPlaceholder { get; set; } = "Personligt";
    [Parameter] public string CenterPlaceholder { get; set; } = "Eatah";

    [Inject] private ToastService Toasts { get; set; } = default!;

    private RenderFragment? LeftFragment => Left ?? State.Left;
    private RenderFragment? CenterFragment => Center ?? State.Center;
    private RenderFragment? RightFragment => Right ?? State.Right;

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }

    private void OnPlaceholderBellClick()
    {
        Toasts.Show("Notiser kommer snart");
    }
}
