@namespace Eatah.Client.Components.Shared
@inject WorkspaceState Workspaces
@inject ModalService Modals
@implements IDisposable

@*
    Read-only household label in the header. Each user belongs to at most one
    household; renaming/leaving/creating happens in ProfileModal. Tapping the
    label opens the profile modal so it's discoverable.
*@
<button type="button" class="eatah-workspace-picker__btn" @onclick="OpenProfile" title="@(_label)">
    <Icon Name="house" Size="14" CssClass="eatah-workspace-picker__icon" />
    <span class="eatah-workspace-picker__label">@_label</span>
</button>

@code {
    private string _label = "Hushåll";

    protected override void OnInitialized()
    {
        Workspaces.OnChange += UpdateLabel;
        UpdateLabel();
    }

    private void UpdateLabel()
    {
        _label = Workspaces.Current?.Name ?? "Inget hushåll";
        InvokeAsync(StateHasChanged);
    }

    private void OpenProfile()
    {
        Modals.Show<Eatah.Client.Components.Profile.ProfileModal>();
    }

    public void Dispose() => Workspaces.OnChange -= UpdateLabel;
}
