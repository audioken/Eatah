@using Microsoft.AspNetCore.Components.Rendering
@inject ModalService Modals
@implements IDisposable
@inject IJSRuntime JS

@if (Modals.Stack.Count > 0)
{
    @foreach (var instance in Modals.Stack)
    {
        <div class="eatah-modal-backdrop @(instance == _closingInstance ? "eatah-modal-backdrop--closing" : "")"
             @onclick="OnBackdropClick">
            <div class="eatah-modal @(instance == _closingInstance ? "eatah-modal--closing" : "")"
                 @onclick:stopPropagation="true">
                <CascadingValue Value="instance" IsFixed="true">
                    <DynamicComponent Type="instance.ComponentType" Parameters="instance.Parameters" />
                </CascadingValue>
            </div>
        </div>
    }
}

@code {
    private bool _bodyLocked;
    private ModalInstance? _closingInstance;

    protected override void OnInitialized()
    {
        Modals.OnChange += OnModalsChanged;
        Modals.CloseRequested += OnCloseRequested;
    }

    private async void OnModalsChanged()
    {
        await InvokeAsync(async () =>
        {
            var shouldLock = Modals.Stack.Count > 0;
            if (shouldLock != _bodyLocked)
            {
                _bodyLocked = shouldLock;
                try
                {
                    await JS.InvokeVoidAsync("eval",
                        shouldLock
                            ? "document.body.classList.add('eatah-modal-open')"
                            : "document.body.classList.remove('eatah-modal-open')");
                }
                catch
                {
                    // JS may be unavailable during prerender — safe to ignore.
                }
            }
            StateHasChanged();
        });
    }

    private async void OnCloseRequested(ModalInstance instance)
    {
        await InvokeAsync(async () =>
        {
            _closingInstance = instance;
            StateHasChanged();
            await Task.Delay(200);
            _closingInstance = null;
            Modals.Close(instance);
        });
    }

    private void OnBackdropClick()
    {
        Modals.RequestCloseTop();
    }

    public void Dispose()
    {
        Modals.OnChange -= OnModalsChanged;
        Modals.CloseRequested -= OnCloseRequested;
    }
}
