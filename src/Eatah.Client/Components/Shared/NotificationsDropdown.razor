@namespace Eatah.Client.Components.Shared
@inject ApiClient Api
@inject WorkspaceState Workspaces
@inject ToastService Toasts
@inject ModalService Modals
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="eatah-notif-bell" @onclick="ToggleDropdownAsync" @onclick:stopPropagation="true">
    <Icon Name="bell" Size="22" />
    @if (_unreadCount > 0)
    {
        <span class="eatah-notif-bell__badge">@(_unreadCount > 9 ? "9+" : _unreadCount.ToString())</span>
    }
</div>

@if (_open)
{
    <div class="eatah-notif-dropdown" @onclick:stopPropagation="true">
        <div class="eatah-notif-dropdown__header">
            <span>Notiser</span>
            @if (_notifications.Any(n => n.ReadAt is null))
            {
                <button type="button" class="eatah-notif-dropdown__mark-all" @onclick="MarkAllReadAsync">
                    Markera alla som lästa
                </button>
            }
        </div>
        <div class="eatah-notif-dropdown__list">
            @if (_notifications.Count == 0)
            {
                <p class="eatah-notif-dropdown__empty">Inga notiser.</p>
            }
            else
            {
                @foreach (var notif in _notifications)
                {
                    <div class="eatah-notif-item @(notif.ReadAt is null ? "eatah-notif-item--unread" : "")">
                        <div class="eatah-notif-item__content">
                            <p class="eatah-notif-item__text">@GetNotifText(notif)</p>
                            <span class="eatah-notif-item__time">@FormatTime(notif.CreatedAt)</span>
                        </div>
                        @if (notif.Type == NotificationType.FriendRequest && notif.ReadAt is null)
                        {
                            var reqId = ParseFriendRequestPayload(notif.Payload);
                            @if (reqId != Guid.Empty)
                            {
                                <div class="eatah-notif-item__actions">
                                    <button type="button" class="eatah-notif-item__btn eatah-notif-item__btn--accept"
                                            @onclick="() => RespondAsync(reqId, notif.Id, true)">
                                        Acceptera
                                    </button>
                                    <button type="button" class="eatah-notif-item__btn eatah-notif-item__btn--reject"
                                            @onclick="() => RespondAsync(reqId, notif.Id, false)">
                                        Neka
                                    </button>
                                </div>
                            }
                        }
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback OnFriendRequestResponded { get; set; }

    private bool _open;
    private List<NotificationResponse> _notifications = [];
    private int _unreadCount;
    private System.Threading.Timer? _pollTimer;
    private DotNetObjectReference<NotificationsDropdown>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        await LoadAsync();
        _pollTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadAsync();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadAsync()
    {
        try
        {
            _notifications = await Api.GetNotificationsAsync();
            _unreadCount = _notifications.Count(n => n.ReadAt is null);
        }
        catch { }
    }

    private async Task ToggleDropdownAsync()
    {
        _open = !_open;
        if (_open)
        {
            await LoadAsync();
            await JS.InvokeVoidAsync("eatahUi.registerNotifClose", _dotNetRef);
        }
        else
        {
            await JS.InvokeVoidAsync("eatahUi.unregisterNotifClose");
        }
    }

    [JSInvokable]
    public void CloseFromOutside()
    {
        _open = false;
        InvokeAsync(StateHasChanged);
    }

    private async Task MarkAllReadAsync()
    {
        try
        {
            await Api.MarkAllNotificationsAsReadAsync();
            await LoadAsync();
        }
        catch { }
    }

    private async Task RespondAsync(Guid requestId, Guid notifId, bool accept)
    {
        if (accept)
        {
            var confirmed = await ShowAcceptConfirmAsync(requestId);
            if (!confirmed) return;
        }

        try
        {
            await Api.RespondToFriendRequestAsync(requestId, accept);
            // Accepting moves the user to a new workspace and deletes the old one.
            // Reset the stale cached workspace ID now so subsequent requests don't send
            // the old (now-deleted) workspace ID in X-Eatah-Workspace → would get 403.
            if (accept)
                Workspaces.Reset();
            await Api.MarkNotificationAsReadAsync(notifId);
            await LoadAsync();
            if (accept)
            {
                await Workspaces.RefreshAsync();
                Toasts.Show("Du har gått med i hushållet!");
            }
            await OnFriendRequestResponded.InvokeAsync();
        }
        catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.FriendRequestNotFound)
        {
            Toasts.Show("Inbjudan är inte längre giltig.");
            await LoadAsync();
        }
        catch
        {
            Toasts.Show("Något gick fel. Försök igen.");
        }
    }

    private async Task<bool> ShowAcceptConfirmAsync(Guid requestId)
    {
        var currentHousehold = Workspaces.Current;
        var isInSharedHousehold = currentHousehold?.MemberCount > 1;

        // Try to get the new household name from the notification payload
        var notif = _notifications.FirstOrDefault(n =>
        {
            var parsed = ParseFriendRequestPayload(n.Payload);
            return parsed == requestId;
        });
        var newHouseholdName = ParseHouseholdNameFromPayload(notif?.Payload ?? "");
        var inviterName = ParseStringFromPayload(notif?.Payload ?? "", "fromDisplayName");
        var displayName = !string.IsNullOrWhiteSpace(newHouseholdName)
            ? newHouseholdName
            : (!string.IsNullOrWhiteSpace(inviterName) ? $"{inviterName}s hushåll" : "det nya hushållet");

        string title;
        string message;
        string confirmText;

        if (isInSharedHousehold)
        {
            var oldName = currentHousehold!.Name;
            title = "Byta hushåll?";
            message = $"Du lämnar \"{oldName}\" och går med i \"{displayName}\". " +
                      "All din nuvarande data i hushållet kopplas bort och du får det nya hushållets innehåll.";
            confirmText = $"Lämna {oldName} och gå med i {displayName}";
        }
        else
        {
            title = "Gå med i hushåll?";
            message = $"Du går med i \"{displayName}\". Din personliga data och maträtter raderas och ersätts med hushållets innehåll.";
            confirmText = "Gå med";
        }

        var instance = Modals.Show<ConfirmDialog>(new Dictionary<string, object?>
        {
            ["Title"] = title,
            ["Message"] = message,
            ["ConfirmText"] = confirmText,
            ["IsDanger"] = isInSharedHousehold,
        });
        var result = await instance.Result;
        return result is true;
    }

    private string GetNotifText(NotificationResponse notif)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(notif.Payload);
            return notif.Type switch
            {
                NotificationType.FriendRequest =>
                    doc.RootElement.TryGetProperty("fromDisplayName", out var n)
                        ? $"{n.GetString()} undrar om du vill gå med i deras hushåll"
                        : "Någon vill att du går med i deras hushåll",
                NotificationType.FriendRequestAccepted =>
                    doc.RootElement.TryGetProperty("byDisplayName", out var n)
                        ? $"{n.GetString()} accepterade din inbjudan"
                        : "Din inbjudan accepterades",
                NotificationType.HouseholdMemberLeft =>
                    doc.RootElement.TryGetProperty("displayName", out var dn)
                        ? $"{dn.GetString()} lämnade hushållet"
                        : "En medlem lämnade hushållet",
                _ => "Ny notis"
            };
        }
        catch { return "Notis"; }
    }

    private Guid ParseFriendRequestPayload(string payload)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(payload);
            if (doc.RootElement.TryGetProperty("requestId", out var rid) && rid.TryGetGuid(out var id))
                return id;
        }
        catch { }
        return Guid.Empty;
    }

    private static string ParseHouseholdNameFromPayload(string payload) =>
        ParseStringFromPayload(payload, "householdName");

    private static string ParseStringFromPayload(string payload, string key)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(payload);
            if (doc.RootElement.TryGetProperty(key, out var val))
                return val.GetString() ?? "";
        }
        catch { }
        return "";
    }

    private static string FormatTime(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;
        if (diff.TotalMinutes < 1) return "Just nu";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes} min sedan";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours} tim sedan";
        return utc.ToLocalTime().ToString("d MMM");
    }

    public async ValueTask DisposeAsync()
    {
        _pollTimer?.Dispose();
        await JS.InvokeVoidAsync("eatahUi.unregisterNotifClose");
        _dotNetRef?.Dispose();
    }
}
