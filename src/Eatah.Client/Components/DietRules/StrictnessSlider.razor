@namespace Eatah.Client.Components.DietRules

<div class="p-4 rounded-lg border border-slate-200 bg-white">
	<div class="flex items-center justify-between mb-2">
		<label for="strictness" class="text-sm font-semibold text-slate-700">Strikthet</label>
		<span class="text-sm font-mono text-slate-600">@Percent%</span>
	</div>
	<input id="strictness"
		   type="range"
		   min="0"
		   max="100"
		   step="5"
		   value="@Percent"
		   @oninput="OnInput"
		   class="w-full accent-brand-600" />
	<div class="flex justify-between text-xs text-slate-500 mt-1">
		<span>Slumpmässigt</span>
		<span>Följer regler strikt</span>
	</div>
</div>

@code {
	[Parameter] public double Value { get; set; }
	[Parameter] public EventCallback<double> ValueChanged { get; set; }

	private int Percent => (int)Math.Round(Math.Clamp(Value, 0.0, 1.0) * 100);

	private Task OnInput(ChangeEventArgs e)
	{
		if (!int.TryParse(e.Value?.ToString(), out var percent))
		{
			return Task.CompletedTask;
		}

		var next = Math.Clamp(percent / 100.0, 0.0, 1.0);
		Value = next;
		return ValueChanged.InvokeAsync(next);
	}
}
