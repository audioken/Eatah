@namespace Eatah.Client.Components.DietRules
@inject ApiClient Api
@inject ModalService Modals
@inject ToastService Toasts
@inject DietProfileState ProfileState

<div class="eatah-diet-modal">
    <div class="eatah-diet-modal__header">
        <h2 class="eatah-diet-modal__title">Kostprofiler</h2>
        <button type="button" class="eatah-diet-modal__close" @onclick="Close" aria-label="Stäng">
            <Icon Name="close" Size="20" />
        </button>
    </div>

    <div class="eatah-diet-modal__body">

        @* ── Create section ── *@
        <section class="eatah-diet-modal__section">

            @* Mode toggle *@
            <div class="eatah-diet-modal__mode-row">
                <span
                    class="eatah-diet-modal__mode-label @(!_manualMode ? "eatah-diet-modal__mode-label--active" : "")">
                    <Icon Name="dice" Size="13" CssClass="eatah-diet-modal__mode-icon" />AI
                </span>
                <label class="eatah-diet-modal__switch" aria-label="Byt till manuellt läge">
                    <input type="checkbox" @bind="_manualMode" />
                    <span class="eatah-diet-modal__switch-track"></span>
                </label>
                <span class="eatah-diet-modal__mode-label @(_manualMode ? "eatah-diet-modal__mode-label--active" : "")">
                    Manuellt
                </span>
            </div>

            @if (!_manualMode)
            {
                <p class="eatah-diet-modal__description">
                    Ge profilen ett namn och beskriv ditt mål – t.ex. viktnedgång eller mer växtbaserat – så genereras
                    reglerna av AI.
                </p>
            }

            <div class="eatah-diet-modal__field">
                <label class="eatah-diet-modal__label" for="diet-name">Namn</label>
                <input id="diet-name" class="eatah-diet-modal__input" @bind="_name" @bind:event="oninput"
                       placeholder="t.ex. LCHF" />
            </div>

            @if (!_manualMode)
            {
                <div class="eatah-diet-modal__field">
                    <label class="eatah-diet-modal__label" for="diet-desc">Beskrivning / mål</label>
                    <textarea id="diet-desc" class="eatah-diet-modal__input eatah-diet-modal__input--textarea" rows="2"
                              @bind="_description" @bind:event="oninput"
                              placeholder="t.ex. Fokus på viktnedgång och lågt kolhydratintag"></textarea>
                </div>
            }
            else
            {
                @* Manual rule editor *@
                <div class="eatah-diet-modal__manual-rules">
                    @foreach (var category in AllCategories)
                    {
                        var min = _manualRules[category].Min;
                        var max = _manualRules[category].Max;
                        <div class="eatah-diet-modal__manual-row">
                            <span class="eatah-diet-modal__manual-cat">@CategoryLabel(category)</span>
                            <div class="eatah-diet-modal__manual-controls">
                                <span class="eatah-diet-modal__stepper-label">Min</span>
                                <div class="eatah-diet-modal__stepper">
                                    <button type="button" class="eatah-diet-modal__stepper-btn"
                                            @onclick="() => AdjustMin(category, -1)" disabled="@(min <= 0)">−</button>
                                    <span class="eatah-diet-modal__stepper-val">@min</span>
                                    <button type="button" class="eatah-diet-modal__stepper-btn"
                                            @onclick="() => AdjustMin(category, +1)" disabled="@(min >= 7)">+</button>
                                </div>
                                <span class="eatah-diet-modal__stepper-label eatah-diet-modal__stepper-label--max">Max</span>
                                <div class="eatah-diet-modal__stepper">
                                    <button type="button" class="eatah-diet-modal__stepper-btn"
                                            @onclick="() => AdjustMax(category, -1)" disabled="@(max <= 0)">−</button>
                                    <span class="eatah-diet-modal__stepper-val">@max</span>
                                    <button type="button" class="eatah-diet-modal__stepper-btn"
                                            @onclick="() => AdjustMax(category, +1)" disabled="@(max >= 7)">+</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (_error is not null)
            {
                <p class="eatah-diet-modal__error">@_error</p>
            }

            <button class="eatah-diet-modal__generate-btn" @onclick="SubmitAsync"
                    disabled="@(_busy || string.IsNullOrWhiteSpace(_name))">
                @if (_busy)
                {
                    <span class="eatah-btn-spinner"></span>
                    <span>@(_manualMode ? "Sparar…" : "Genererar…")</span>
                }
                else
                {
                    @if (!_manualMode)
                    {
                        <Icon Name="dice" Size="16" CssClass="eatah-diet-modal__generate-icon" />
                    }
                    <span>@(_manualMode ? "Spara profil" : "Generera profil")</span>
                }
            </button>
        </section>

        @* ── Profiles list ── *@
        <section class="eatah-diet-modal__section eatah-diet-modal__section--list">
            @if (_profiles is null)
            {
                <LoadingSpinner IsAi="true" Label="Laddar profiler…" />
            }
            else if (_profiles.Count == 0)
            {
                <p class="eatah-diet-modal__empty">Inga profiler ännu. Skapa din första ovan!</p>
            }
            else
            {
                <ul class="eatah-diet-modal__list">
                    @foreach (var profile in _profiles)
                    {
                        var isExpanded = _expandedId == profile.Id;
                        <li class="eatah-diet-modal__list-item">
                            <div class="eatah-diet-modal__item-row">
                                <button type="button" class="eatah-diet-modal__item-toggle"
                                        @onclick="() => ToggleExpand(profile.Id)" aria-expanded="@isExpanded.ToString().ToLower()">
                                    <span class="eatah-diet-modal__item-name">@profile.Name</span>
                                    <Icon Name="@(isExpanded ? "chevron-up" : "chevron-down")" Size="16"
                                          CssClass="eatah-diet-modal__item-chevron" />
                                </button>
                                <button type="button" class="eatah-diet-modal__item-delete"
                                        @onclick="() => DeleteAsync(profile)" title="Ta bort @profile.Name"
                                        aria-label="Ta bort @profile.Name">
                                    <Icon Name="trash" Size="16" />
                                </button>
                            </div>

                            @if (isExpanded)
                            {
                                <ul class="eatah-diet-modal__rules">
                                    @foreach (var rule in profile.Rules)
                                    {
                                        <li class="eatah-diet-modal__rule">
                                            <span class="eatah-diet-modal__rule-cat">@CategoryLabel(rule.Category)</span>
                                            <span class="eatah-diet-modal__rule-range">@rule.MinPerWeek–@rule.MaxPerWeek / vecka</span>
                                            <span class="eatah-diet-modal__rule-desc">@rule.Description</span>
                                        </li>
                                    }
                                </ul>
                            }
                        </li>
                    }
                </ul>
            }
        </section>

    </div>
</div>

@code {
    private static readonly MealCategory[] AllCategories =
        [MealCategory.Meat, MealCategory.Poultry, MealCategory.Fish, MealCategory.Vegetarian, MealCategory.Vegan];

    private sealed class RuleValues { public int Min; public int Max; }

    [CascadingParameter] private ModalInstance? ModalInstance { get; set; }

    private List<DietProfileResponse>? _profiles;
    private string _name = string.Empty;
    private string _description = string.Empty;
    private bool _manualMode;
    private bool _busy;
    private string? _error;
    private Guid? _expandedId;

    private readonly Dictionary<MealCategory, RuleValues> _manualRules =
        AllCategories.ToDictionary(c => c, _ => new RuleValues { Min = 0, Max = 0 });

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private void Close() => Modals.CloseTop();

    private void ToggleExpand(Guid id)
    {
        _expandedId = _expandedId == id ? null : id;
    }

    private void AdjustMin(MealCategory category, int delta)
    {
        var rule = _manualRules[category];
        rule.Min = Math.Clamp(rule.Min + delta, 0, 7);
        if (rule.Max < rule.Min) rule.Max = rule.Min;
    }

    private void AdjustMax(MealCategory category, int delta)
    {
        var rule = _manualRules[category];
        rule.Max = Math.Clamp(rule.Max + delta, 0, 7);
        if (rule.Min > rule.Max) rule.Min = rule.Max;
    }

    private static string CategoryLabel(MealCategory c) => c switch
    {
        MealCategory.Meat => "Rött kött",
        MealCategory.Poultry => "Fågel",
        MealCategory.Fish => "Fisk",
        MealCategory.Vegetarian => "Vegetariskt",
        MealCategory.Vegan => "Veganskt",
        _ => c.ToString()
    };

    private async Task LoadAsync()
    {
        try
        {
            _profiles = await Api.GetDietProfilesAsync();
        }
        catch (ApiException ex)
        {
            _error = $"Kunde inte hämta profiler: {ex.Message}";
        }
    }

    private Task SubmitAsync() => _manualMode ? CreateManualAsync() : GenerateAsync();

    private async Task GenerateAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || _busy) return;

        _busy = true;
        _error = null;
        try
        {
            var request = new GenerateDietProfileRequest(_name.Trim(), _description.Trim());
            var generated = await Api.GenerateDietProfileAsync(request);
            if (generated is not null)
            {
                _name = string.Empty;
                _description = string.Empty;
                _expandedId = generated.Id;
                await LoadAsync();
                ProfileState.NotifyChanged();
                Toasts.Show($"Kostprofil \"{generated.Name}\" skapad!");
            }
        }
        catch (ApiException ex)
        {
            _error = ex.Error?.Detail ?? ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CreateManualAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || _busy) return;

        _busy = true;
        _error = null;
        try
        {
            var rules = AllCategories
                .Select(c => new CreateDietRuleRequest(c, _manualRules[c].Min, _manualRules[c].Max))
                .ToList();

            var request = new CreateDietProfileRequest(_name.Trim(), rules);
            var created = await Api.CreateDietProfileAsync(request);
            if (created is not null)
            {
                _name = string.Empty;
                foreach (var v in _manualRules.Values) { v.Min = 0; v.Max = 0; }
                _expandedId = created.Id;
                await LoadAsync();
                ProfileState.NotifyChanged();
                Toasts.Show($"Kostprofil \"{created.Name}\" skapad!");
            }
        }
        catch (ApiException ex)
        {
            _error = ex.Error?.Detail ?? ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync(DietProfileResponse profile)
    {
        try
        {
            await Api.DeleteDietProfileAsync(profile.Id);
            if (_expandedId == profile.Id) _expandedId = null;
            _profiles?.Remove(profile);
            Toasts.Show($"\"{profile.Name}\" borttagen.");
        }
        catch (ApiException)
        {
            Toasts.Show("Kunde inte ta bort profilen.");
        }
    }
}
