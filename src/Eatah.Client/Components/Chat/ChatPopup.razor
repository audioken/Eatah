@inject ApiClient Api
@inject ChatState ChatState
@inject ChatHubService Hub
@inject AuthState Auth
@inject WorkspaceState Workspace
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (ChatState.IsOpen)
{
    <div class="eatah-chat-overlay" @onclick="CloseIfBackdrop">
        <div class="eatah-chat-panel" @onclick:stopPropagation="true">

            <div class="eatah-chat-panel__body">

                <!-- Thread list sidebar -->
                <div class="eatah-chat-panel__sidebar">
                    <div class="eatah-chat-panel__sidebar-header">
                        <span>Chattar</span>
                        <button type="button" class="eatah-chat-panel__close" @onclick="() => ChatState.Close()">
                            <Icon Name="close" Size="16" />
                        </button>
                    </div>

                    <div class="eatah-chat-panel__thread-list">
                        @foreach (var thread in _threads)
                        {
                            var isActive = ChatState.ActiveThread?.Id == thread.Id;
                            <button type="button"
                                    class="eatah-chat-thread-item @(isActive ? "eatah-chat-thread-item--active" : "")"
                                    @onclick="() => SelectThread(thread)">
                                @if (thread.Type == "Group")
                                {
                                    <div class="eatah-chat-thread-item__avatar eatah-chat-thread-item__avatar--group">
                                        <Icon Name="house" Size="14" />
                                    </div>
                                    <div class="eatah-chat-thread-item__info">
                                        <span class="eatah-chat-thread-item__name">Hushållet</span>
                                        @if (thread.LastMessagePreview is not null)
                                        {
                                            <span class="eatah-chat-thread-item__preview">@thread.LastMessagePreview</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="eatah-chat-thread-item__avatar">
                                        <Icon Name="profile" Size="14" />
                                    </div>
                                    <div class="eatah-chat-thread-item__info">
                                        <span class="eatah-chat-thread-item__name">@(thread.DirectPartnerDisplayName ?? "Okänd")</span>
                                        @if (thread.LastMessagePreview is not null)
                                        {
                                            <span class="eatah-chat-thread-item__preview">@thread.LastMessagePreview</span>
                                        }
                                    </div>
                                }
                            </button>
                        }

                        @if (_isLoading)
                        {
                            <div class="eatah-chat-panel__loading">Laddar…</div>
                        }
                    </div>
                </div>

                <!-- Active thread view -->
                <div class="eatah-chat-panel__thread">
                    @if (ChatState.ActiveThread is { } activeThread)
                    {
                        <div class="eatah-chat-panel__thread-header">
                            @if (activeThread.Type == "Group")
                            {
                                <Icon Name="house" Size="15" CssClass="eatah-chat-panel__thread-icon" />
                                <span>Hushållet</span>
                            }
                            else
                            {
                                <Icon Name="profile" Size="15" CssClass="eatah-chat-panel__thread-icon" />
                                <span>@(activeThread.DirectPartnerDisplayName ?? "Okänd")</span>
                            }
                        </div>
                        <ChatThreadView Thread="activeThread" />
                    }
                    else
                    {
                        <div class="eatah-chat-panel__empty">Välj en konversation</div>
                    }
                </div>

            </div>

        </div>
    </div>
}

@code {
    private List<ChatThreadSummaryResponse> _threads = [];
    private bool _isLoading = false;
    private DotNetObjectReference<ChatPopup>? _selfRef;
    private bool _visibilityRegistered;

    protected override void OnInitialized()
    {
        ChatState.OnChanged += OnChatStateChanged;
        Workspace.OnChange += OnWorkspaceChanged;
    }

    private async void OnChatStateChanged()
    {
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            if (ChatState.IsOpen && !_threads.Any())
                await LoadThreadsAsync();
        });
    }

    private async void OnWorkspaceChanged()
    {
        await EnsureHubStartedAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        await EnsureHubStartedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_visibilityRegistered)
        {
            _visibilityRegistered = true;
            _selfRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("eatahChat.registerVisibility", _selfRef); }
            catch { /* ignore — JS may not be loaded yet in some hosts */ }
        }
    }

    /// <summary>
    /// Called from JS when the app/tab regains visibility, focus or network.
    /// On iOS Safari (PWA) the WebSocket is killed in the background; we proactively
    /// reconnect and rejoin the active thread so live messages keep flowing.
    /// </summary>
    [JSInvokable]
    public async Task OnAppResumed(string reason)
    {
        if (!Workspace.CurrentId.HasValue) return;
        await Hub.EnsureConnectedAsync();
        // ChatThreadView handles its own rejoin via Hub.Reconnected event,
        // but ensure the connection is at least alive even when no thread is open.
    }

    private async Task EnsureHubStartedAsync()
    {
        if (Workspace.CurrentId.HasValue)
            await Hub.EnsureConnectedAsync();
    }

    private async Task LoadThreadsAsync()
    {
        _isLoading = true;
        try
        {
            _threads = await Api.GetChatThreadsAsync();

            // If no active thread, select the group thread by default
            if (ChatState.ActiveThread is null && _threads.FirstOrDefault(t => t.Type == "Group") is { } group)
                ChatState.SetActiveThread(group);
        }
        catch { }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void SelectThread(ChatThreadSummaryResponse thread)
    {
        ChatState.SetActiveThread(thread);
    }

    private void CloseIfBackdrop() => ChatState.Close();

    public async ValueTask DisposeAsync()
    {
        ChatState.OnChanged -= OnChatStateChanged;
        Workspace.OnChange -= OnWorkspaceChanged;
        if (_visibilityRegistered)
        {
            try { await JS.InvokeVoidAsync("eatahChat.unregisterVisibility"); }
            catch { }
        }
        _selfRef?.Dispose();
    }
}
