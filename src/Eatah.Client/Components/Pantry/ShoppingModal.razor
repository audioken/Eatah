            coverage.CoveredSessionIds.Add(dayPlanId);
    }

    private async Task CoverAllAndConfirmAsync()
    {
        foreach (var cov in _pendingCoverage)
            foreach (var s in cov.AllSessions)
                cov.CoveredSessionIds.Add(s.DayPlanId);
        await ConfirmCoverageAsync();
    }

    private async Task ConfirmCoverageAsync()
    {
        _coveragePopupOpen = false;
        foreach (var coverage in _pendingCoverage)
        {
            try
            {
                PantryItemResponse? pantryItem = null;
                try { pantryItem = await Api.AddToPantryAsync(coverage.Item.IngredientId); }
                catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists) { }

                if (pantryItem is not null)
                {
                    PantryState.AddItem(pantryItem);
                    CheckState.AddPantryName(coverage.Item.Name);
                }

                // Persist coverage answers per session so the pending question won't be re-asked.
                foreach (var session in coverage.AllSessions)
                {
                    var covers = coverage.CoveredSessionIds.Contains(session.DayPlanId);
                    try
                    {
                        await Api.SetPantryCoverageAsync(coverage.Item.IngredientId, session.DayPlanId, covers);
                        CheckState.MarkCoverage(coverage.Item.Name, session.DayPlanId, covers);
                    }
                    catch { /* best-effort */ }
                }

                var remainingNotes = BuildRemainingNotesByDayPlan(coverage.Item.Notes, coverage.CoveredSessionIds);
                if (remainingNotes is null)
                {
                    // All sessions covered: remove shopping item entirely
                    await Api.RemoveFromShoppingListAsync(coverage.Item.Id);
                    ShoppingState.RemoveItem(coverage.Item.Id);
                }
                else
                {
                    // Some sessions remain: update Notes to keep only uncovered entries
                    await Api.AddToShoppingListAsync(coverage.Item.IngredientId, remainingNotes);
                    ShoppingState.AddOrUpdateItem(coverage.Item with { Notes = remainingNotes });
                }
            }
            catch (Exception ex) { _error = ex.Message; }
        }
        _pendingCoverage.Clear();
    }

    /// <summary>Rebuilds Notes keeping only parts whose DayPlanId is NOT in coveredDayPlans (and parts without DayPlanId).
    /// Returns null if everything is covered.</summary>
    private static string? BuildRemainingNotesByDayPlan(string? originalNotes, HashSet<Guid> coveredDayPlans)
    {
        if (string.IsNullOrEmpty(originalNotes)) return null;
        var remaining = originalNotes
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(part =>
            {
                var (_, _, _, dpId) = ParseNoteEntry(part);
                return !dpId.HasValue || !coveredDayPlans.Contains(dpId.Value);
            })
            .ToList();
        return remaining.Count > 0 ? string.Join(", ", remaining) : null;
    }

