@namespace Eatah.Client.Components.WeeklyPlan
@using Eatah.Client.Services
@implements IDisposable
@inject ApiClient Api
@inject IngredientCheckState CheckState

<div class="relative w-full max-w-[420px] h-[80px] select-none">

	@* Action layer behind the card *@
	<div class="absolute inset-0 flex items-center justify-between px-1 pointer-events-none">

		@* Left action: trash (revealed when sliding right) *@
		<div class="pointer-events-auto transition-opacity duration-150" style="opacity: @LeftOpacity;">
			<button type="button"
					class="inline-flex items-center justify-center h-[45px] rounded-full bg-[#F24E4E] text-white hover:brightness-95 disabled:opacity-40"
					style="filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.25)); width: @TrashButtonWidth;"
					title="Ta bort maträtt" disabled="@(Day.Meal is null)" @onclick:stopPropagation="true"
					@onclick="HandleClear">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="@IconPaths.TrashCanViewBox" fill="currentColor"
					 class="w-5 h-5 flex-shrink-0">
					<path d="@IconPaths.TrashCanPath" />
				</svg>
			</button>
		</div>

		@* Right actions: AI + dice (revealed when sliding left) *@
		<div class="flex items-center gap-2 pointer-events-auto transition-opacity duration-150"
			 style="opacity: @RightOpacity;">
			<button type="button"
					class="inline-flex items-center justify-center w-[45px] h-[45px] rounded-full bg-[#A014B9] text-white hover:brightness-110"
					style="filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.25));" title="Generera maträtt med AI"
					@onclick:stopPropagation="true" @onclick="HandleRandomAi">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="@IconPaths.WandSparklesViewBox" fill="currentColor"
					 class="w-[22px] h-[22px] flex-shrink-0">
					<path d="@IconPaths.WandSparklesPath" />
				</svg>
			</button>
			<button type="button"
					class="inline-flex items-center justify-center h-[45px] rounded-full bg-[#4ED4F2] text-white hover:brightness-110"
					style="filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.25)); width: @DiceButtonWidth;"
					title="Slumpa maträtt" @onclick:stopPropagation="true" @onclick="HandleRandomDb">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="@IconPaths.DiceViewBox" fill="currentColor"
					 class="w-[22px] h-[22px] flex-shrink-0">
					<path d="@IconPaths.DicePath" />
				</svg>
			</button>
		</div>
	</div>

	@* Sliding card surface *@
	<div class="relative h-full w-full rounded-[15px] border border-black/10 font-kanit overflow-hidden cursor-pointer touch-pan-y"
		 style="transform: translateX(@OffsetCss); transition: @(_dragging ? "none" : "transform .25s ease"); background: @CardBackground; box-shadow: @CardShadow;"
		 @onpointerdown="OnPointerDown" @onpointermove="OnPointerMove" @onpointerup="OnPointerUp"
		 @onpointercancel="OnPointerUp" @onclick="HandleClick">

		@* Day + meal *@
		<div class="absolute left-[15px] top-[8px] right-[70px]">
			<div class="flex items-center gap-2">
				<span class="text-white font-medium leading-[1.2] text-[24px] uppercase tracking-tight truncate">@DayLabel</span>
				@if (IsToday)
				{
					<span class="shrink-0 text-[10px] font-bold leading-none px-[7px] py-[3px] rounded-full bg-white/40 text-white uppercase tracking-[0.12em]">idag</span>
				}
			</div>
			<div class="text-dayCardText font-medium text-[16px] leading-[2.25] truncate">
				@(Day.Meal?.Name ?? "Ingen maträtt vald")
			</div>
		</div>

		@* Badge top-right *@
		<div class="absolute right-[8px] top-[2px]">
			@if (Day.Meal is not null)
			{
				<CategoryBadge Meal="Day.Meal" />
			}
		</div>

		@* Checklist tile bottom-right *@
		<button type="button"
				class="absolute right-[8px] bottom-[8px] inline-flex items-center justify-center w-[45px] h-[34px] rounded-[15px] bg-[#BCBCAC] hover:brightness-95 transition disabled:opacity-50"
				style="filter: drop-shadow(0px 4px 4px rgba(0,0,0,0.25));"
				title="@(Day.Meal is not null ? "Ingredienschecklista" : "Ingen maträtt")" disabled="@(Day.Meal is null)"
				@onclick:stopPropagation="true" @onclick="OpenChecklist">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="@IconPaths.ListViewBox" fill="white"
				 class="w-[18px] h-[18px]">
				<path d="@IconPaths.ListPath" />
			</svg>

			@if (Day.Meal is not null)
			{
				if (AllIngredientsChecked)
				{
					<span
						class="absolute -top-1 -right-1 inline-flex items-center justify-center w-[15px] h-[15px] rounded-full bg-[#7CD331]">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="@IconPaths.CheckViewBox" fill="white" class="w-2 h-2">
							<path d="@IconPaths.CheckPath" />
						</svg>
					</span>
				}
				else
				{
					<span
					class="absolute -top-1 -right-1 inline-flex items-center justify-center w-[15px] h-[15px] rounded-full bg-[#F24E4E] text-white text-[10px] leading-none font-bold">!</span>
				}
			}
			else
			{
				<span
				class="absolute -top-1 -right-1 inline-flex items-center justify-center w-[15px] h-[15px] rounded-full bg-[#8D8D83] text-white text-[10px] leading-none font-bold">?</span>
			}
		</button>
	</div>
</div>

<IngredientChecklist IsOpen="_checklistOpen" MealId="Day.Meal?.Id" MealName="@Day.Meal?.Name"
					 OnClose="CloseChecklist" />

@code {
	[Parameter, EditorRequired] public DayPlanResponse Day { get; set; } = default!;
	[Parameter] public EventCallback<DayPlanResponse> OnSelect { get; set; }
	[Parameter] public EventCallback<DayPlanResponse> OnClear { get; set; }
	[Parameter] public EventCallback<DayPlanResponse> OnRandomDb { get; set; }
	[Parameter] public EventCallback<DayPlanResponse> OnRandomAi { get; set; }

	private const double LeftRevealPx = 60; // shows trash
	private const double RightRevealPx = -120; // shows AI + dice
	private const double LeftTriggerPx = 140; // past this on release => delete
	private const double RightTriggerPx = -210; // past this on release => randomize
	private const double DragThresholdPx = 8;
	private const double SnapThresholdPx = 30;
	private const double NormalButtonPx = 45;
	private const double MaxButtonPx = 118; // pill width at full overshoot

	private static readonly System.Globalization.CultureInfo Inv = System.Globalization.CultureInfo.InvariantCulture;

	private double _offset;
	private double _startX;
	private double _startOffset;
	private bool _dragging;
	private bool _dragMoved;
	private bool _checklistOpen;
	private Guid? _loadedMealId;

	private string OffsetCss => _offset.ToString("0.##", Inv) + "px";

	private string LeftOpacity =>
		(_offset > 5 ? Math.Min(1, _offset / LeftRevealPx) : 0).ToString("0.##", Inv);

	private string RightOpacity =>
		(_offset < -5 ? Math.Min(1, _offset / RightRevealPx) : 0).ToString("0.##", Inv);

	private string TrashButtonWidth
	{
		get
		{
			if (_offset <= LeftRevealPx) return NormalButtonPx.ToString("0", Inv) + "px";
			var span = LeftTriggerPx - LeftRevealPx;
			var progress = Math.Min(1, (_offset - LeftRevealPx) / span);
			return (NormalButtonPx + (MaxButtonPx - NormalButtonPx) * progress).ToString("0.##", Inv) + "px";
		}
	}

	private string DiceButtonWidth
	{
		get
		{
			if (_offset >= RightRevealPx) return NormalButtonPx.ToString("0", Inv) + "px";
			var span = RightTriggerPx - RightRevealPx; // negative
			var progress = Math.Min(1, (_offset - RightRevealPx) / span);
			return (NormalButtonPx + (MaxButtonPx - NormalButtonPx) * progress).ToString("0.##", Inv) + "px";
		}
	}

	private bool AllIngredientsChecked =>
		Day.Meal is { } m && CheckState.AreAllChecked(m.Id);

	protected override void OnInitialized()
	{
		CheckState.OnChange += StateHasChanged;
	}

	protected override async Task OnParametersSetAsync()
	{
		if (Day.Meal is { } m && _loadedMealId != m.Id)
		{
			_loadedMealId = m.Id;
			if (!CheckState.HasIngredients(m.Id))
			{
				try
				{
					var meal = await Api.GetMealAsync(m.Id);
					var names = meal?.Ingredients.Select(i => i.Name) ?? Enumerable.Empty<string>();
					CheckState.SetIngredients(m.Id, names);
				}
				catch
				{
					// Silently ignore – badge will fall back to "missing".
				}
			}
		}
		else if (Day.Meal is null)
		{
			_loadedMealId = null;
		}
	}

	public void Dispose()
	{
		CheckState.OnChange -= StateHasChanged;
	}

	private bool IsToday => Day.DayOfWeek == DateTime.Today.DayOfWeek;

	private string CardBackground => IsToday
		? "linear-gradient(90deg, #896124 0%, #D4A843 91.83%)"
		: "linear-gradient(90deg, #839B7F 0%, #A8D1AA 91.83%)";

	private string CardShadow => IsToday
		? "0px 4px 12px rgba(212,168,67,0.45), 0px 4px 4px rgba(0,0,0,0.25)"
		: "0px 4px 4px rgba(0,0,0,0.25)";

	private string DayLabel => Day.DayOfWeek switch
	{
		DayOfWeek.Monday => "Måndag",
		DayOfWeek.Tuesday => "Tisdag",
		DayOfWeek.Wednesday => "Onsdag",
		DayOfWeek.Thursday => "Torsdag",
		DayOfWeek.Friday => "Fredag",
		DayOfWeek.Saturday => "Lördag",
		DayOfWeek.Sunday => "Söndag",
		_ => Day.DayOfWeek.ToString()
	};

	private void OnPointerDown(PointerEventArgs e)
	{
		_dragging = true;
		_dragMoved = false;
		_startX = e.ClientX;
		_startOffset = _offset;
	}

	private void OnPointerMove(PointerEventArgs e)
	{
		if (!_dragging) return;
		var delta = e.ClientX - _startX;
		if (Math.Abs(delta) > DragThresholdPx) _dragMoved = true;
		var next = _startOffset + delta;
		// Allow overshoot up to the trigger thresholds, then rubber-band beyond.
		if (next > LeftTriggerPx) next = LeftTriggerPx + (next - LeftTriggerPx) * 0.2;
		else if (next < RightTriggerPx) next = RightTriggerPx + (next - RightTriggerPx) * 0.2;
		_offset = next;
	}

	private async Task OnPointerUp(PointerEventArgs e)
	{
		if (!_dragging) return;
		_dragging = false;

		// Overshoot triggers the action and snaps the card back.
		if (_offset >= LeftTriggerPx)
		{
			_offset = 0;
			_dragMoved = false;
			if (Day.Meal is not null)
				await OnClear.InvokeAsync(Day);
			return;
		}
		if (_offset <= RightTriggerPx)
		{
			_offset = 0;
			_dragMoved = false;
			await OnRandomDb.InvokeAsync(Day);
			return;
		}

		if (_offset >= SnapThresholdPx) _offset = LeftRevealPx;
		else if (_offset <= -SnapThresholdPx) _offset = RightRevealPx;
		else _offset = 0;
	}

	private Task HandleClick()
	{
		// Swallow click that resulted from a drag gesture.
		if (_dragMoved)
		{
			_dragMoved = false;
			return Task.CompletedTask;
		}
		// If actions are revealed, first tap closes them.
		if (_offset != 0)
		{
			_offset = 0;
			return Task.CompletedTask;
		}
		return OnSelect.InvokeAsync(Day);
	}

	private Task HandleClear()
	{
		_offset = 0;
		return OnClear.InvokeAsync(Day);
	}

	private Task HandleRandomDb()
	{
		_offset = 0;
		return OnRandomDb.InvokeAsync(Day);
	}

	private Task HandleRandomAi()
	{
		_offset = 0;
		return OnRandomAi.InvokeAsync(Day);
	}

	private void OpenChecklist()
	{
		if (Day.Meal is null) return;
		_checklistOpen = true;
	}

	private void CloseChecklist() => _checklistOpen = false;
}
