@namespace Eatah.Client.Components.WeeklyPlan
@using Eatah.Client.Services
@implements IDisposable
@inject ApiClient Api
@inject IngredientCheckState CheckState
@inject PantryStateService PantryState
@inject ShoppingStateService ShoppingState
@inject ShoppingSyncService ShoppingSync

@if (IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4"
         style="padding-top: max(1rem, var(--header-height, 56px)); padding-bottom: max(1rem, var(--navbar-height, 82px));"
         @onclick="HandleClose">
        <div class="eatah-modal font-kanit" @onclick:stopPropagation="true">

            @* Header *@
            <div class="px-5 pt-4 pb-3 flex items-center justify-between flex-shrink-0">
                <div>
                    <div class="font-bold text-[20px] leading-tight uppercase tracking-tight" style="color: var(--color-text-dark)">
                        Ingredienser
                    </div>
                    @if (!string.IsNullOrWhiteSpace(MealName))
                    {
                        <div class="font-medium text-[14px] leading-tight" style="color: rgba(51,62,47,0.65)">@MealName</div>
                    }
                </div>
                <button type="button"
                        class="inline-flex items-center justify-center w-[32px] h-[32px] rounded-full bg-black/10 hover:bg-black/20 text-base"
                        style="color: var(--color-text-dark)"
                        title="Stäng" @onclick="HandleClose">
                    ✕
                </button>
            </div>

            @* Two-column body *@
            @if (_isLoading)
            {
                <div class="px-4 py-6 text-center text-sm" style="color: rgba(51,62,47,0.7)">Laddar ingredienser…</div>
            }
            else if (_ingredients is null || _ingredients.Count == 0)
            {
                <div class="px-4 py-6 text-center text-sm" style="color: rgba(51,62,47,0.7)">Inga ingredienser registrerade.</div>
            }
            else
            {
                <div class="grid grid-cols-2 gap-2 px-3 pb-4 max-h-[60vh] overflow-y-auto">

                    @* Left: Skafferi – ingredients already in pantry *@
                    <div>
                        <div class="flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-wider mb-2 px-1"
                             style="color: rgba(51,62,47,0.55)">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="@IconPaths.CheckViewBox" fill="currentColor"
                                 class="w-3 h-3">
                                <path d="@IconPaths.CheckPath" />
                            </svg>
                            Skafferi
                        </div>
                        @if (!PantryIngredients.Any())
                        {
                            <div class="text-[12px] italic px-1 py-1" style="color: rgba(51,62,47,0.4)">Ingenting ännu</div>
                        }
                        @foreach (var name in PantryIngredients)
                        {
                            var (pantryCovered, pantryTotal) = CheckState.GetCoverageFraction(name);
                            var sharedCount = pantryTotal > 0 ? pantryTotal : CheckState.GetSharedSessionCount(name);
                            <div class="flex items-center gap-2 px-2 py-[6px] rounded-[10px] bg-black/[0.06] border border-black/10 mb-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="@IconPaths.CheckViewBox" fill="#7CD331"
                                     class="w-[11px] h-[11px] flex-shrink-0">
                                    <path d="@IconPaths.CheckPath" />
                                </svg>
                                <span class="text-[13px] font-medium line-through leading-snug min-w-0 flex-1 truncate"
                                      style="color: rgba(51,62,47,0.5)">@name</span>
                                @if (pantryTotal > 1 && pantryCovered < pantryTotal)
                                {
                                    <span class="shrink-0 text-[#F2A20C] text-[10px] font-semibold leading-none">@pantryCovered/@pantryTotal</span>
                                }
                                else if (pantryTotal > 1)
                                {
                                    <span class="shrink-0 text-[10px] font-semibold leading-none"
                                          style="color: rgba(51,62,47,0.4)">@pantryTotal/@pantryTotal</span>
                                }
                                else if (sharedCount > 1)
                                {
                                    <span class="shrink-0 text-[10px] font-semibold leading-none"
                                          style="color: rgba(51,62,47,0.4)">(@sharedCount)</span>
                                }
                            </div>
                        }
                    </div>

                    @* Right: Köp – ingredients not yet in pantry *@
                    <div>
                        <div class="flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-wider mb-2 px-1"
                             style="color: rgba(51,62,47,0.55)">
                            <Icon Name="basket" Size="12" />
                            Köp
                        </div>
                        @if (_selectedMissing.Count > 0)
                        {
                            <div class="eatah-checklist-actions mb-2">
                                <button type="button" class="eatah-checklist-actions__btn eatah-checklist-actions__btn--primary"
                                        @onclick="MoveSelectedToPantryAsync">
                                    <Icon Name="arrow-left" Size="12" />
                                    <span>Till skafferi</span>
                                </button>
                                <div class="eatah-checklist-actions__slot" />
                                <div class="eatah-checklist-actions__slot" />
                            </div>
                        }
                        @if (!MissingIngredients.Any())
                        {
                            <div class="text-[12px] italic px-1 py-1" style="color: rgba(51,62,47,0.5)">Allt klart ✓</div>
                        }
                        @foreach (var name in MissingIngredients)
                        {
                            var onList = _shoppingNames.Contains(name);
                            var isSelected = _selectedMissing.Contains(name);
                            var rowClass = isSelected ? "bg-[#5AAE00]/15 border-[#5AAE00]/30" : onList ? "bg-[#5AAE00]/10 border-[#5AAE00]/20" : "bg-black/[0.04] border-black/10";
                            var selectClass = isSelected ? "eatah-checklist-select--active" : "";
                            var textClass = isSelected ? "opacity-100" : onList ? "opacity-80" : "opacity-60";
                            var missingCount = CheckState.GetUncoveredSessionCount(name);
                            <div class="flex items-center gap-1.5 px-2 py-[6px] rounded-[10px] border mb-1.5 cursor-pointer @rowClass"
                                 @onclick="() => ToggleMissingSelection(name)">
                                <span class="eatah-checklist-select @selectClass">
                                    @if (isSelected)
                                    {
                                        <Icon Name="check" Size="9" />
                                    }
                                </span>
                                <span class="text-[13px] font-medium leading-snug min-w-0 flex-1 truncate @textClass"
                                      style="color: var(--color-text-dark)">@name</span>
                                @if (missingCount > 1)
                                {
                                    <span class="shrink-0 text-[10px] font-semibold leading-none"
                                          style="color: rgba(51,62,47,0.45)">(@missingCount)</span>
                                }
                            </div>
                        }
                    </div>

                </div>
            }
        </div>
    </div>
}

@* Coverage popup – rendered on top of the ingredient modal (z-70 > modal z-50) *@
@if (_coveragePopupOpen)
{
    <div class="fixed inset-0 z-[70] flex items-center justify-center bg-black/50 p-4"
         style="padding-top: max(1rem, var(--header-height, 56px)); padding-bottom: max(1rem, var(--navbar-height, 82px));"
         @onclick="() => _coveragePopupOpen = false">
        <div class="eatah-modal font-kanit" @onclick:stopPropagation="true">

            <div class="px-5 pt-4 pb-2 flex-shrink-0">
                <div class="font-bold text-[18px] uppercase tracking-tight leading-tight"
                     style="color: var(--color-text-dark)">
                    Räcker till fler rätter?
                </div>
                <div class="text-[13px] mt-1" style="color: rgba(51,62,47,0.6)">
                    Bocka av vilka rätter ingrediensen räcker till.
                </div>
            </div>

            <div class="px-4 pb-2 max-h-[50vh] overflow-y-auto space-y-3">
                @foreach (var cov in _pendingCoverage)
                {
                    <div>
                        <div class="font-semibold text-[14px] mb-2 px-1" style="color: var(--color-text-dark)">
                            @cov.IngredientName</div>
                            @foreach (var weekGrp in cov.AllSessions.GroupBy(s => s.WeekNumber).OrderBy(g => g.Key ?? 9999))
                            {
                                <div class="font-extrabold text-[11px] uppercase tracking-[0.03em] px-[10px] py-[5px] rounded-[8px] mb-1.5"
                                     style="background: rgba(0,0,0,0.07); color: rgba(51,62,47,0.55)">
                                    @GetCoverageWeekLabel(weekGrp.Key)
                                </div>
                                @foreach (var session in weekGrp)
                                {
                                    var isCovered = cov.CoveredSessionIds.Contains(session.DayPlanId);
                                    var isOrigin = session.DayPlanId == cov.OriginDayPlanId;
                                    var rowClass = isOrigin && isCovered
                                        ? "bg-[#5AAE00]/15 border-[#5AAE00]/30 ring-1 ring-[#5AAE00]/20"
                                        : isCovered ? "bg-[#5AAE00]/10 border-[#5AAE00]/20" : "bg-black/[0.04] border-black/10";
                                    <label class="flex items-center gap-2.5 px-3 py-2 rounded-[10px] border cursor-pointer mb-1 @rowClass">
                                        <input type="checkbox" class="w-4 h-4 cursor-pointer flex-shrink-0" checked="@isCovered"
                                               @onchange="@(() => ToggleCoverage(cov, session.DayPlanId))" />
                                        <span class="text-[13px] font-medium flex-1 min-w-0 truncate"
                                              style="color: var(--color-text-dark)">@session.MealName</span>
                                        <span class="eatah-shopping-group__day">@session.DayName</span>
                                    </label>
                                }
                            }
                        </div>
                    }
                </div>

                @{
                    var onlyOriginCovered = _pendingCoverage.All(cov =>
                        cov.OriginDayPlanId.HasValue &&
                        cov.CoveredSessionIds.Count == 1 &&
                        cov.CoveredSessionIds.Contains(cov.OriginDayPlanId.Value));
                    var confirmBtnLabel = onlyOriginCovered ? "RÄCKER TILL DENNA" : "Spara urval";
                }
                <div class="px-4 pb-5 pt-2 flex gap-2">
                    <button type="button"
                            class="flex-1 eatah-modal-footer__btn eatah-modal-footer__btn--primary uppercase tracking-wide"
                            @onclick="CoverAllAndConfirmAsync">
                        Räcker till alla
                    </button>
                    <button type="button" class="flex-1 eatah-modal-footer__btn eatah-modal-footer__btn--ghost"
                            @onclick="ConfirmCoverageAsync">
                        @confirmBtnLabel
                    </button>
                </div>
            </div>
        </div>
    }

    @* Pending-coverage prompt – asks per ingredient whether pantry stock covers THIS session *@
    @if (_pendingMealCoverage.Count > 0 && _pendingCoverageDayPlanId is not null && IsOpen)
    {
        <div class="fixed inset-0 z-[80] flex items-center justify-center bg-black/50 p-4"
             style="padding-top: max(1rem, var(--header-height, 56px)); padding-bottom: max(1rem, var(--navbar-height, 82px));">
            <div class="eatah-modal font-kanit">
                <div class="px-5 pt-4 pb-2 flex-shrink-0">
                    <div class="font-bold text-[18px] uppercase tracking-tight leading-tight"
                         style="color: var(--color-text-dark)">
                        Räcker skafferiet?
                    </div>
                    @if (!string.IsNullOrWhiteSpace(MealName))
                    {
                        <div class="font-medium text-[13px] leading-tight mt-1" style="color: rgba(51,62,47,0.7)">@MealName</div>
                    }
                </div>
                <div class="px-4 pb-2 max-h-[55vh] overflow-y-auto space-y-2">
                    @foreach (var ing in _pendingMealCoverage.ToList())
                    {
                        <div class="px-3 py-2.5 rounded-[12px] border"
                             style="background: rgba(0,0,0,0.04); border-color: rgba(0,0,0,0.1)">
                            <div class="text-[14px] mb-2" style="color: var(--color-text-dark)">
                                Det finns <span class="font-semibold">@ing</span> i skafferiet – räcker den till denna rätten?
                            </div>
                            <div class="flex gap-2">
                                <button type="button"
                                        class="flex-1 eatah-modal-footer__btn eatah-modal-footer__btn--primary uppercase tracking-wide"
                                        @onclick="() => AnswerPendingAsync(ing, true)">Ja</button>
                                <button type="button" class="flex-1 eatah-modal-footer__btn eatah-modal-footer__btn--ghost"
                                        @onclick="() => AnswerPendingAsync(ing, false)">Nej</button>
                            </div>
                        </div>
                    }
                </div>
                <div class="px-4 pb-5 pt-2">
                    <button type="button" class="w-full py-2.5 rounded-[12px] font-medium text-[12px]"
                            style="background: rgba(0,0,0,0.06); color: rgba(51,62,47,0.6)"
                            @onclick="() => { _pendingMealCoverage = []; _pendingCoverageDayPlanId = null; }">
                        Hoppa över
                    </button>
                </div>
            </div>
        </div>
    }

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? DayPlanId { get; set; }
    [Parameter] public Guid? MealId { get; set; }
    [Parameter] public string? MealName { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private List<string>? _ingredients;
    private Dictionary<string, Guid> _ingredientIds = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedMissing = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _shoppingNames = new(StringComparer.OrdinalIgnoreCase);

    // A single scheduled cooking session (a DayPlan) — distinct from a Meal so that the
    // same recipe scheduled on multiple days is asked independently.
    private record SessionRef(Guid DayPlanId, string MealName, int DayIndex, int? WeekNumber = null)
    {
        public string DayName => DayLabel(DayIndex);
        public string DisplayLabel => WeekNumber.HasValue
            ? $"{MealName} ({DayLabel(DayIndex)}, v{WeekNumber})"
            : $"{MealName} ({DayLabel(DayIndex)})";
        private static string DayLabel(int d) => d switch
        {
            0 => "Mån",
            1 => "Tis",
            2 => "Ons",
            3 => "Tor",
            4 => "Fre",
            5 => "Lör",
            _ => "Sön"
        };
    }

    private record ChecklistPendingCoverage(ShoppingItemResponse? ShoppingItem, string IngredientName, Guid IngredientId,
        List<SessionRef> AllSessions, Guid? OriginDayPlanId = null)
    {
        public HashSet<Guid> CoveredSessionIds { get; } = OriginDayPlanId is { } oid
            ? new HashSet<Guid> { oid }
            : AllSessions.Count > 0 ? new HashSet<Guid> { AllSessions[0].DayPlanId } : new HashSet<Guid>();
    }

    private bool _coveragePopupOpen;
    private List<ChecklistPendingCoverage> _pendingCoverage = [];
    private List<string> _pendingMealCoverage = [];
    private Guid? _pendingCoverageDayPlanId;
    private bool _isLoading;
    // Re-load when EITHER (DayPlanId, MealId) changes so opening a different DayCard
    // for the same meal still re-checks pending coverage for that specific session.
    private (Guid? DayPlanId, Guid? MealId) _loadedFor;

    private IEnumerable<string> PantryIngredients =>
        _ingredients?.Where(n => CheckState.IsInPantry(n) && !IsStillNeededForThisSession(n)) ?? [];

    private IEnumerable<string> MissingIngredients =>
        _ingredients?.Where(n => !CheckState.IsInPantry(n) || IsStillNeededForThisSession(n)) ?? [];

    /// <summary>
    /// True when the ingredient is still on the shopping list for THIS specific DayPlan
    /// (i.e. its DayPlanId is referenced in some shopping note).
    /// </summary>
    private bool IsStillNeededForThisSession(string ingredientName)
    {
        if (DayPlanId is not { } dpId) return false;
        return ShoppingState.Items.Any(s =>
            !s.IsChecked &&
            string.Equals(s.Name, ingredientName, StringComparison.OrdinalIgnoreCase) &&
            ExtractAllSessionIds(s.Notes).Contains(dpId));
    }

    protected override void OnInitialized()
    {
        CheckState.OnChange += StateHasChanged;
        ShoppingState.OnChanged += StateHasChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen)
        {
            _selectedMissing.Clear();
            _loadedFor = default; // force fresh shopping-list fetch on next open
            return;
        }
        if (MealId is not null && (DayPlanId, MealId) != _loadedFor)
        {
            _selectedMissing.Clear();
            await LoadAsync(MealId.Value);
        }
    }

    private async Task LoadAsync(Guid mealId)
    {
        _isLoading = true;
        try
        {
            if (CheckState.HasIngredients(mealId))
            {
                _ingredients = CheckState.GetIngredients(mealId).ToList();
            }
            else
            {
                var meal = await Api.GetMealAsync(mealId);
                var ingList = meal?.Ingredients ?? [];
                var names = ingList.Select(i => i.Name).ToList();
                CheckState.SetIngredients(mealId, names);
                _ingredients = names;
            }
            _ingredientIds.Clear(); // always re-resolve master IDs lazily on move

            // Fetch fresh shopping list so the Köp column shows a cart icon for items
            // already queued, vs "!" for ingredients not covered anywhere.
            var shopping = await Api.GetShoppingListAsync();
            _shoppingNames = shopping.Select(s => s.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);

            _loadedFor = (DayPlanId, mealId);

            // Pantry items whose coverage for THIS DayPlan is still pending get the
            // "Räcker skafferiet?" prompt before the regular checklist appears.
            if (DayPlanId is { } dpId)
            {
                var pending = CheckState.GetPendingCoverageIngredients(dpId, mealId).ToList();
                if (pending.Count > 0)
                {
                    _pendingMealCoverage = pending;
                    _pendingCoverageDayPlanId = dpId;
                }
                else
                {
                    _pendingMealCoverage = [];
                    _pendingCoverageDayPlanId = null;
                }
            }
            else
            {
                _pendingMealCoverage = [];
                _pendingCoverageDayPlanId = null;
            }
        }
        catch
        {
            _ingredients = [];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task HandleClose() => OnClose.InvokeAsync();

    private async Task AnswerPendingAsync(string ingredientName, bool covers)
    {
        if (_pendingCoverageDayPlanId is not { } dpId) return;

        if (!CheckState.TryGetPantryIngredientId(ingredientName, out var ingredientId))
        {
            // Fallback: resolve via catalog if local map is missing the entry.
            var matches = await Api.SearchIngredientsAsync(ingredientName);
            var master = matches.FirstOrDefault(i => string.Equals(i.Name, ingredientName, StringComparison.OrdinalIgnoreCase));
            if (master is null) { _pendingMealCoverage.Remove(ingredientName); return; }
            ingredientId = master.Id;
        }

        try
        {
            await Api.SetPantryCoverageAsync(ingredientId, dpId, covers);
            CheckState.MarkCoverage(ingredientName, dpId, covers);
            // Resync so the shopping list reflects the new coverage decision.
            ShoppingSync.TriggerSync();
        }
        catch
        {
            // Swallow; user can retry by reopening.
        }
        finally
        {
            _pendingMealCoverage.Remove(ingredientName);
            if (_pendingMealCoverage.Count == 0)
                _pendingCoverageDayPlanId = null;
        }
    }

    private void ToggleMissingSelection(string name)
    {
        if (!_selectedMissing.Remove(name))
            _selectedMissing.Add(name);
    }

    private async Task MoveSelectedToPantryAsync()
    {
        var toMove = _selectedMissing.ToList();
        _selectedMissing.Clear();

        // Resolve all ingredient IDs first, then split into normal vs shared
        var resolved = new List<(string Name, Guid IngredientId)>();
        foreach (var name in toMove)
        {
            if (!_ingredientIds.TryGetValue(name, out var ingId))
            {
                var matches = await Api.SearchIngredientsAsync(name);
                var master = matches.FirstOrDefault(i => string.Equals(i.Name, name, StringComparison.OrdinalIgnoreCase));
                if (master is null) { _selectedMissing.Add(name); continue; }
                ingId = master.Id;
                _ingredientIds[name] = ingId;
            }
            resolved.Add((name, ingId));
        }

        var normalItems = new List<(string Name, Guid IngredientId)>();
        var sharedPending = new List<ChecklistPendingCoverage>();

        foreach (var (name, ingId) in resolved)
        {
            var shoppingItem = ShoppingState.Items.FirstOrDefault(s => s.IngredientId == ingId && !s.IsChecked);

            // Sessions still needing confirmation. Covered ones are filtered out so the
            // popup never asks about a session the user has already answered.
            var uncoveredSessions = CheckState.GetUncoveredActiveSessionsForIngredient(name)
                .Select(s => new SessionRef(s.DayPlanId, s.MealName, s.DayIndex, s.WeekNumber))
                .OrderBy(s => s.WeekNumber ?? 9999).ThenBy(s => s.DayIndex)
                .ToList();

            // Fallback when the planner isn't loaded — derive sessions from the shopping
            // notes (covered ones get pruned during partial-coverage flows, so what
            // remains is genuinely uncovered).
            if (uncoveredSessions.Count == 0 && shoppingItem is not null)
                uncoveredSessions = ExtractAllSessionRefs(shoppingItem.Notes);

            if (uncoveredSessions.Count > 1)
                sharedPending.Add(new ChecklistPendingCoverage(shoppingItem, name, ingId, uncoveredSessions, DayPlanId));
            else
                normalItems.Add((name, ingId));
        }

        foreach (var (name, ingId) in normalItems)
        {
            try
            {
                PantryItemResponse? pantryItem = null;
                try { pantryItem = await Api.AddToPantryAsync(ingId); }
                catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists) { }

                if (pantryItem is not null)
                    PantryState.AddItem(pantryItem);

                CheckState.AddPantryName(name);

                // User added this from THIS DayPlan's checklist — record coverage=true for
                // THIS session only (other sessions of the same meal keep their own answers).
                if (DayPlanId is { } dpId)
                {
                    try
                    {
                        await Api.SetPantryCoverageAsync(ingId, dpId, true);
                        CheckState.MarkCoverage(name, dpId, true);
                    }
                    catch { /* best-effort */ }
                }

                // Strip ONLY this DayPlan's note part — sessions of other days/weeks remain
                // on the shopping list. If nothing remains, the row is removed.
                var shoppingItem = ShoppingState.Items.FirstOrDefault(s => s.IngredientId == ingId);
                if (shoppingItem is not null && DayPlanId is { } dpIdForNotes)
                {
                    var remaining = BuildRemainingNotesByDayPlan(shoppingItem.Notes, new HashSet<Guid> { dpIdForNotes });
                    if (remaining is null)
                    {
                        try { await Api.RemoveFromShoppingListAsync(shoppingItem.Id); } catch { }
                        ShoppingState.RemoveItem(shoppingItem.Id);
                    }
                    else
                    {
                        try { await Api.AddToShoppingListAsync(shoppingItem.IngredientId, remaining); } catch { }
                        ShoppingState.AddOrUpdateItem(shoppingItem with { Notes = remaining });
                    }
                }
            }
            catch (Exception)
            {
                _selectedMissing.Add(name);
            }
        }

        if (normalItems.Count > 0)
            ShoppingSync.TriggerSync();

        if (sharedPending.Count > 0)
        {
            _pendingCoverage = sharedPending;
            _coveragePopupOpen = true;
        }
    }

    private void ToggleCoverage(ChecklistPendingCoverage coverage, Guid dayPlanId)
    {
        if (!coverage.CoveredSessionIds.Remove(dayPlanId))
            coverage.CoveredSessionIds.Add(dayPlanId);
    }

    private async Task CoverAllAndConfirmAsync()
    {
        foreach (var cov in _pendingCoverage)
            foreach (var s in cov.AllSessions)
                cov.CoveredSessionIds.Add(s.DayPlanId);
        await ConfirmCoverageAsync();
    }

    private async Task ConfirmCoverageAsync()
    {
        _coveragePopupOpen = false;
        foreach (var coverage in _pendingCoverage)
        {
            try
            {
                PantryItemResponse? pantryItem = null;
                try { pantryItem = await Api.AddToPantryAsync(coverage.IngredientId); }
                catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists) { }

                if (pantryItem is not null)
                {
                    PantryState.AddItem(pantryItem);
                    CheckState.AddPantryName(coverage.IngredientName);
                }

                // Persist coverage answers per session so the pending question won't be re-asked.
                foreach (var session in coverage.AllSessions)
                {
                    var covers = coverage.CoveredSessionIds.Contains(session.DayPlanId);
                    try
                    {
                        await Api.SetPantryCoverageAsync(coverage.IngredientId, session.DayPlanId, covers);
                        CheckState.MarkCoverage(coverage.IngredientName, session.DayPlanId, covers);
                    }
                    catch { /* best-effort */ }
                }

                if (coverage.ShoppingItem is { } shopping)
                {
                    var remainingNotes = BuildRemainingNotesByDayPlan(shopping.Notes, coverage.CoveredSessionIds);
                    if (remainingNotes is null)
                    {
                        await Api.RemoveFromShoppingListAsync(shopping.Id);
                        ShoppingState.RemoveItem(shopping.Id);
                    }
                    else
                    {
                        await Api.AddToShoppingListAsync(shopping.IngredientId, remainingNotes);
                        ShoppingState.AddOrUpdateItem(shopping with { Notes = remainingNotes });
                    }
                }
            }
            catch (Exception)
            {
                _selectedMissing.Add(coverage.IngredientName);
            }
        }
        _pendingCoverage.Clear();
        ShoppingSync.TriggerSync();
    }

    private static int GetMealCount(string? notes)
    {
        if (string.IsNullOrEmpty(notes)) return 0;
        return notes.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Length;
    }

    private static string GetCoverageWeekLabel(int? weekNum)
    {
        if (weekNum is null) return "Vecka ?";
        var current = System.Globalization.ISOWeek.GetWeekOfYear(DateTime.Today);
        return weekNum == current
            ? $"V. {weekNum} (Denna vecka)"
            : $"V. {weekNum}";
    }

    /// <summary>Parses a single note part into (MealName, DayPlanId, DayIndex, WeekNumber).</summary>
    private static (string MealName, Guid? DayPlanId, int? Day, int? Week) ParseNotePart(string part)
    {
        Guid? dpId = null;
        var pipeIdx = part.LastIndexOf('|');
        if (pipeIdx > 0 && Guid.TryParseExact(part[(pipeIdx + 1)..].Trim(), "N", out var gid))
        {
            dpId = gid;
            part = part[..pipeIdx];
        }
        var vIdx = part.LastIndexOf(" v");
        if (vIdx > 0)
        {
            var suffix = part[(vIdx + 2)..].Trim();
            var dIdx = suffix.IndexOf('d');
            if (dIdx > 0 && int.TryParse(suffix[..dIdx], out var week) && int.TryParse(suffix[(dIdx + 1)..], out var day))
                return (part[..vIdx].Trim(), dpId, day, week);
            if (int.TryParse(suffix, out var weekOnly))
                return (part[..vIdx].Trim(), dpId, null, weekOnly);
        }
        return (part.Trim(), dpId, null, null);
    }

    private static List<SessionRef> ExtractAllSessionRefs(string? notes)
    {
        if (string.IsNullOrEmpty(notes)) return [];
        return notes.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(ParseNotePart)
            .Where(x => x.DayPlanId.HasValue)
            .GroupBy(x => x.DayPlanId!.Value)
            .Select(g =>
            {
                var first = g.First();
                return new SessionRef(g.Key, first.MealName, first.Day ?? 0, first.Week);
            })
            .OrderBy(s => s.WeekNumber ?? 9999)
            .ThenBy(s => s.DayIndex)
            .ToList();
    }

    private static HashSet<Guid> ExtractAllSessionIds(string? notes) =>
        ExtractAllSessionRefs(notes).Select(s => s.DayPlanId).ToHashSet();

    private static string? BuildRemainingNotesByDayPlan(string? originalNotes, HashSet<Guid> coveredDayPlans)
    {
        if (string.IsNullOrEmpty(originalNotes)) return null;
        var remaining = originalNotes
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(part =>
            {
                var (_, dpId, _, _) = ParseNotePart(part);
                // Keep parts that either have no DayPlanId (legacy/manual) or aren't covered.
                return !dpId.HasValue || !coveredDayPlans.Contains(dpId.Value);
            })
            .ToList();
        return remaining.Count > 0 ? string.Join(", ", remaining) : null;
    }

    public void Dispose()
    {
        CheckState.OnChange -= StateHasChanged;
        ShoppingState.OnChanged -= StateHasChanged;
    }
}
