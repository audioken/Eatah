@namespace Eatah.Client.Components.WeeklyPlan
@using Eatah.Client.Services
@implements IDisposable
@inject ApiClient Api
@inject IngredientCheckState CheckState
@inject PantryStateService PantryState
@inject ShoppingStateService ShoppingState
@inject ShoppingSyncService ShoppingSync

@if (IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4"
         style="padding-top: max(1rem, var(--header-height, 56px)); padding-bottom: max(1rem, var(--navbar-height, 82px));"
         @onclick="HandleClose">
        <div class="w-full max-w-[420px] rounded-[20px] border border-black/10 font-kanit overflow-hidden"
             style="background: linear-gradient(135deg, #839B7F 0%, #A8D1AA 91.83%); box-shadow: 0px 8px 24px rgba(0,0,0,0.35);"
             @onclick:stopPropagation="true">

            @* Header *@
            <div class="px-5 pt-4 pb-3 flex items-center justify-between">
                <div>
                    <div class="text-white font-medium text-[20px] leading-tight uppercase tracking-tight">
                        Ingredienser
                    </div>
                    @if (!string.IsNullOrWhiteSpace(MealName))
                    {
                        <div class="text-dayCardText font-medium text-[14px] leading-tight">@MealName</div>
                    }
                </div>
                <button type="button"
                        class="inline-flex items-center justify-center w-[32px] h-[32px] rounded-full bg-white/30 hover:bg-white/50 text-white text-base"
                        title="Stäng" @onclick="HandleClose">
                    ✕
                </button>
            </div>

            @* Two-column body *@
            @if (_isLoading)
            {
                <div class="px-4 py-6 text-center text-white/90 text-sm">Laddar ingredienser…</div>
            }
            else if (_ingredients is null || _ingredients.Count == 0)
            {
                <div class="px-4 py-6 text-center text-white/90 text-sm">Inga ingredienser registrerade.</div>
            }
            else
            {
                <div class="grid grid-cols-2 gap-2 px-3 pb-4 max-h-[60vh] overflow-y-auto">

                    @* Left: Skafferi – ingredients already in pantry *@
                    <div>
                        <div
                            class="flex items-center gap-1.5 text-white/80 text-[11px] font-semibold uppercase tracking-wider mb-2 px-1">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="@IconPaths.CheckViewBox" fill="currentColor"
                                 class="w-3 h-3">
                                <path d="@IconPaths.CheckPath" />
                            </svg>
                            Skafferi
                        </div>
                        @if (!PantryIngredients.Any())
                        {
                            <div class="text-white/50 text-[12px] italic px-1 py-1">Ingenting ännu</div>
                        }
                        @foreach (var name in PantryIngredients)
                        {
                            var (pantryCovered, pantryTotal) = CheckState.GetCoverageFraction(name);
                            var sharedCount = pantryTotal > 0 ? pantryTotal : CheckState.GetSharedMealCount(name);
                            <div
                                class="flex items-center gap-2 px-2 py-[6px] rounded-[10px] bg-white/25 border border-white/20 mb-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="@IconPaths.CheckViewBox" fill="#7CD331"
                                     class="w-[11px] h-[11px] flex-shrink-0">
                                    <path d="@IconPaths.CheckPath" />
                                </svg>
                                <span
                                class="text-dayCardText/55 text-[13px] font-medium line-through leading-snug min-w-0 flex-1 truncate">@name</span>
                                @if (pantryTotal > 1 && pantryCovered < pantryTotal)
                                {
                                    <span class="shrink-0 text-[#F2A20C] text-[10px] font-semibold leading-none">@pantryCovered/@pantryTotal</span>
                                }
                                else if (pantryTotal > 1)
                                {
                                    <span class="shrink-0 text-white/50 text-[10px] font-semibold leading-none">@pantryTotal/@pantryTotal</span>
                                }
                                else if (sharedCount > 1)
                                {
                                    <span class="shrink-0 text-white/50 text-[10px] font-semibold leading-none">(@sharedCount)</span>
                                }
                            </div>
                        }
                    </div>

                    @* Right: Köp – ingredients not yet in pantry *@
                    <div>
                        <div
                            class="flex items-center gap-1.5 text-white/80 text-[11px] font-semibold uppercase tracking-wider mb-2 px-1">
                            <Icon Name="basket" Size="12" CssClass="opacity-80" />
                            Köp
                        </div>
                        @if (_selectedMissing.Count > 0)
                        {
                            <div class="eatah-checklist-actions mb-2">
                                <button type="button" class="eatah-checklist-actions__btn eatah-checklist-actions__btn--primary"
                                        @onclick="MoveSelectedToPantryAsync">
                                    <Icon Name="arrow-left" Size="12" />
                                    <span>Till skafferi</span>
                                </button>
                                <div class="eatah-checklist-actions__slot" />
                                <div class="eatah-checklist-actions__slot" />
                            </div>
                        }
                        @if (!MissingIngredients.Any())
                        {
                            <div class="text-white/70 text-[12px] italic px-1 py-1">Allt klart ✓</div>
                        }
                        @foreach (var name in MissingIngredients)
                        {
                            var onList = _shoppingNames.Contains(name);
                            var isSelected = _selectedMissing.Contains(name);
                            var rowClass = isSelected ? "bg-white/50 border-white/60" : onList ? "bg-white/35 border-white/30" :
              "bg-white/15 border-white/10";
                            var selectClass = isSelected ? "eatah-checklist-select--active" : "";
                            var textClass = isSelected ? "opacity-100" : onList ? "opacity-80" : "opacity-60";
                            var missingCount = CheckState.GetUncoveredMealCount(name);
                            <div class="flex items-center gap-1.5 px-2 py-[6px] rounded-[10px] border mb-1.5 cursor-pointer @rowClass"
                                 @onclick="() => ToggleMissingSelection(name)">
                                <span class="eatah-checklist-select @selectClass">
                                    @if (isSelected)
                                    {
                                        <Icon Name="check" Size="9" />
                                    }
                                </span>
                                <span
                                class="text-dayCardText text-[13px] font-medium leading-snug min-w-0 flex-1 truncate @textClass">@name</span>
                                @if (missingCount > 1)
                                {
                                    <span class="shrink-0 text-white/80 text-[10px] font-semibold leading-none">(@missingCount)</span>
                                }
                            </div>
                        }
                    </div>

                </div>
            }
        </div>
    </div>
}

@* Coverage popup – rendered on top of the ingredient modal (z-70 > modal z-50) *@
@if (_coveragePopupOpen)
{
    <div class="fixed inset-0 z-[70] flex items-center justify-center bg-black/50 p-4"
         style="padding-top: max(1rem, var(--header-height, 56px)); padding-bottom: max(1rem, var(--navbar-height, 82px));"
         @onclick="() => _coveragePopupOpen = false">
        <div class="w-full max-w-[420px] rounded-[20px] border border-black/10 font-kanit overflow-hidden"
             style="background: linear-gradient(135deg, #839B7F 0%, #A8D1AA 91.83%); box-shadow: 0px 8px 24px rgba(0,0,0,0.35);"
             @onclick:stopPropagation="true">

            <div class="px-5 pt-4 pb-2">
                <div class="text-white font-medium text-[18px] uppercase tracking-tight leading-tight">
                    Räcker till fler rätter?
                </div>
                <div class="text-white/75 text-[13px] mt-1">
                    Bocka av vilka rätter ingrediensen räcker till.
                </div>
            </div>

            <div class="px-4 pb-2 max-h-[50vh] overflow-y-auto space-y-3">
                @foreach (var cov in _pendingCoverage)
                {
                    <div>
                        <div class="text-white font-semibold text-[14px] mb-1.5 px-1">@cov.IngredientName</div>
                        @foreach (var meal in cov.AllMeals)
                        {
                            var isCovered = cov.CoveredMeals.Contains(meal.Name);
                            var rowClass = isCovered ? "bg-white/35 border-white/30" : "bg-white/15 border-white/10";
                            <label class="flex items-center gap-2.5 px-3 py-2 rounded-[10px] border cursor-pointer mb-1 @rowClass">
                                <input type="checkbox" class="w-4 h-4 accent-white cursor-pointer flex-shrink-0"
                                       checked="@isCovered" @onchange="@(() => ToggleCoverage(cov, meal.Name))" />
                                <span class="text-dayCardText text-[13px] font-medium truncate">@meal.Name</span>
                            </label>
                        }
                    </div>
                }
            </div>

            <div class="px-4 pb-5 pt-2 flex gap-2">
                <button type="button"
                        class="flex-1 py-2.5 rounded-[12px] bg-white/30 hover:bg-white/45 text-white font-semibold text-[13px] uppercase tracking-wide"
                        @onclick="CoverAllAndConfirmAsync">
                    Räcker till alla
                </button>
                <button type="button"
                        class="flex-1 py-2.5 rounded-[12px] bg-white/15 hover:bg-white/25 text-white font-medium text-[13px]"
                        @onclick="ConfirmCoverageAsync">
                    Spara urval
                </button>
            </div>
        </div>
    </div>
}

@* Pending-coverage prompt – asks per ingredient whether pantry stock covers THIS meal *@
@if (_pendingMealCoverage.Count > 0 && _pendingMealCoverageMealId is not null && IsOpen)
{
    <div class="fixed inset-0 z-[80] flex items-center justify-center bg-black/50 p-4"
         style="padding-top: max(1rem, var(--header-height, 56px)); padding-bottom: max(1rem, var(--navbar-height, 82px));">
        <div class="w-full max-w-[420px] rounded-[20px] border border-black/10 font-kanit overflow-hidden"
             style="background: linear-gradient(135deg, #839B7F 0%, #A8D1AA 91.83%); box-shadow: 0px 8px 24px rgba(0,0,0,0.35);">
            <div class="px-5 pt-4 pb-2">
                <div class="text-white font-medium text-[18px] uppercase tracking-tight leading-tight">
                    Räcker skafferiet?
                </div>
                @if (!string.IsNullOrWhiteSpace(MealName))
                {
                    <div class="text-dayCardText font-medium text-[13px] leading-tight mt-1">@MealName</div>
                }
            </div>
            <div class="px-4 pb-2 max-h-[55vh] overflow-y-auto space-y-2">
                @foreach (var ing in _pendingMealCoverage.ToList())
                {
                    <div class="px-3 py-2.5 rounded-[12px] bg-white/15 border border-white/20">
                        <div class="text-white text-[14px] mb-2">
                            Det finns <span class="font-semibold">@ing</span> i skafferiet – räcker den till denna rätten?
                        </div>
                        <div class="flex gap-2">
                            <button type="button"
                                    class="flex-1 py-2 rounded-[10px] bg-white/30 hover:bg-white/45 text-white font-semibold text-[13px] uppercase tracking-wide"
                                    @onclick="() => AnswerPendingAsync(ing, true)">Ja</button>
                            <button type="button"
                                    class="flex-1 py-2 rounded-[10px] bg-white/15 hover:bg-white/25 text-white font-medium text-[13px]"
                                    @onclick="() => AnswerPendingAsync(ing, false)">Nej</button>
                        </div>
                    </div>
                }
            </div>
            <div class="px-4 pb-5 pt-2">
                <button type="button"
                        class="w-full py-2.5 rounded-[12px] bg-white/10 hover:bg-white/20 text-white/80 font-medium text-[12px]"
                        @onclick="() => { _pendingMealCoverage = []; _pendingMealCoverageMealId = null; }">
                    Hoppa över
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? MealId { get; set; }
    [Parameter] public string? MealName { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private List<string>? _ingredients;
    private Dictionary<string, Guid> _ingredientIds = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedMissing = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _shoppingNames = new(StringComparer.OrdinalIgnoreCase);

    // Coverage popup state — AllMeals carries name + optional MealId for coverage persistence.
    // ShoppingItem is nullable: the popup also fires when no shopping row exists (e.g. the
    // ingredient is already in pantry but still uncovered for multiple meals).
    private record MealRef(string Name, Guid? MealId);
    private record ChecklistPendingCoverage(ShoppingItemResponse? ShoppingItem, string IngredientName, Guid IngredientId,
List<MealRef> AllMeals)
    {
        public HashSet<string> CoveredMeals { get; } = new(AllMeals.Select(m => m.Name), StringComparer.OrdinalIgnoreCase);
    }
    private bool _coveragePopupOpen;
    private List<ChecklistPendingCoverage> _pendingCoverage = [];
    private List<string> _pendingMealCoverage = [];
    private Guid? _pendingMealCoverageMealId;
    private bool _isLoading;
    private Guid? _loadedFor;

    private IEnumerable<string> PantryIngredients =>
        _ingredients?.Where(n => CheckState.IsInPantry(n) && !IsStillNeededForThisMeal(n)) ?? [];

    private IEnumerable<string> MissingIngredients =>
        _ingredients?.Where(n => !CheckState.IsInPantry(n) || IsStillNeededForThisMeal(n)) ?? [];

    /// <summary>
    /// Returns true when the ingredient is still on the shopping list for THIS meal
    /// (i.e. pantry stock does not cover this meal yet — partial coverage was chosen for another meal).
    /// </summary>
    private bool IsStillNeededForThisMeal(string ingredientName)
    {
        if (string.IsNullOrEmpty(MealName)) return false;
        return ShoppingState.Items.Any(s =>
            !s.IsChecked &&
            string.Equals(s.Name, ingredientName, StringComparison.OrdinalIgnoreCase) &&
            ExtractAllMealRefs(s.Notes).Any(m => string.Equals(m.Name, MealName, StringComparison.OrdinalIgnoreCase)));
    }

    protected override void OnInitialized()
    {
        CheckState.OnChange += StateHasChanged;
        ShoppingState.OnChanged += StateHasChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen)
        {
            _selectedMissing.Clear();
            _loadedFor = null; // force fresh shopping-list fetch on next open
            return;
        }
        if (MealId is not null && MealId != _loadedFor)
        {
            _selectedMissing.Clear();
            await LoadAsync(MealId.Value);
        }
    }

    private async Task LoadAsync(Guid mealId)
    {
        _isLoading = true;
        try
        {
            if (CheckState.HasIngredients(mealId))
            {
                _ingredients = CheckState.GetIngredients(mealId).ToList();
            }
            else
            {
                var meal = await Api.GetMealAsync(mealId);
                var ingList = meal?.Ingredients ?? [];
                var names = ingList.Select(i => i.Name).ToList();
                CheckState.SetIngredients(mealId, names);
                _ingredients = names;
            }
            _ingredientIds.Clear(); // always re-resolve master IDs lazily on move

            // Fetch fresh shopping list so the Köp column shows a cart icon for items
            // already queued, vs "!" for ingredients not covered anywhere.
            var shopping = await Api.GetShoppingListAsync();
            _shoppingNames = shopping.Select(s => s.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);

            _loadedFor = mealId;

            // If pantry stocks haven't been confirmed for this meal yet, ask the user
            // before showing the regular checklist. Builds a synthetic pending list per ingredient.
            var pending = CheckState.GetPendingCoverageIngredients(mealId).ToList();
            if (pending.Count > 0)
            {
                _pendingMealCoverage = pending;
                _pendingMealCoverageMealId = mealId;
            }
            else
            {
                _pendingMealCoverage = [];
                _pendingMealCoverageMealId = null;
            }
        }
        catch
        {
            _ingredients = [];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task HandleClose() => OnClose.InvokeAsync();

    private async Task AnswerPendingAsync(string ingredientName, bool covers)
    {
        if (_pendingMealCoverageMealId is not { } mealId) return;

        if (!CheckState.TryGetPantryIngredientId(ingredientName, out var ingredientId))
        {
            // Fallback: resolve via catalog if local map is missing the entry.
            var matches = await Api.SearchIngredientsAsync(ingredientName);
            var master = matches.FirstOrDefault(i => string.Equals(i.Name, ingredientName, StringComparison.OrdinalIgnoreCase));
            if (master is null) { _pendingMealCoverage.Remove(ingredientName); return; }
            ingredientId = master.Id;
        }

        try
        {
            await Api.SetPantryCoverageAsync(ingredientId, mealId, covers);
            CheckState.MarkCoverage(ingredientName, mealId, covers);
            // Resync so the shopping list reflects the new coverage decision.
            ShoppingSync.TriggerSync();
        }
        catch
        {
            // Swallow; user can retry by reopening.
        }
        finally
        {
            _pendingMealCoverage.Remove(ingredientName);
            if (_pendingMealCoverage.Count == 0)
                _pendingMealCoverageMealId = null;
        }
    }

    private void ToggleMissingSelection(string name)
    {
        if (!_selectedMissing.Remove(name))
            _selectedMissing.Add(name);
    }

    private async Task MoveSelectedToPantryAsync()
    {
        var toMove = _selectedMissing.ToList();
        _selectedMissing.Clear();

        // Resolve all ingredient IDs first, then split into normal vs shared
        var resolved = new List<(string Name, Guid IngredientId)>();
        foreach (var name in toMove)
        {
            if (!_ingredientIds.TryGetValue(name, out var ingId))
            {
                var matches = await Api.SearchIngredientsAsync(name);
                var master = matches.FirstOrDefault(i => string.Equals(i.Name, name, StringComparison.OrdinalIgnoreCase));
                if (master is null) { _selectedMissing.Add(name); continue; }
                ingId = master.Id;
                _ingredientIds[name] = ingId;
            }
            resolved.Add((name, ingId));
        }

        var normalItems = new List<(string Name, Guid IngredientId)>();
        var sharedPending = new List<ChecklistPendingCoverage>();

        foreach (var (name, ingId) in resolved)
        {
            var shoppingItem = ShoppingState.Items.FirstOrDefault(s => s.IngredientId == ingId && !s.IsChecked);

            // Only ask about meals that aren't already marked as covered. If 0 or 1 meals
            // remain uncovered, just auto-mark (handled in normalItems below).
            var uncoveredMeals = CheckState.GetUncoveredActiveMealsForIngredient(name)
                .Select(m => new MealRef(m.Name, m.Id))
                .ToList();

            // Fallback when the plan isn't loaded — use shopping notes (which only carry uncovered
            // meals since covered ones get pruned from notes during partial-coverage flows).
            if (uncoveredMeals.Count == 0 && shoppingItem is not null)
                uncoveredMeals = ExtractAllMealRefs(shoppingItem.Notes);

            if (uncoveredMeals.Count > 1)
                sharedPending.Add(new ChecklistPendingCoverage(shoppingItem, name, ingId, uncoveredMeals));
            else
                normalItems.Add((name, ingId));
        }

        foreach (var (name, ingId) in normalItems)
        {
            try
            {
                PantryItemResponse? pantryItem = null;
                try { pantryItem = await Api.AddToPantryAsync(ingId); }
                catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists) { }

                if (pantryItem is not null)
                    PantryState.AddItem(pantryItem);

                // Always update check-state and remove the shopping item, even when the
                // ingredient was already in pantry (partial-coverage scenario where a
                // previous move covered another meal but this meal remained).
                CheckState.AddPantryName(name);

                // User explicitly added this from THIS meal's checklist — record coverage=true
                // for the current meal (overrides any prior "declined" answer). Without this the
                // next sync would re-add the shopping row because the meal still counts as uncovered.
                if (MealId is { } mealId)
                {
                    try
                    {
                        await Api.SetPantryCoverageAsync(ingId, mealId, true);
                        CheckState.MarkCoverage(name, mealId, true);
                    }
                    catch { /* best-effort */ }
                }

                var shoppingItem = ShoppingState.Items.FirstOrDefault(s => s.IngredientId == ingId);
                if (shoppingItem is not null)
                {
                    try { await Api.RemoveFromShoppingListAsync(shoppingItem.Id); } catch { }
                    ShoppingState.RemoveItem(shoppingItem.Id);
                }
            }
            catch (Exception)
            {
                _selectedMissing.Add(name);
            }
        }

        if (normalItems.Count > 0)
            ShoppingSync.TriggerSync();

        if (sharedPending.Count > 0)
        {
            _pendingCoverage = sharedPending;
            _coveragePopupOpen = true;
        }
    }

    private void ToggleCoverage(ChecklistPendingCoverage coverage, string meal)
    {
        if (!coverage.CoveredMeals.Remove(meal))
            coverage.CoveredMeals.Add(meal);
    }

    private async Task CoverAllAndConfirmAsync()
    {
        foreach (var cov in _pendingCoverage)
            foreach (var meal in cov.AllMeals)
                cov.CoveredMeals.Add(meal.Name);
        await ConfirmCoverageAsync();
    }

    private async Task ConfirmCoverageAsync()
    {
        _coveragePopupOpen = false;
        foreach (var coverage in _pendingCoverage)
        {
            try
            {
                PantryItemResponse? pantryItem = null;
                try { pantryItem = await Api.AddToPantryAsync(coverage.IngredientId); }
                catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists) { }

                if (pantryItem is not null)
                {
                    PantryState.AddItem(pantryItem);
                    CheckState.AddPantryName(coverage.IngredientName);
                }

                // Persist coverage answers per meal so the per-meal pending question won't be asked again.
                foreach (var meal in coverage.AllMeals)
                {
                    if (meal.MealId is not { } mealId) continue;
                    var covers = coverage.CoveredMeals.Contains(meal.Name);
                    try
                    {
                        await Api.SetPantryCoverageAsync(coverage.IngredientId, mealId, covers);
                        CheckState.MarkCoverage(coverage.IngredientName, mealId, covers);
                    }
                    catch { /* best-effort */ }
                }

                if (coverage.ShoppingItem is { } shopping)
                {
                    var remainingNotes = BuildRemainingNotes(shopping.Notes, coverage.CoveredMeals);
                    if (remainingNotes is null)
                    {
                        await Api.RemoveFromShoppingListAsync(shopping.Id);
                        ShoppingState.RemoveItem(shopping.Id);
                    }
                    else
                    {
                        await Api.AddToShoppingListAsync(shopping.IngredientId, remainingNotes);
                        ShoppingState.AddOrUpdateItem(shopping with { Notes = remainingNotes });
                    }
                }
            }
            catch (Exception)
            {
                _selectedMissing.Add(coverage.IngredientName);
            }
        }
        _pendingCoverage.Clear();
        ShoppingSync.TriggerSync();
    }

    private static int GetMealCount(string? notes)
    {
        if (string.IsNullOrEmpty(notes)) return 0;
        return notes.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Length;
    }

    private static (string MealName, Guid? MealId) ParseNotePart(string part)
    {
        // Trailing "|<guid>" carries the MealId; strip it before parsing the week/day suffix.
        Guid? mealId = null;
        var pipeIdx = part.LastIndexOf('|');
        if (pipeIdx > 0 && Guid.TryParseExact(part[(pipeIdx + 1)..].Trim(), "N", out var gid))
        {
            mealId = gid;
            part = part[..pipeIdx];
        }
        var vIdx = part.LastIndexOf(" v");
        if (vIdx > 0)
        {
            var suffix = part[(vIdx + 2)..].Trim();
            var dIdx = suffix.IndexOf('d');
            var hasWeek = dIdx > 0
                ? int.TryParse(suffix[..dIdx], out _) && int.TryParse(suffix[(dIdx + 1)..], out _)
                : int.TryParse(suffix, out _);
            if (hasWeek) return (part[..vIdx].Trim(), mealId);
        }
        return (part.Trim(), mealId);
    }

    private static List<MealRef> ExtractAllMealRefs(string? notes)
    {
        if (string.IsNullOrEmpty(notes)) return [];
        return notes.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(ParseNotePart)
            .Where(x => !string.IsNullOrEmpty(x.MealName))
            .GroupBy(x => x.MealName, StringComparer.OrdinalIgnoreCase)
            .Select(g =>
            {
                var withId = g.FirstOrDefault(x => x.MealId.HasValue);
                return new MealRef(g.Key, withId.MealId);
            })
            .ToList();
    }

    private static List<string> ExtractAllMealNames(string? notes) =>
        ExtractAllMealRefs(notes).Select(m => m.Name).ToList();

    private static string? BuildRemainingNotes(string? originalNotes, HashSet<string> coveredMeals)
    {
        if (string.IsNullOrEmpty(originalNotes)) return null;
        var remaining = originalNotes
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(part =>
            {
                var (mealName, _) = ParseNotePart(part);
                return !coveredMeals.Contains(mealName);
            })
            .ToList();
        return remaining.Count > 0 ? string.Join(", ", remaining) : null;
    }

    public void Dispose()
    {
        CheckState.OnChange -= StateHasChanged;
        ShoppingState.OnChanged -= StateHasChanged;
    }
}
