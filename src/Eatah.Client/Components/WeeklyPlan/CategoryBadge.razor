@namespace Eatah.Client.Components.WeeklyPlan

@if (Meal is not null)
{
	<span class="@BadgeClass" style="@BadgeStyle">@CategoryLabel</span>
}

@code {
	[Parameter, EditorRequired] public MealSummaryResponse? Meal { get; set; }

	private string CategoryLabel => Meal!.Category switch
	{
		MealCategory.Meat => "Rött kött",
		MealCategory.Fish => "Fisk",
		MealCategory.Vegetarian => "Vegetariskt",
		MealCategory.Vegan => "Veganskt",
		_ => Meal!.Category.ToString()
	};

	private const string BadgeClass =
		"inline-flex items-center justify-center font-kanit font-normal text-white text-[10px] leading-[10px] px-[7px] py-[4px] rounded-full whitespace-nowrap";

	private string BadgeStyle => Meal!.Category switch
	{
		MealCategory.Meat => "background:#A13A3A;",
		MealCategory.Fish => "background:#005ED9;",
		MealCategory.Vegetarian => "background:#3C8F3A;",
		MealCategory.Vegan => "background:#AC279D;",
		_ => "background:#64748b;"
	};
}
