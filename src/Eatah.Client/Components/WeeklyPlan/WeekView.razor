@namespace Eatah.Client.Components.WeeklyPlan

<div class="flex flex-col gap-3 pb-6">
	@foreach (var day in OrderedDays)
	{
		<DayCard Day="day" WeekOffset="WeekOffset" IsRandomizing="@(RandomizingDay == day.DayOfWeek)"
				 OnSelect="OnDaySelected" OnClear="OnDayCleared" OnRandomDb="OnDayRandomDb" OnRandomAi="OnDayRandomAi" />
	}
</div>

@code {
	private static readonly DayOfWeek[] WeekOrder =
	[
		DayOfWeek.Monday,
		DayOfWeek.Tuesday,
		DayOfWeek.Wednesday,
		DayOfWeek.Thursday,
		DayOfWeek.Friday,
		DayOfWeek.Saturday,
		DayOfWeek.Sunday
	];

	[Parameter, EditorRequired] public IReadOnlyList<DayPlanResponse> Days { get; set; } = [];
	[Parameter] public int WeekOffset { get; set; } = 0;
	[Parameter] public DayOfWeek? RandomizingDay { get; set; }
	[Parameter] public EventCallback<DayPlanResponse> OnDaySelected { get; set; }
	[Parameter] public EventCallback<DayPlanResponse> OnDayCleared { get; set; }
	[Parameter] public EventCallback<DayPlanResponse> OnDayRandomDb { get; set; }
	[Parameter] public EventCallback<DayPlanResponse> OnDayRandomAi { get; set; }

	private IEnumerable<DayPlanResponse> OrderedDays =>
		WeekOrder
			.Select(d => Days.FirstOrDefault(x => x.DayOfWeek == d))
			.Where(x => x is not null)!
			.Cast<DayPlanResponse>();
}
