@namespace Eatah.Client.Components.WeeklyPlan

@if (IsOpen)
{
    <div class="eatah-modal-backdrop" @onclick="HandleBackdrop">
        <div class="eatah-modal" @onclick:stopPropagation="true">
            <div class="eatah-ai-preview">

                <div class="eatah-diet-modal__header">
                    <h2 class="eatah-diet-modal__title">AI-förslag för @DayLabel</h2>
                    <button type="button" class="eatah-diet-modal__close" @onclick="Close" aria-label="Stäng">
                        <Icon Name="close" Size="20" />
                    </button>
                </div>

                <div class="eatah-ai-preview__body">
                    @if (IsLoading)
                    {
                        <LoadingSpinner IsAi="true" Label="Genererar förslag…" />
                    }
                    else if (Error is not null)
                    {
                        <p class="eatah-modal-notice eatah-modal-notice--error">@Error</p>
                    }
                    else if (Meal is not null)
                    {
                        <div>
                            <h3 class="eatah-ai-preview__meal-title">@Meal.Name</h3>
                            <div class="eatah-ai-preview__meal-meta">
                                <span>@CategoryLabel(Meal.Category)</span>
                                @if (Meal.CookingTimeMinutes.HasValue)
                                {
                                    <span>~@Meal.CookingTimeMinutes min</span>
                                }
                            </div>
                        </div>

                        <div>
                            <p class="eatah-ai-preview__ing-label">Ingredienser</p>
                            <div class="eatah-ai-preview__ing-chips">
                                @foreach (var ingredient in Meal.Ingredients)
                                {
                                    <span class="eatah-ai-preview__ing-chip">@ingredient</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="eatah-modal-footer">
                    <button type="button" class="eatah-modal-footer__btn eatah-modal-footer__btn--ghost" @onclick="Close">
                        Avbryt
                    </button>
                    @if (!IsLoading)
                    {
                        <button type="button" class="eatah-modal-footer__btn eatah-modal-footer__btn--ghost"
                                @onclick="HandleRetry">
                            <Icon Name="rotate" Size="16" />
                        </button>
                    }
                    <button type="button" class="eatah-modal-footer__btn eatah-modal-footer__btn--primary"
                            disabled="@(Meal is null || IsLoading)" @onclick="HandleSave">
                        Spara
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public DayOfWeek? Day { get; set; }
    [Parameter] public AiGeneratedMealResponse? Meal { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnRetry { get; set; }

    private string DayLabel => Day switch
    {
        DayOfWeek.Monday => "måndag",
        DayOfWeek.Tuesday => "tisdag",
        DayOfWeek.Wednesday => "onsdag",
        DayOfWeek.Thursday => "torsdag",
        DayOfWeek.Friday => "fredag",
        DayOfWeek.Saturday => "lördag",
        DayOfWeek.Sunday => "söndag",
        _ => string.Empty
    };

    private static string CategoryLabel(MealCategory c) => c switch
    {
        MealCategory.Meat => "Rött kött",
        MealCategory.Poultry => "Fågel",
        MealCategory.Fish => "Fisk",
        MealCategory.Vegetarian => "Vegetariskt",
        MealCategory.Vegan => "Veganskt",
        _ => c.ToString()
    };

    private Task Close() => OnClose.InvokeAsync();
    private Task HandleBackdrop() => Close();
    private Task HandleSave() => OnSave.InvokeAsync();
    private Task HandleRetry() => OnRetry.InvokeAsync();
}
