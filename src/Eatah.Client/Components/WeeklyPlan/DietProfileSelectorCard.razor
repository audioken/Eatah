@namespace Eatah.Client.Components.WeeklyPlan
@using System.Globalization
@using Eatah.Client.Services
@implements IDisposable
@inject ApiClient Api
@inject ToastService Toasts
@inject DietProfileState ProfileState

<div class="eatah-card eatah-diet-card">
    <!-- Top row: title + score pill + dropdown -->
    <div class="eatah-diet-card__header">
        <div class="eatah-diet-card__title-row">
            <span class="eatah-diet-card__title">Kostprofil</span>
            @if (HasProfile && _evaluation is not null)
            {
                <span class="eatah-diet-card__score-pill" style="background: @ScoreBackground;"
                      title="@($"{ScorePercent}% av regler uppfyllda")">
                    @($"{ScorePercent}%")
                </span>
            }
        </div>
        @if (_profiles is { Count: > 0 })
        {
            <div class="eatah-diet-card__select-wrap">
                @if (IsLocked)
                {
                    <span class="eatah-diet-card__select-locked">
                        @(SelectedProfileName ?? "Ingen profil")
                    </span>
                }
                else
                {
                    <button type="button" class="eatah-diet-card__select-btn" @onclick="ToggleDropdown"
                            aria-haspopup="listbox" aria-expanded="@_dropdownOpen">
                        <span class="eatah-diet-card__select-label">@(SelectedProfileName ?? "Välj profil")</span>
                        <span class="eatah-diet-card__chevron">
                            <Icon Name="chevron-down" Size="12" />
                        </span>
                    </button>

                    @if (_dropdownOpen)
                    {
                        <div class="eatah-diet-card__backdrop" @onclick="CloseDropdown"></div>
                        <div class="eatah-diet-card__dropdown" role="listbox">
                            <div class="eatah-diet-card__dropdown-list">
                                @foreach (var profile in _profiles)
                                {
                                    var isSelected = profile.Id == _selectedProfileId;
                                    <button type="button" role="option" aria-selected="@isSelected"
                                            class="eatah-diet-card__dropdown-item @(isSelected ? "eatah-diet-card__dropdown-item--active" : "")"
                                            @onclick="() => SelectProfileAsync(profile.Id)">
                                        @if (isSelected)
                                        {
                                            <span class="eatah-diet-card__dropdown-check">
                                                <Icon Name="check" Size="12" />
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="eatah-diet-card__dropdown-check eatah-diet-card__dropdown-check--empty"></span>
                                        }
                                        <span>@profile.Name</span>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <span class="eatah-diet-card__select-empty">Ingen profil vald</span>
        }
    </div>

    <!-- Bottom row: category icons + randomize button -->
    <div class="eatah-diet-card__bottom">
        <div class="eatah-diet-card__icons">
            @foreach (var category in CategoriesInOrder)
            {
                var rule = FindRule(category);
                var actual = FindActual(category);
                var isExcluded = rule is { MinPerWeek: 0, MaxPerWeek: 0 };
                <div class="eatah-diet-card__icon-cell @(isExcluded ? "eatah-diet-card__icon-cell--excluded" : "")">
                    <span class="eatah-category-icon @CategoryClass(category)">
                        <Icon Name="@CategoryIconName(category)" />
                    </span>
                    @if (rule is not null)
                    {
                        if (isExcluded)
                        {
                            <span class="eatah-pill eatah-pill--muted eatah-diet-card__rule-pill">0</span>
                        }
                        else
                        {
                            var ok = actual >= rule.MinPerWeek && actual <= rule.MaxPerWeek;
                            <span class="eatah-pill @(ok ? "eatah-pill--ok" : "eatah-pill--bad") eatah-diet-card__rule-pill">
                                @(rule.MinPerWeek == rule.MaxPerWeek ? $"{rule.MinPerWeek}" : $"{rule.MinPerWeek}-{rule.MaxPerWeek}")
                            </span>
                        }
                    }
                    else
                    {
                        <span class="eatah-pill eatah-pill--muted eatah-diet-card__rule-pill">–</span>
                    }
                </div>
            }
        </div>

        <button type="button" class="eatah-diet-card__randomize" disabled="@_isRandomizing"
                @onclick="HandleRandomize">
            <Icon Name="dice" Size="20" />
            <span class="eatah-diet-card__randomize-label">Slumpa maträtter</span>
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public WeeklyPlanResponse Plan { get; set; } = default!;
    [Parameter] public EventCallback<Guid?> OnRandomize { get; set; }
    /// <summary>-1 = previous week (locked), 0 = current week, 1 = next week.</summary>
    [Parameter] public int WeekOffset { get; set; }

    private static readonly MealCategory[] CategoriesInOrder =
    [
        MealCategory.Vegan,
        MealCategory.Vegetarian,
        MealCategory.Fish,
        MealCategory.Poultry,
        MealCategory.Meat
    ];

    private List<DietProfileResponse>? _profiles;
    private Guid? _selectedProfileId;
    private DietEvaluationResponse? _evaluation;
    private bool _isRandomizing;
    private bool _dropdownOpen;
    private string? _planSignature;

    private bool HasProfile => _selectedProfileId is not null;
    private bool IsLocked => WeekOffset < 0;

    private string? SelectedProfileName =>
        _profiles?.FirstOrDefault(p => p.Id == _selectedProfileId)?.Name;

    protected override async Task OnInitializedAsync()
    {
        ProfileState.OnChanged += OnProfilesChanged;
        await LoadProfilesAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        var signature = ComputeSignature(Plan);
        if (signature != _planSignature)
        {
            _planSignature = signature;

            // Sync selected profile from the plan (server-stored per week).
            if (_profiles is not null)
            {
                _selectedProfileId = Plan.DietProfileId is Guid planProfileId
                    && _profiles.Any(p => p.Id == planProfileId)
                        ? planProfileId
                        : _profiles.FirstOrDefault()?.Id;
                ProfileState.SetSelectedProfileId(_selectedProfileId);
            }

            await EvaluateAsync();
        }
    }

    public void Dispose()
    {
        ProfileState.OnChanged -= OnProfilesChanged;
    }

    private void OnProfilesChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadProfilesAsync();
            StateHasChanged();
        });
    }

    private async Task LoadProfilesAsync()
    {
        try
        {
            _profiles = await Api.GetDietProfilesAsync();

            // Use the profile stored on the plan; fallback to first available.
            _selectedProfileId = Plan?.DietProfileId is Guid planProfileId
                && _profiles.Any(p => p.Id == planProfileId)
                    ? planProfileId
                    : _profiles.FirstOrDefault()?.Id;

            ProfileState.SetSelectedProfileId(_selectedProfileId);
            await EvaluateAsync();
        }
        catch
        {
            _profiles = [];
        }
    }

    private async Task EvaluateAsync()
    {
        if (Plan is null || _selectedProfileId is null)
        {
            _evaluation = null;
            return;
        }
        try
        {
            _evaluation = await Api.EvaluateWeeklyPlanAsync(Plan.Id, _selectedProfileId.Value);
        }
        catch
        {
            _evaluation = null;
        }
    }

    private void ToggleDropdown() => _dropdownOpen = !_dropdownOpen;
    private void CloseDropdown() => _dropdownOpen = false;

    private async Task SelectProfileAsync(Guid id)
    {
        _dropdownOpen = false;
        if (id == _selectedProfileId) return;

        _selectedProfileId = id;
        ProfileState.SetSelectedProfileId(id);

        try
        {
            await Api.UpdateWeeklyPlanDietProfileAsync(Plan.Id, id);
        }
        catch
        {
            Toasts.Show("Kunde inte spara kostprofilen.");
        }

        await EvaluateAsync();
    }

    private async Task HandleRandomize()
    {
        if (_isRandomizing) return;
        _isRandomizing = true;
        try
        {
            await OnRandomize.InvokeAsync(_selectedProfileId);
        }
        finally
        {
            _isRandomizing = false;
        }
    }

    private DietRuleResponse? FindRule(MealCategory category)
    {
        var profile = _profiles?.FirstOrDefault(p => p.Id == _selectedProfileId);
        return profile?.Rules.FirstOrDefault(r => r.Category == category);
    }

    private int FindActual(MealCategory category)
    {
        if (_evaluation is null) return 0;
        var match = _evaluation.RuleResults.FirstOrDefault(r => r.Category == category);
        return match?.Actual ?? 0;
    }

    private int ScorePercent =>
        (int)Math.Round(Math.Clamp((_evaluation?.OverallScore ?? 0) * 100, 0, 100));

    private string ScoreBackground
    {
        get
        {
            var clamped = ScorePercent.ToString(CultureInfo.InvariantCulture);
            return $"color-mix(in srgb, var(--color-pill-good) {clamped}%, var(--color-pill-bad))";
        }
    }

    private static string CategoryClass(MealCategory category) => category switch
    {
        MealCategory.Vegan => "eatah-category-icon--vegan",
        MealCategory.Vegetarian => "eatah-category-icon--veg",
        MealCategory.Fish => "eatah-category-icon--fish",
        MealCategory.Poultry => "eatah-category-icon--poultry",
        MealCategory.Meat => "eatah-category-icon--meat",
        _ => string.Empty
    };

    private static string CategoryIconName(MealCategory category) => category switch
    {
        MealCategory.Vegan => "vegan",
        MealCategory.Vegetarian => "vegetarian",
        MealCategory.Fish => "fish",
        MealCategory.Poultry => "poultry",
        MealCategory.Meat => "meat",
        _ => "question"
    };

    private static string ComputeSignature(WeeklyPlanResponse plan)
    {
        if (plan?.Days is null) return string.Empty;
        // Include DietProfileId in signature so profile changes re-evaluate.
        var days = string.Join("|", plan.Days.OrderBy(d => d.DayOfWeek).Select(d => d.MealId?.ToString() ?? "-"));
        return $"{days}#{plan.DietProfileId}";
    }
}
