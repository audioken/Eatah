@page "/diet-profiles"
@using Eatah.Client.Services
@using Eatah.Client.Services.Contracts
@inject ApiClient Api

<div class="max-w-5xl mx-auto p-4 space-y-6">
	<div>
		<h1 class="text-2xl md:text-3xl font-bold mb-1">Kostprofiler</h1>
		<p class="text-slate-600">Generera en ny kostprofil med hjälp av AI eller bläddra bland befintliga.</p>
	</div>

	<section class="bg-white shadow rounded-lg p-4 space-y-3">
		<h2 class="text-xl font-semibold">Generera profil med AI</h2>
		<div class="grid gap-3 md:grid-cols-2">
			<label class="block">
				<span class="text-sm font-medium text-slate-700">Namn</span>
				<input class="mt-1 w-full rounded border-slate-300 px-3 py-2 border" @bind="_name"
					   placeholder="t.ex. LCHF" />
			</label>
			<label class="block">
				<span class="text-sm font-medium text-slate-700">Strictness (@_strictness.ToString("F2"))</span>
				<input type="range" min="0" max="1" step="0.05" class="mt-2 w-full" @bind="_strictness"
					   @bind:event="oninput" />
			</label>
		</div>
		<label class="block">
			<span class="text-sm font-medium text-slate-700">Beskrivning / mål</span>
			<textarea class="mt-1 w-full rounded border-slate-300 px-3 py-2 border" rows="2" @bind="_description"
					  placeholder="t.ex. Fokus på viktnedgång och lågt kolhydratintag"></textarea>
		</label>

		<div class="flex items-center gap-3">
			<button class="px-4 py-2 bg-emerald-600 text-white rounded disabled:opacity-50" @onclick="GenerateAsync"
					disabled="@(_busy || string.IsNullOrWhiteSpace(_name))">
				@(_busy ? "Genererar..." : "Generera profil")
			</button>
			@if (!string.IsNullOrEmpty(_error))
			{
				<span class="text-red-600 text-sm">@_error</span>
			}
		</div>
	</section>

	<section>
		<h2 class="text-xl font-semibold mb-3">Befintliga profiler</h2>
		@if (_profiles is null)
		{
			<p class="text-slate-500">Laddar...</p>
		}
		else if (_profiles.Count == 0)
		{
			<p class="text-slate-500">Inga profiler ännu.</p>
		}
		else
		{
			<div class="grid gap-3 md:grid-cols-2">
				@foreach (var profile in _profiles)
				{
					<div class="bg-white shadow rounded-lg p-4">
						<h3 class="font-semibold text-lg">@profile.Name</h3>
						<ul class="mt-2 space-y-1 text-sm text-slate-700">
							@foreach (var rule in profile.Rules)
							{
								<li>
									<span class="font-medium">@rule.Category:</span>
									@rule.MinPerWeek–@rule.MaxPerWeek / vecka
									<span class="text-slate-500"> – @rule.Description</span>
								</li>
							}
						</ul>
					</div>
				}
			</div>
		}
	</section>
</div>

@code {
	private List<DietProfileResponse>? _profiles;
	private string _name = string.Empty;
	private string _description = string.Empty;
	private double _strictness = 0.5;
	private bool _busy;
	private string? _error;

	protected override async Task OnInitializedAsync()
	{
		await LoadProfilesAsync();
	}

	private async Task LoadProfilesAsync()
	{
		try
		{
			_profiles = await Api.GetDietProfilesAsync();
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte hämta profiler: {ex.Message}";
		}
	}

	private async Task GenerateAsync()
	{
		if (string.IsNullOrWhiteSpace(_name) || _busy)
		{
			return;
		}

		_busy = true;
		_error = null;
		try
		{
			var request = new GenerateDietProfileRequest(_name.Trim(), _description?.Trim(), _strictness);
			var generated = await Api.GenerateDietProfileAsync(request);
			if (generated is not null)
			{
				_name = string.Empty;
				_description = string.Empty;
				await LoadProfilesAsync();
			}
		}
		catch (Exception ex)
		{
			_error = ex.Message;
		}
		finally
		{
			_busy = false;
		}
	}
}
