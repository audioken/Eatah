@page "/"
@using System.Globalization
@inject ApiClient Api
@inject HeaderState Header
@inject WorkspaceState Workspaces
@inject IngredientCheckState CheckState
@inject ShoppingSyncService ShoppingSync
@inject Eatah.Client.Services.DietProfileState ProfileState
@inject WeeklyPlanStateService WeeklyPlans
@inject MealsStateService MealsCache
@inject PantryStateService PantryCache
@inject PantryCoverageStateService CoverageCache
@inject ToastService Toasts
@implements IDisposable

<div class="max-w-[1000px] mx-auto">
	@if (_error is not null)
	{
		<div class="mb-4 p-3 rounded-md bg-red-50 border border-red-200 text-red-700 text-sm">
			@_error
		</div>
	}

	@if (_plan is null)
	{
		@if (_isLoading)
		{
			<LoadingSpinner Label="Laddar veckoplan…" />
		}
		else
		{
			<div class="p-8 text-center text-slate-500">Ingen veckoplan kunde laddas.</div>
		}
	}
	else
	{
		<div class="dashboard-card-spacer"></div>

		<WeekView Days="_plan.Days" WeekOffset="_weekOffset" RandomizingDay="_randomizingDay" OnDaySelected="OpenSelector"
				  OnDayCleared="ClearDayAsync" OnDayRandomDb="RandomizeDayDbAsync" OnDayRandomAi="StartAiForDayAsync" />
	}
</div>

@if (_plan is not null)
{
	<div class="dashboard-fixed-card">
		<DietProfileSelectorCard Plan="_plan" WeekOffset="_weekOffset" OnRandomize="RandomizeAsync" />
	</div>
}

<MealSelector IsOpen="_selectorOpen" Day="_selectedDay?.DayOfWeek" Meals="_meals" OnSelect="AssignMealAsync"
			  OnCreate="CreateMealFromSelectorAsync" OnClose="CloseSelector" />

<AiMealPreview IsOpen="_aiPreviewOpen" Day="_aiTargetDay?.DayOfWeek" Meal="_aiMeal" IsLoading="_aiLoading"
			   Error="@_aiError" OnSave="OpenSaveAiMealForm" OnClose="CloseAiPreview" />

<MealForm IsOpen="_aiSaveFormOpen" InitialName="@_aiMeal?.Name" InitialCategory="_aiMeal?.Category"
		  InitialIngredients="_aiMeal?.Ingredients" InitialCookingTimeMinutes="_aiMeal?.CookingTimeMinutes"
		  UnsavedNotice="@($"Spara maträtten till databasen för att tilldela den till {AiTargetDayLabel}.")"
		  OnSubmit="SaveAiMealAndAssignAsync" OnClose="CloseAiSaveForm" />

@code {
	private DayPlanResponse? _selectedDay;
	private bool _selectorOpen;
	private bool _isLoading = true; // only true while we have NOTHING to show yet (cold load)
	private string? _error;
	private int _weekOffset = 0; // -1 = förra veckan, 0 = denna vecka, +1 = nästa vecka
								 // Sessions keyed by week offset (0 = current, 1 = next). Merging both gives global badge counts
								 // that match the shopping-sync scope (current week from today + next week all days).
	private readonly Dictionary<int, List<IngredientCheckState.ActiveSession>> _cachedSessions = new();

	// All view data is sourced from the singleton state caches. Pages just observe them —
	// SignalR-driven background refreshes update the caches and the OnChanged events trigger
	// re-renders, so navigation between weeks never causes a spinner/blink once warmed up.
	private (int Year, int Week) _viewedKey
	{
		get
		{
			var target = DateTime.UtcNow.Date.AddDays(_weekOffset * 7);
			return (ISOWeek.GetYear(target), ISOWeek.GetWeekOfYear(target));
		}
	}

	private WeeklyPlanResponse? _plan => WeeklyPlans.TryGet(_viewedKey.Year, _viewedKey.Week);
	private IReadOnlyList<MealResponse>? _meals => MealsCache.IsLoaded ? MealsCache.Items : null;
	private int _viewedWeekNumber => _plan?.WeekNumber ?? _viewedKey.Week;

	private DayPlanResponse? _aiTargetDay;
	private AiGeneratedMealResponse? _aiMeal;
	private bool _aiPreviewOpen;
	private bool _aiLoading;
	private string? _aiError;
	private bool _aiSaveFormOpen;
	private DayOfWeek? _randomizingDay;

	private string AiTargetDayLabel => _aiTargetDay?.DayOfWeek switch
	{
		DayOfWeek.Monday => "måndag",
		DayOfWeek.Tuesday => "tisdag",
		DayOfWeek.Wednesday => "onsdag",
		DayOfWeek.Thursday => "torsdag",
		DayOfWeek.Friday => "fredag",
		DayOfWeek.Saturday => "lördag",
		DayOfWeek.Sunday => "söndag",
		_ => "vald dag"
	};

	protected override async Task OnInitializedAsync()
	{
		Workspaces.OnChange += OnWorkspaceChanged;
		WeeklyPlans.OnChanged += OnWeeklyPlanCacheChanged;
		MealsCache.OnChanged += OnMealsCacheChanged;
		PantryCache.OnChanged += OnPantryCacheChanged;
		CoverageCache.OnChanged += OnCoverageCacheChanged;
		await LoadAsync();
	}

	public void Dispose()
	{
		Workspaces.OnChange -= OnWorkspaceChanged;
		WeeklyPlans.OnChanged -= OnWeeklyPlanCacheChanged;
		MealsCache.OnChanged -= OnMealsCacheChanged;
		PantryCache.OnChanged -= OnPantryCacheChanged;
		CoverageCache.OnChanged -= OnCoverageCacheChanged;
		Header.Clear();
	}

	private void OnWeeklyPlanCacheChanged(int year, int week)
	{
		// Any cached week changed (mutation, SignalR refresh, or workspace clear).
		// Cheap — recompute sessions from caches and re-render.
		_ = InvokeAsync(() =>
		{
			RefreshActiveMeals();
			StateHasChanged();
		});
	}

	private void OnMealsCacheChanged() => _ = InvokeAsync(StateHasChanged);

	private void OnPantryCacheChanged()
	{
		_ = InvokeAsync(() =>
		{
			SyncPantryToCheckState();
			StateHasChanged();
		});
	}

	private void OnCoverageCacheChanged()
	{
		_ = InvokeAsync(() =>
		{
			SyncCoverageToCheckState();
			StateHasChanged();
		});
	}

	private void OnWorkspaceChanged()
	{
		// RealtimeSyncService.OnWorkspaceChanged has just cleared every cache for the
		// previous workspace, so we need to repopulate for the new one. Mark loading so
		// the spinner appears (cache is genuinely empty now).
		_isLoading = true;
		_ = InvokeAsync(async () =>
		{
			await LoadAsync();
			StateHasChanged();
		});
	}

	private void SyncPantryToCheckState()
	{
		var pantry = PantryCache.Items;
		CheckState.SetPantryItems(pantry.Select(p => p.Name));
		CheckState.SetPantryIngredientIds(pantry.Select(p => (p.Name, p.IngredientId)));
	}

	private void SyncCoverageToCheckState()
	{
		CheckState.SetCoverage(CoverageCache.Items.Select(c => (c.IngredientId, c.DayPlanId, c.Covers)));
	}

	private void UpdateHeader()
	{
		Header.Set(center: builder =>
		{
			builder.OpenElement(0, "div");
			builder.AddAttribute(1, "class", "flex items-center gap-1");

			builder.OpenElement(2, "button");
			builder.AddAttribute(3, "class", "p-2 rounded-lg text-white/80 hover:bg-white/15 active:bg-white/20 disabled:opacity-40 disabled:cursor-not-allowed transition-colors");
			builder.AddAttribute(4, "disabled", _weekOffset <= -1 || _isLoading);
			builder.AddAttribute(5, "onclick", EventCallback.Factory.Create(this, () => NavigateWeekAsync(-1)));
			builder.OpenComponent<Icon>(6);
			builder.AddAttribute(7, "Name", "chevron-left");
			builder.AddAttribute(8, "Size", 18);
			builder.CloseComponent();
			builder.CloseElement();

			builder.OpenElement(9, "span");
			builder.AddAttribute(10, "class", "text-sm font-semibold text-white px-1");
			builder.AddContent(11, $"Vecka {_viewedWeekNumber}");
			builder.CloseElement();

			builder.OpenElement(12, "button");
			builder.AddAttribute(13, "class", "p-2 rounded-lg text-white/80 hover:bg-white/15 active:bg-white/20 disabled:opacity-40 disabled:cursor-not-allowed transition-colors");
			builder.AddAttribute(14, "disabled", _weekOffset >= 1 || _isLoading);
			builder.AddAttribute(15, "onclick", EventCallback.Factory.Create(this, () => NavigateWeekAsync(1)));
			builder.OpenComponent<Icon>(16);
			builder.AddAttribute(17, "Name", "chevron-right");
			builder.AddAttribute(18, "Size", 18);
			builder.CloseComponent();
			builder.CloseElement();

			builder.CloseElement();
		});
	}

	private async Task LoadAsync()
	{
		_error = null;
		// Only show the spinner if we have nothing at all to render — otherwise the
		// cached plan stays visible while we refresh in the background.
		_isLoading = _plan is null;
		try
		{
			var (year, week) = _viewedKey;
			// Every EnsureLoadedAsync returns the cached value instantly if present and
			// deduplicates concurrent fetches. Only the first time after sign-in or after a
			// workspace switch does this actually go to the network.
			await Task.WhenAll(
				WeeklyPlans.EnsureLoadedAsync(year, week),
				MealsCache.EnsureLoadedAsync(),
				PantryCache.EnsureLoadedAsync(),
				CoverageCache.EnsureLoadedAsync());
			SyncPantryToCheckState();
			SyncCoverageToCheckState();
			RefreshActiveMeals();
			// Pre-warm sibling weeks so badge counts are accurate immediately — fire-and-forget,
			// non-blocking. Cached weeks are no-ops.
			_ = PrewarmPartnerWeeksAsync();
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte ladda veckoplanen: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			UpdateHeader();
		}
	}

	private static int DayIdx(DayOfWeek d) => d == DayOfWeek.Sunday ? 6 : (int)d - 1;

	/// <summary>
	/// Ensures offset=0 (current week) and offset=1 (next week) are present in the cache and
	/// rebuilds the merged ActiveSession list for CheckState. Cache hits are instant.
	/// </summary>
	private async Task PrewarmPartnerWeeksAsync()
	{
		var today = DateTime.UtcNow.Date;
		var (curYear, curWeek) = (ISOWeek.GetYear(today), ISOWeek.GetWeekOfYear(today));
		var next = today.AddDays(7);
		var (nextYear, nextWeek) = (ISOWeek.GetYear(next), ISOWeek.GetWeekOfYear(next));

		try { await WeeklyPlans.EnsureLoadedAsync(curYear, curWeek); }
		catch { /* badge counts degrade gracefully */ }
		try { await WeeklyPlans.EnsureLoadedAsync(nextYear, nextWeek); }
		catch { /* badge counts degrade gracefully */ }

		var cur = WeeklyPlans.TryGet(curYear, curWeek);
		if (cur is not null)
		{
			var minDay = DayIdx(today.DayOfWeek);
			_cachedSessions[0] = cur.Days
				.Where(d => d.Meal is not null && DayIdx(d.DayOfWeek) >= minDay)
				.Select(d => new IngredientCheckState.ActiveSession(d.Id, d.Meal!.Id, d.Meal!.Name, DayIdx(d.DayOfWeek), curWeek))
				.ToList();
		}
		var nxt = WeeklyPlans.TryGet(nextYear, nextWeek);
		if (nxt is not null)
		{
			_cachedSessions[1] = nxt.Days
				.Where(d => d.Meal is not null)
				.Select(d => new IngredientCheckState.ActiveSession(d.Id, d.Meal!.Id, d.Meal!.Name, DayIdx(d.DayOfWeek), nextWeek))
				.ToList();
		}
		CheckState.SetActiveSessions(
			new[] { 0, 1 }.Where(_cachedSessions.ContainsKey).SelectMany(o => _cachedSessions[o]));
	}

	private void RefreshActiveMeals()
	{
		if (_plan is null) return;
		// Past days of the current week are excluded — those meals already happened, their
		// ingredients aren't on the shopping list and shouldn't drive coverage popups/badges.
		// Other weeks (prev/next) include all days.
		var minDayIdx = _weekOffset == 0 ? DayIdx(DateTime.Today.DayOfWeek) : 0;
		var weekNum = ISOWeek.GetWeekOfYear(DateTime.Today.AddDays(_weekOffset * 7));
		_cachedSessions[_weekOffset] = _plan.Days
			.Where(d => d.Meal is not null && DayIdx(d.DayOfWeek) >= minDayIdx)
			.Select(d => new IngredientCheckState.ActiveSession(d.Id, d.Meal!.Id, d.Meal!.Name, DayIdx(d.DayOfWeek), weekNum))
			.ToList();
		// Merge current (0) and next (1) week sessions — matches shopping-sync scope so badge
		// counts in the checklist are consistent with what the shopping list shows.
		CheckState.SetActiveSessions(
			new[] { 0, 1 }.Where(_cachedSessions.ContainsKey).SelectMany(o => _cachedSessions[o]));
	}

	private async Task NavigateWeekAsync(int delta)
	{
		_weekOffset = Math.Clamp(_weekOffset + delta, -1, 1);
		_error = null;
		UpdateHeader();
		// Cache-first: if the week is already loaded the swap is instant — no spinner, no flicker.
		// Only the very first time we visit a previously-unseen week does this hit the network.
		var (year, week) = _viewedKey;
		try
		{
			await WeeklyPlans.EnsureLoadedAsync(year, week);
			RefreshActiveMeals();
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte ladda veckoplanen: {ex.Message}";
		}
		UpdateHeader();
	}

	private void OpenSelector(DayPlanResponse day)
	{
		_selectedDay = day;
		_selectorOpen = true;
	}

	private void CloseSelector()
	{
		_selectorOpen = false;
		_selectedDay = null;
	}

	private async Task AssignMealAsync(MealResponse meal)
	{
		if (_plan is null || _selectedDay is null)
		{
			return;
		}

		try
		{
			var affectedId = _selectedDay.Id;
			var updated = await Api.AssignMealAsync(_plan.Id, _selectedDay.DayOfWeek, meal.Id);
			if (updated is not null)
			{
				CheckState.ClearCoverageForDayPlans([affectedId]);
				// Push the authoritative state into the cache so the computed _plan picks it up
				// and OnChanged subscribers re-render.
				WeeklyPlans.Set(updated);
				ShoppingSync.TriggerSync();
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte tilldela maträtten: {ex.Message}";
		}
		finally
		{
			CloseSelector();
		}
	}

	private async Task ClearDayAsync(DayPlanResponse day)
	{
		if (_plan is null)
		{
			return;
		}

		try
		{
			var updated = await Api.ClearDayAsync(_plan.Id, day.DayOfWeek);
			if (updated is not null)
			{
				CheckState.ClearCoverageForDayPlans([day.Id]);
				WeeklyPlans.Set(updated);
				ShoppingSync.TriggerSync();
				Toasts.Show("Maträtten togs bort.");
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte ta bort maträtten: {ex.Message}";
		}
	}

	private async Task RandomizeAsync(Guid? profileId)
	{
		if (_plan is null)
		{
			return;
		}

		_error = null;
		try
		{
			var affectedIds = _plan.Days.Select(d => d.Id).ToList();
			var updated = await Api.RandomizeWeekAsync(_plan.Id, profileId);
			if (updated is not null)
			{
				CheckState.ClearCoverageForDayPlans(affectedIds);
				WeeklyPlans.Set(updated);
				ShoppingSync.TriggerSync();
				Toasts.Show("Veckans måltider har slumpats.");
			}
		}
		catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.MealsInsufficient)
		{
			_error = "För få rätter. Skapa fler eller generera med AI.";
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte slumpa veckan: {ex.Message}";
		}
	}

	private async Task RandomizeDayDbAsync(DayPlanResponse day)
	{
		if (_plan is null)
		{
			return;
		}

		_error = null;
		_randomizingDay = day.DayOfWeek;
		StateHasChanged();
		try
		{
			var updated = await Api.RandomizeDayAsync(_plan.Id, day.DayOfWeek, profileId: ProfileState.SelectedProfileId);
			if (updated is not null)
			{
				var dayLabel = day.DayOfWeek switch
				{
					DayOfWeek.Monday => "måndag",
					DayOfWeek.Tuesday => "tisdag",
					DayOfWeek.Wednesday => "onsdag",
					DayOfWeek.Thursday => "torsdag",
					DayOfWeek.Friday => "fredag",
					DayOfWeek.Saturday => "lördag",
					DayOfWeek.Sunday => "söndag",
					_ => "dagen"
				};
				var newMeal = updated.Days.FirstOrDefault(d => d.DayOfWeek == day.DayOfWeek);
				CheckState.ClearCoverageForDayPlans([day.Id]);
				WeeklyPlans.Set(updated);
				ShoppingSync.TriggerSync();
				if (newMeal?.Meal is { } m)
					Toasts.Show($"{m.Name} slumpades till {dayLabel}.");
			}
		}
		catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.MealsInsufficient)
		{
			_error = "För få rätter. Skapa fler eller generera med AI.";
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte slumpa dagen: {ex.Message}";
		}
		finally
		{
			_randomizingDay = null;
		}
	}

	private async Task StartAiForDayAsync(DayPlanResponse day)
	{
		if (_plan is null)
		{
			return;
		}

		_aiTargetDay = day;
		_aiMeal = null;
		_aiError = null;
		_aiLoading = true;
		_aiPreviewOpen = true;
		try
		{
			var request = new GenerateMealRequest(
				Category: null,
				DietProfileId: ProfileState.SelectedProfileId,
				WeeklyPlanId: _plan.Id,
				TargetDay: day.DayOfWeek);
			_aiMeal = await Api.GenerateAiMealAsync(request);
		}
		catch (Exception ex)
		{
			_aiError = $"AI-generering misslyckades: {ex.Message}";
		}
		finally
		{
			_aiLoading = false;
		}
	}

	private void CloseAiPreview()
	{
		_aiPreviewOpen = false;
		_aiMeal = null;
		_aiError = null;
		_aiTargetDay = null;
	}

	private void OpenSaveAiMealForm()
	{
		if (_aiMeal is null)
		{
			return;
		}
		_aiPreviewOpen = false;
		_aiSaveFormOpen = true;
	}

	private void CloseAiSaveForm()
	{
		_aiSaveFormOpen = false;
		_aiMeal = null;
		_aiTargetDay = null;
	}

	private async Task SaveAiMealAndAssignAsync(MealForm.MealFormResult result)
	{
		var targetDay = _aiTargetDay;
		_aiSaveFormOpen = false;
		_error = null;
		try
		{
			var created = await Api.CreateMealAsync(new CreateMealRequest(
				result.Name, result.Category, result.Ingredients, result.CookingTimeMinutes));
			if (created is not null)
			{
				MealsCache.AddOrUpdate(created);
				if (_plan is not null && targetDay is not null)
				{
					var updated = await Api.AssignMealAsync(_plan.Id, targetDay.DayOfWeek, created.Id);
					if (updated is not null)
					{
						CheckState.ClearCoverageForDayPlans([targetDay.Id]);
						WeeklyPlans.Set(updated);
						ShoppingSync.TriggerSync();
						Toasts.Show($"\u201e{created.Name}\u201d sparad och tilldelad.");
					}
				}
				else
				{
					Toasts.Show($"\u201e{created.Name}\u201d sparad.");
				}
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte spara AI-maträtten: {ex.Message}";
		}
		finally
		{
			_aiMeal = null;
			_aiTargetDay = null;
		}
	}

	private async Task CreateMealFromSelectorAsync(MealForm.MealFormResult result)
	{
		if (_plan is null || _selectedDay is null)
		{
			return;
		}

		_error = null;
		try
		{
			var created = await Api.CreateMealAsync(new CreateMealRequest(
				result.Name, result.Category, result.Ingredients, result.CookingTimeMinutes));
			if (created is not null)
			{
				MealsCache.AddOrUpdate(created);
				var affectedId = _selectedDay.Id;
				var updated = await Api.AssignMealAsync(_plan.Id, _selectedDay.DayOfWeek, created.Id);
				if (updated is not null)
				{
					CheckState.ClearCoverageForDayPlans([affectedId]);
					WeeklyPlans.Set(updated);
					ShoppingSync.TriggerSync();
					Toasts.Show($"\u201e{created.Name}\u201d sparad och tilldelad.");
				}
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte skapa maträtten: {ex.Message}";
		}
		finally
		{
			CloseSelector();
		}
	}
}
