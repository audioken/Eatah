@page "/"
@inject ApiClient Api

<div class="max-w-6xl mx-auto">
	<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
		<div>
			<h1 class="text-2xl md:text-3xl font-bold">Veckoplan</h1>
			@if (_plan is not null)
			{
				<p class="text-slate-500 text-sm">Vecka @_plan.WeekNumber, @_plan.Year</p>
			}
		</div>
		@if (_plan is not null)
		{
			<RandomizeButton IsBusy="_isRandomizing" OnClick="RandomizeAsync" />
		}
	</div>

	@if (_error is not null)
	{
		<div class="mb-4 p-3 rounded-md bg-red-50 border border-red-200 text-red-700 text-sm">
			@_error
		</div>
	}

	@if (_isLoading)
	{
		<div class="p-8 text-center text-slate-500">Laddar veckoplan..</div>
	}
	else if (_plan is null)
	{
		<div class="p-8 text-center text-slate-500">Ingen veckoplan kunde laddas.</div>
	}
	else
	{
		<div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_320px] gap-6">
			<WeekView Days="_plan.Days" OnDaySelected="OpenSelector" OnDayCleared="ClearDayAsync"
					  OnDayRandomDb="RandomizeDayDbAsync" OnDayRandomAi="StartAiForDayAsync" />

			<aside class="space-y-4">
				@if (_profiles is { Count: > 0 })
				{
					<div class="p-4 rounded-lg border border-slate-200 bg-white">
						<label for="profile" class="block text-sm font-semibold text-slate-700 mb-2">Kostprofil</label>
						<select id="profile"
								class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-500"
								@onchange="OnProfileChanged">
							@foreach (var profile in _profiles)
							{
								<option value="@profile.Id" selected="@(profile.Id == _selectedProfileId)">@profile.Name</option>
							}
						</select>
					</div>

					<StrictnessSlider Value="_strictness" ValueChanged="OnStrictnessChanged" />

					@if (_isEvaluating)
					{
						<div class="p-4 rounded-lg border border-slate-200 bg-white text-sm text-slate-500 text-center">
							Utvärderar plan...
						</div>
					}
					else if (_evaluation is not null)
					{
						<DietScoreGauge Score="_evaluation.OverallScore" />

						<div class="space-y-2">
							@foreach (var rule in _evaluation.RuleResults)
							{
								<RuleResultCard Result="rule" />
							}
						</div>
					}
				}
			</aside>
		</div>
	}
</div>

<MealSelector IsOpen="_selectorOpen" Day="_selectedDay?.DayOfWeek" Meals="_meals" OnSelect="AssignMealAsync"
			  OnCreate="CreateMealFromSelectorAsync" OnClose="CloseSelector" />

<AiMealPreview IsOpen="_aiPreviewOpen" Day="_aiTargetDay?.DayOfWeek" Meal="_aiMeal" IsLoading="_aiLoading"
			   Error="@_aiError" OnSave="OpenSaveAiMealForm" OnClose="CloseAiPreview" />

<MealForm IsOpen="_aiSaveFormOpen" InitialName="@_aiMeal?.Name" InitialCategory="_aiMeal?.Category"
		  InitialIngredients="_aiMeal?.Ingredients" InitialCookingTimeMinutes="_aiMeal?.CookingTimeMinutes"
		  UnsavedNotice="@($"Spara maträtten till databasen för att tilldela den till {AiTargetDayLabel}.")"
		  OnSubmit="SaveAiMealAndAssignAsync" OnClose="CloseAiSaveForm" />

@code {
	private WeeklyPlanResponse? _plan;
	private List<MealResponse>? _meals;
	private List<DietProfileResponse>? _profiles;
	private DietEvaluationResponse? _evaluation;
	private Guid? _selectedProfileId;
	private double _strictness = 0.5;
	private DayPlanResponse? _selectedDay;
	private bool _selectorOpen;
	private bool _isLoading = true;
	private bool _isRandomizing;
	private bool _isEvaluating;
	private string? _error;

	private DayPlanResponse? _aiTargetDay;
	private AiGeneratedMealResponse? _aiMeal;
	private bool _aiPreviewOpen;
	private bool _aiLoading;
	private string? _aiError;
	private bool _aiSaveFormOpen;

	private string AiTargetDayLabel => _aiTargetDay?.DayOfWeek switch
	{
		DayOfWeek.Monday => "måndag",
		DayOfWeek.Tuesday => "tisdag",
		DayOfWeek.Wednesday => "onsdag",
		DayOfWeek.Thursday => "torsdag",
		DayOfWeek.Friday => "fredag",
		DayOfWeek.Saturday => "lördag",
		DayOfWeek.Sunday => "söndag",
		_ => "vald dag"
	};

	protected override async Task OnInitializedAsync()
	{
		await LoadAsync();
	}

	private async Task LoadAsync()
	{
		_isLoading = true;
		_error = null;
		try
		{
			var planTask = Api.GetCurrentWeeklyPlanAsync();
			var mealsTask = Api.GetMealsAsync();
			var profilesTask = Api.GetDietProfilesAsync();
			await Task.WhenAll(planTask, mealsTask, profilesTask);
			_plan = await planTask;
			_meals = await mealsTask;
			_profiles = await profilesTask;
			_selectedProfileId = _profiles.FirstOrDefault()?.Id;
			await EvaluateAsync();
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte ladda veckoplanen: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
		}
	}

	private async Task EvaluateAsync()
	{
		if (_plan is null || _selectedProfileId is null)
		{
			_evaluation = null;
			return;
		}

		_isEvaluating = true;
		try
		{
			_evaluation = await Api.EvaluateWeeklyPlanAsync(_plan.Id, _selectedProfileId.Value);
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte utvÃ¤rdera planen: {ex.Message}";
		}
		finally
		{
			_isEvaluating = false;
		}
	}

	private async Task OnProfileChanged(ChangeEventArgs e)
	{
		if (Guid.TryParse(e.Value?.ToString(), out var id))
		{
			_selectedProfileId = id;
			await EvaluateAsync();
		}
	}

	private void OnStrictnessChanged(double value)
	{
		_strictness = value;
	}

	private void OpenSelector(DayPlanResponse day)
	{
		_selectedDay = day;
		_selectorOpen = true;
	}

	private void CloseSelector()
	{
		_selectorOpen = false;
		_selectedDay = null;
	}

	private async Task AssignMealAsync(MealResponse meal)
	{
		if (_plan is null || _selectedDay is null)
		{
			return;
		}

		try
		{
			var updated = await Api.AssignMealAsync(_plan.Id, _selectedDay.DayOfWeek, meal.Id);
			if (updated is not null)
			{
				_plan = updated;
				await EvaluateAsync();
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte tilldela matrÃ¤tten: {ex.Message}";
		}
		finally
		{
			CloseSelector();
		}
	}

	private async Task ClearDayAsync(DayPlanResponse day)
	{
		if (_plan is null)
		{
			return;
		}

		try
		{
			var updated = await Api.ClearDayAsync(_plan.Id, day.DayOfWeek);
			if (updated is not null)
			{
				_plan = updated;
				await EvaluateAsync();
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte ta bort matrÃ¤tten: {ex.Message}";
		}
	}

	private async Task RandomizeAsync()
	{
		if (_plan is null)
		{
			return;
		}

		_isRandomizing = true;
		_error = null;
		try
		{
			var updated = await Api.RandomizeWeekAsync(_plan.Id, _selectedProfileId, _strictness);
			if (updated is not null)
			{
				_plan = updated;
				await EvaluateAsync();
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte slumpa veckan: {ex.Message}";
		}
		finally
		{
			_isRandomizing = false;
		}
	}

	private async Task RandomizeDayDbAsync(DayPlanResponse day)
	{
		if (_plan is null)
		{
			return;
		}

		_error = null;
		try
		{
			var updated = await Api.RandomizeDayAsync(_plan.Id, day.DayOfWeek, _selectedProfileId, _strictness);
			if (updated is not null)
			{
				_plan = updated;
				await EvaluateAsync();
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte slumpa dagen: {ex.Message}";
		}
	}

	private async Task StartAiForDayAsync(DayPlanResponse day)
	{
		if (_plan is null)
		{
			return;
		}

		_aiTargetDay = day;
		_aiMeal = null;
		_aiError = null;
		_aiLoading = true;
		_aiPreviewOpen = true;
		try
		{
			var request = new GenerateMealRequest(
				Category: null,
				DietProfileId: _selectedProfileId,
				WeeklyPlanId: _plan.Id,
				TargetDay: day.DayOfWeek);
			_aiMeal = await Api.GenerateAiMealAsync(request);
		}
		catch (Exception ex)
		{
			_aiError = $"AI-generering misslyckades: {ex.Message}";
		}
		finally
		{
			_aiLoading = false;
		}
	}

	private void CloseAiPreview()
	{
		_aiPreviewOpen = false;
		_aiMeal = null;
		_aiError = null;
		_aiTargetDay = null;
	}

	private void OpenSaveAiMealForm()
	{
		if (_aiMeal is null)
		{
			return;
		}
		_aiPreviewOpen = false;
		_aiSaveFormOpen = true;
	}

	private void CloseAiSaveForm()
	{
		_aiSaveFormOpen = false;
		_aiMeal = null;
		_aiTargetDay = null;
	}

	private async Task SaveAiMealAndAssignAsync(MealForm.MealFormResult result)
	{
		var targetDay = _aiTargetDay;
		_aiSaveFormOpen = false;
		_error = null;
		try
		{
			var created = await Api.CreateMealAsync(new CreateMealRequest(
				result.Name, result.Category, result.Ingredients, result.CookingTimeMinutes));
			if (created is not null)
			{
				_meals = _meals is null ? [created] : [.. _meals, created];
				if (_plan is not null && targetDay is not null)
				{
					var updated = await Api.AssignMealAsync(_plan.Id, targetDay.DayOfWeek, created.Id);
					if (updated is not null)
					{
						_plan = updated;
						await EvaluateAsync();
					}
				}
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte spara AI-maträtten: {ex.Message}";
		}
		finally
		{
			_aiMeal = null;
			_aiTargetDay = null;
		}
	}

	private async Task CreateMealFromSelectorAsync(MealForm.MealFormResult result)
	{
		if (_plan is null || _selectedDay is null)
		{
			return;
		}

		_error = null;
		try
		{
			var created = await Api.CreateMealAsync(new CreateMealRequest(
				result.Name, result.Category, result.Ingredients, result.CookingTimeMinutes));
			if (created is not null)
			{
				_meals = _meals is null ? [created] : [.. _meals, created];
				var updated = await Api.AssignMealAsync(_plan.Id, _selectedDay.DayOfWeek, created.Id);
				if (updated is not null)
				{
					_plan = updated;
					await EvaluateAsync();
				}
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte skapa maträtten: {ex.Message}";
		}
		finally
		{
			CloseSelector();
		}
	}
}
