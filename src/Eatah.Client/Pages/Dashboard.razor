@page "/"
@inject ApiClient Api

<div class="max-w-6xl mx-auto">
	<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
		<div>
			<h1 class="text-2xl md:text-3xl font-bold">Veckoplan</h1>
			@if (_plan is not null)
			{
				<p class="text-slate-500 text-sm">Vecka @_plan.WeekNumber, @_plan.Year</p>
			}
		</div>
		@if (_plan is not null)
		{
			<RandomizeButton IsBusy="_isRandomizing" OnClick="RandomizeAsync" />
		}
	</div>

	@if (_error is not null)
	{
		<div class="mb-4 p-3 rounded-md bg-red-50 border border-red-200 text-red-700 text-sm">
			@_error
		</div>
	}

	@if (_isLoading)
	{
		<div class="p-8 text-center text-slate-500">Laddar veckoplanâ€¦</div>
	}
	else if (_plan is null)
	{
		<div class="p-8 text-center text-slate-500">Ingen veckoplan kunde laddas.</div>
	}
	else
	{
		<div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_320px] gap-6">
			<WeekView Days="_plan.Days"
					  OnDaySelected="OpenSelector"
					  OnDayCleared="ClearDayAsync" />

			<aside class="space-y-4">
				@if (_profiles is { Count: > 0 })
				{
					<div class="p-4 rounded-lg border border-slate-200 bg-white">
						<label for="profile" class="block text-sm font-semibold text-slate-700 mb-2">Kostprofil</label>
						<select id="profile"
								class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-500"
								@onchange="OnProfileChanged">
							@foreach (var profile in _profiles)
							{
								<option value="@profile.Id" selected="@(profile.Id == _selectedProfileId)">@profile.Name</option>
							}
						</select>
					</div>

					<StrictnessSlider Value="_strictness" ValueChanged="OnStrictnessChanged" />

					@if (_isEvaluating)
					{
						<div class="p-4 rounded-lg border border-slate-200 bg-white text-sm text-slate-500 text-center">
							UtvÃ¤rderar planâ€¦
						</div>
					}
					else if (_evaluation is not null)
					{
						<DietScoreGauge Score="_evaluation.OverallScore" />

						<div class="space-y-2">
							@foreach (var rule in _evaluation.RuleResults)
							{
								<RuleResultCard Result="rule" />
							}
						</div>
					}
				}
			</aside>
		</div>
	}
</div>

<MealSelector IsOpen="_selectorOpen"
			  Day="_selectedDay?.DayOfWeek"
			  Meals="_meals"
			  OnSelect="AssignMealAsync"
			  OnClose="CloseSelector" />

@code {
	private WeeklyPlanResponse? _plan;
	private List<MealResponse>? _meals;
	private List<DietProfileResponse>? _profiles;
	private DietEvaluationResponse? _evaluation;
	private Guid? _selectedProfileId;
	private double _strictness = 0.5;
	private DayPlanResponse? _selectedDay;
	private bool _selectorOpen;
	private bool _isLoading = true;
	private bool _isRandomizing;
	private bool _isEvaluating;
	private string? _error;

	protected override async Task OnInitializedAsync()
	{
		await LoadAsync();
	}

	private async Task LoadAsync()
	{
		_isLoading = true;
		_error = null;
		try
		{
			var planTask = Api.GetCurrentWeeklyPlanAsync();
			var mealsTask = Api.GetMealsAsync();
			var profilesTask = Api.GetDietProfilesAsync();
			await Task.WhenAll(planTask, mealsTask, profilesTask);
			_plan = await planTask;
			_meals = await mealsTask;
			_profiles = await profilesTask;
			_selectedProfileId = _profiles.FirstOrDefault()?.Id;
			await EvaluateAsync();
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte ladda veckoplanen: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
		}
	}

	private async Task EvaluateAsync()
	{
		if (_plan is null || _selectedProfileId is null)
		{
			_evaluation = null;
			return;
		}

		_isEvaluating = true;
		try
		{
			_evaluation = await Api.EvaluateWeeklyPlanAsync(_plan.Id, _selectedProfileId.Value);
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte utvÃ¤rdera planen: {ex.Message}";
		}
		finally
		{
			_isEvaluating = false;
		}
	}

	private async Task OnProfileChanged(ChangeEventArgs e)
	{
		if (Guid.TryParse(e.Value?.ToString(), out var id))
		{
			_selectedProfileId = id;
			await EvaluateAsync();
		}
	}

	private void OnStrictnessChanged(double value)
	{
		_strictness = value;
	}

	private void OpenSelector(DayPlanResponse day)
	{
		_selectedDay = day;
		_selectorOpen = true;
	}

	private void CloseSelector()
	{
		_selectorOpen = false;
		_selectedDay = null;
	}

	private async Task AssignMealAsync(MealResponse meal)
	{
		if (_plan is null || _selectedDay is null)
		{
			return;
		}

		try
		{
			var updated = await Api.AssignMealAsync(_plan.Id, _selectedDay.DayOfWeek, meal.Id);
			if (updated is not null)
			{
				_plan = updated;
				await EvaluateAsync();
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte tilldela matrÃ¤tten: {ex.Message}";
		}
		finally
		{
			CloseSelector();
		}
	}

	private async Task ClearDayAsync(DayPlanResponse day)
	{
		if (_plan is null)
		{
			return;
		}

		try
		{
			var updated = await Api.ClearDayAsync(_plan.Id, day.DayOfWeek);
			if (updated is not null)
			{
				_plan = updated;
				await EvaluateAsync();
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte ta bort matrÃ¤tten: {ex.Message}";
		}
	}

	private async Task RandomizeAsync()
	{
		if (_plan is null)
		{
			return;
		}

		_isRandomizing = true;
		_error = null;
		try
		{
			var updated = await Api.RandomizeWeekAsync(_plan.Id, _selectedProfileId, _strictness);
			if (updated is not null)
			{
				_plan = updated;
				await EvaluateAsync();
			}
		}
		catch (Exception ex)
		{
			_error = $"Kunde inte slumpa veckan: {ex.Message}";
		}
		finally
		{
			_isRandomizing = false;
		}
	}
}
