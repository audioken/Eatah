@page "/auth/change-password"
@inject ApiClient Api
@inject AuthState AuthState
@inject ToastService Toast
@inject NavigationManager Nav

<AuthGuard>
    <div class="eatah-auth-page eatah-auth-page--embedded">
        <div class="eatah-auth-card">
            <h1 class="eatah-auth-card__title">Byt lösenord</h1>

            <form @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                <label class="eatah-auth-field">
                    <span class="eatah-auth-field__label">Nuvarande lösenord</span>
                    <PasswordInput Value="@_current" ValueChanged="v => _current = v" Autocomplete="current-password" />
                </label>
                <label class="eatah-auth-field">
                    <span class="eatah-auth-field__label">Nytt lösenord</span>
                    <PasswordInput Value="@_new" ValueChanged="v => _new = v" Autocomplete="new-password"
                                   ShowStrength="true" />
                </label>
                <label class="eatah-auth-field">
                    <span class="eatah-auth-field__label">Bekräfta nytt lösenord</span>
                    <PasswordInput Value="@_confirm" ValueChanged="v => _confirm = v" Autocomplete="new-password" />
                </label>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="eatah-auth-error">@_error</div>
                }

                <button type="submit" class="eatah-auth-button" disabled="@_busy">
                    @(_busy ? "Sparar…" : "Spara nytt lösenord")
                </button>
            </form>
        </div>
    </div>
</AuthGuard>

@code {
    private string _current = string.Empty;
    private string _new = string.Empty;
    private string _confirm = string.Empty;
    private bool _busy;
    private string? _error;

    private async Task HandleSubmit()
    {
        if (_busy) return;
        _error = null;
        if (_new.Length < 8) { _error = "Nytt lösenord måste vara minst 8 tecken."; return; }
        if (_new != _confirm) { _error = "Lösenorden matchar inte."; return; }

        _busy = true;
        try
        {
            await Api.ChangePasswordAsync(new ChangePasswordRequest(_current, _new));
            Toast.Show("Lösenordet uppdaterat.");
            Nav.NavigateTo(Nav.BaseUri, forceLoad: false);
        }
        catch (ApiException ex)
        {
            _error = ex.ErrorCode switch
            {
                ApiErrorCodes.AuthInvalidCredentials => "Nuvarande lösenord är fel.",
                ApiErrorCodes.AuthPasswordInvalid => "Nytt lösenord uppfyller inte kraven.",
                _ => "Något gick fel. Försök igen."
            };
        }
        catch
        {
            _error = "Kunde inte ansluta till servern.";
        }
        finally
        {
            _busy = false;
        }
    }
}
