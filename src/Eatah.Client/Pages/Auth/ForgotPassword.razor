@page "/auth/forgot-password"
@layout EmptyAuthLayout
@inject ApiClient Api

<div class="eatah-auth-page">
    <div class="eatah-auth-card">
        <h1 class="eatah-auth-card__title">Glömt lösenord</h1>
        <p class="eatah-auth-card__subtitle">Ange din e-post så skickar vi en återställningslänk.</p>

        @if (_sent)
        {
            <div class="eatah-auth-success">
                <p>Om <strong>@_email</strong> finns hos oss har vi nu skickat ett mejl med instruktioner.</p>
            </div>
            <a class="eatah-auth-button eatah-auth-button--secondary" href="/auth/login">Tillbaka till inloggning</a>
        }
        else
        {
            <form @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                <label class="eatah-auth-field">
                    <span class="eatah-auth-field__label">E-post</span>
                    <input type="email" class="eatah-auth-field__input" value="@_email"
                           @oninput="e => _email = e.Value?.ToString() ?? string.Empty" autocomplete="email" required />
                </label>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="eatah-auth-error">@_error</div>
                }

                <button type="submit" class="eatah-auth-button" disabled="@_busy">
                    @(_busy ? "Skickar…" : "Skicka länk")
                </button>
            </form>

            <div class="eatah-auth-card__links">
                <a href="/auth/login">Tillbaka till inloggning</a>
            </div>
        }
    </div>
</div>

@code {
    private string _email = string.Empty;
    private bool _busy;
    private bool _sent;
    private string? _error;

    private async Task HandleSubmit()
    {
        if (_busy) return;
        _error = null;
        if (string.IsNullOrWhiteSpace(_email) || !_email.Contains('@'))
        {
            _error = "Ange en giltig e-postadress.";
            return;
        }

        _busy = true;
        try
        {
            await Api.RequestPasswordResetAsync(new RequestPasswordResetRequest(_email.Trim()));
            _sent = true;
        }
        catch
        {
            // Even on error we show success so we don't leak whether the email exists.
            _sent = true;
        }
        finally
        {
            _busy = false;
        }
    }
}
