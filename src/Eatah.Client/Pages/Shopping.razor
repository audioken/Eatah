@page "/shopping"
@inject ApiClient Api
@inject ToastService Toasts
@inject HeaderState Header
@inject PantryStateService PantryState
@inject ShoppingStateService ShoppingState
@inject IngredientCheckState CheckState
@implements IDisposable

<div class="eatah-shopping-page">
    @if (_error is not null)
    {
        <div class="mb-3 p-3 rounded-md bg-red-50 border border-red-200 text-red-700 text-sm">@_error</div>
    }

    @if (_isLoading)
    {
        <div class="p-8 text-center text-white/70">Laddar köplista…</div>
    }
    else
    {
        <!-- Two-column layout -->
        <div class="eatah-shopping-columns">

            <!-- LEFT: Skafferi -->
            <div class="eatah-shopping-col">
                <div class="eatah-shopping-col__header">
                    <Icon Name="house" Size="16" CssClass="eatah-shopping-col__header-icon" />
                    <span>Skafferi</span>
                    <span class="eatah-shopping-col__count">@PantryState.Items.Count</span>
                </div>

                <div class="eatah-shopping-col__add">
                    <IngredientSearch Placeholder="Lägg till i skafferi…" OnSelected="AddToPantryAsync" />
                </div>

                <div class="eatah-shopping-col__list">
                    @if (!PantryState.Items.Any())
                    {
                        <p class="eatah-shopping-col__empty">Skafferiet är tomt.</p>
                    }
                    else
                    {
                        @foreach (var item in PantryState.Items)
                        {
                            <div class="eatah-shopping-item eatah-shopping-item--pantry">
                                <div class="eatah-shopping-item__body">
                                    <span class="eatah-shopping-item__name">@item.Name</span>
                                    <span class="eatah-shopping-item__meta">Tillagt @FormatDate(item.AddedAt)</span>
                                </div>
                                <button type="button" class="eatah-shopping-item__remove" title="Ta bort från skafferiet"
                                        @onclick="() => RemoveFromPantryAsync(item)">
                                    <Icon Name="close" Size="12" />
                                </button>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- RIGHT: Köplista -->
            <div class="eatah-shopping-col">
                <div class="eatah-shopping-col__header">
                    <Icon Name="basket" Size="16" CssClass="eatah-shopping-col__header-icon" />
                    <span>Köplista</span>
                    <span class="eatah-shopping-col__count">@ShoppingState.Items.Count(s => !s.IsChecked)</span>
                </div>

                <div class="eatah-shopping-col__add">
                    <IngredientSearch Placeholder="Lägg till på köplistan…" OnSelected="AddToShoppingAsync" />
                </div>
                @if (_selectedShoppingItems.Count > 0)
                {
                    <div class="eatah-shopping-actions">
                        <button type="button" class="eatah-shopping-actions__btn eatah-shopping-actions__btn--primary"
                                @onclick="MoveSelectedToPantryAsync">
                            <Icon Name="arrow-left" Size="13" />
                            <span>Flytta till skafferi</span>
                        </button>
                        <div class="eatah-shopping-actions__slot" />
                        <div class="eatah-shopping-actions__slot" />
                    </div>
                }

                <div class="eatah-shopping-col__list">
                    @if (ShoppingState.Items.Count == 0)
                    {
                        <p class="eatah-shopping-col__empty">Köplistan är tom.</p>
                    }
                    else
                    {
                        @* Unchecked items – grouped by meal if Notes contains a meal name *@
                        @if (UseGroups)
                        {
                            @foreach (var group in UncheckedGroups)
                            {
                                var groupKey = group.Key ?? "Övrigt";
                                var isExpanded = _expandedGroups.Contains(groupKey);
                                <div class="eatah-shopping-group">
                                    <button type="button" class="eatah-shopping-group__header"
                                            @onclick="() => ToggleGroup(groupKey)">
                                        <Icon Name="@(isExpanded ? "angle-down-solid" : "angle-right-solid")"
                                              Size="10" CssClass="eatah-shopping-group__chevron" />
                                        <span class="eatah-shopping-group__name">@groupKey</span>
                                        <span class="eatah-shopping-group__count">@group.Count()</span>
                                    </button>
                                    @if (isExpanded)
                                    {
                                        <div class="eatah-shopping-group__items">
                                            @foreach (var item in group)
                                            {
                                                var isSelected = _selectedShoppingItems.Contains(item.Id);
                                                var itemSelClass = isSelected ? "eatah-shopping-item--selected" : "";
                                                var btnSelClass = isSelected ? "eatah-shopping-item__select--active" : "";
                                                <div class="eatah-shopping-item eatah-shopping-item--unchecked @itemSelClass">
                                                    <button type="button" class="eatah-shopping-item__select @btnSelClass"
                                                            @onclick="() => ToggleShoppingSelection(item.Id)">
                                                        @if (isSelected)
                                                        {
                                                            <Icon Name="check" Size="10" />
                                                        }
                                                    </button>
                                                    <div class="eatah-shopping-item__body">
                                                        <span class="eatah-shopping-item__name">@item.Name</span>
                                                    </div>
                                                    <button type="button" class="eatah-shopping-item__remove"
                                                            title="Ta bort"
                                                            @onclick="() => RemoveFromShoppingAsync(item)">
                                                        <Icon Name="close" Size="12" />
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            @foreach (var item in ShoppingState.Items.Where(s => !s.IsChecked))
                            {
                                var isSelected = _selectedShoppingItems.Contains(item.Id);
                                var itemSelClass = isSelected ? "eatah-shopping-item--selected" : "";
                                var btnSelClass = isSelected ? "eatah-shopping-item__select--active" : "";
                                <div class="eatah-shopping-item eatah-shopping-item--unchecked @itemSelClass">
                                    <button type="button" class="eatah-shopping-item__select @btnSelClass"
                                            @onclick="() => ToggleShoppingSelection(item.Id)">
                                        @if (isSelected)
                                        {
                                            <Icon Name="check" Size="10" />
                                        }
                                    </button>
                                    <div class="eatah-shopping-item__body">
                                        <span class="eatah-shopping-item__name">@item.Name</span>
                                        @if (!string.IsNullOrEmpty(item.Notes))
                                        {
                                            <span class="eatah-shopping-item__notes">@item.Notes</span>
                                        }
                                    </div>
                                    <button type="button" class="eatah-shopping-item__remove" title="Ta bort"
                                            @onclick="() => RemoveFromShoppingAsync(item)">
                                        <Icon Name="close" Size="12" />
                                    </button>
                                </div>
                            }
                        }

                        <!-- Checked items (grayed out) -->
                        @if (ShoppingState.Items.Any(s => s.IsChecked))
                        {
                            <div class="eatah-shopping-checked-divider">
                                <span>Köpt</span>
                                <button type="button" class="eatah-shopping-clear-btn" @onclick="ClearCheckedAsync">
                                    Rensa
                                </button>
                            </div>
                            @foreach (var item in ShoppingState.Items.Where(s => s.IsChecked))
                            {
                                <div class="eatah-shopping-item eatah-shopping-item--checked">
                                    <button type="button" class="eatah-shopping-item__check eatah-shopping-item__check--done"
                                            title="Avmarkera" @onclick="() => UncheckItemAsync(item)">
                                        <Icon Name="check" Size="10" />
                                    </button>
                                    <div class="eatah-shopping-item__body">
                                        <span class="eatah-shopping-item__name">@item.Name</span>
                                    </div>
                                    <button type="button" class="eatah-shopping-item__remove" title="Ta bort"
                                            @onclick="() => RemoveFromShoppingAsync(item)">
                                        <Icon Name="close" Size="12" />
                                    </button>
                                </div>
                            }
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private HashSet<Guid> _selectedShoppingItems = [];
    private HashSet<string> _expandedGroups = new(StringComparer.OrdinalIgnoreCase);

    private IList<IGrouping<string?, ShoppingItemResponse>> UncheckedGroups =>
        ShoppingState.Items
            .Where(s => !s.IsChecked)
            .GroupBy(s => ExtractMealName(s.Notes))
            .OrderBy(g => g.Key is null ? 1 : 0)
            .ThenBy(g => g.Key)
            .ToList();

    private bool UseGroups
    {
        get
        {
            var g = UncheckedGroups;
            return g.Count > 1 || g.Any(x => x.Key != null);
        }
    }
    private bool _isLoading = true;
    private string? _error;
    private Guid? _currentPlanId;

    protected override void OnInitialized()
    {
        Header.Set(center: @<span>Köplista</span>);
        PantryState.OnChanged += OnPantryChanged;
        ShoppingState.OnChanged += OnShoppingChanged;
    }

    public void Dispose()
    {
        Header.Clear();
        PantryState.OnChanged -= OnPantryChanged;
        ShoppingState.OnChanged -= OnShoppingChanged;
    }

    private void OnPantryChanged() => InvokeAsync(StateHasChanged);
    private void OnShoppingChanged() { ReinitGroups(); InvokeAsync(StateHasChanged); }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var planTask = Api.GetCurrentWeeklyPlanAsync();
            var pantryTask = Api.GetPantryAsync();
            var shoppingTask = Api.GetShoppingListAsync();

            await Task.WhenAll(pantryTask, shoppingTask, planTask);

            ShoppingState.SetShopping(await shoppingTask);
            _currentPlanId = (await planTask)?.Id;
            PantryState.SetPantry(await pantryTask);
            ReinitGroups();
        }
        catch (Exception ex)
        {
            _error = $"Kunde inte ladda data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }

        // Auto-sync from meal plan silently in the background after initial data is shown
        if (_currentPlanId.HasValue)
            _ = SyncSilentlyAsync(_currentPlanId.Value);
    }

    private async Task SyncSilentlyAsync(Guid planId)
    {
        try
        {
            // ShoppingState.SetShopping fires OnShoppingChanged which calls ReinitGroups + StateHasChanged
            ShoppingState.SetShopping(await Api.SyncShoppingFromWeeklyPlanAsync(planId));
        }
        catch
        {
            // Silent failure – don't interrupt the user
        }
    }

    private async Task AddToPantryAsync(IngredientResponse ing)
    {
        try
        {
            var item = await Api.AddToPantryAsync(ing.Id);
            if (item is not null)
            {
                PantryState.AddItem(item);
                CheckState.AddPantryName(ing.Name);
            }
        }
        catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists)
        {
            Toasts.Show($"{ing.Name} finns redan i skafferiet.");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RemoveFromPantryAsync(PantryItemResponse item)
    {
        try
        {
            await Api.RemoveFromPantryAsync(item.Id);
            PantryState.RemoveItem(item.Id);

            // Re-sync so any newly missing ingredient appears on the shopping list immediately
            if (_currentPlanId.HasValue)
                _ = SyncSilentlyAsync(_currentPlanId.Value);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task AddToShoppingAsync(IngredientResponse ing)
    {
        try
        {
            var item = await Api.AddToShoppingListAsync(ing.Id);
            if (item is not null)
                ShoppingState.AddOrUpdateItem(item);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void ToggleShoppingSelection(Guid itemId)
    {
        if (!_selectedShoppingItems.Remove(itemId))
            _selectedShoppingItems.Add(itemId);
    }

    private async Task MoveSelectedToPantryAsync()
    {
        var toMove = ShoppingState.Items
            .Where(s => _selectedShoppingItems.Contains(s.Id) && !s.IsChecked)
            .ToList();
        _selectedShoppingItems.Clear();

        foreach (var item in toMove)
        {
            try
            {
                PantryItemResponse? pantryItem = null;
                try
                {
                    pantryItem = await Api.AddToPantryAsync(item.IngredientId);
                }
                catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists) { }

                await Api.RemoveFromShoppingListAsync(item.Id);
                ShoppingState.RemoveItem(item.Id);

                if (pantryItem is not null)
                {
                    PantryState.AddItem(pantryItem);
                    CheckState.AddPantryName(item.Name);
                }
            }
            catch (Exception ex)
            {
                _error = ex.Message;
            }
        }
    }

    private async Task CheckItemAsync(ShoppingItemResponse item)
    {
        try
        {
            await Api.ToggleShoppingItemAsync(item.Id, true);
            ShoppingState.UpdateItem(item with { IsChecked = true });
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task UncheckItemAsync(ShoppingItemResponse item)
    {
        try
        {
            await Api.ToggleShoppingItemAsync(item.Id, false);
            ShoppingState.UpdateItem(item with { IsChecked = false });
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RemoveFromShoppingAsync(ShoppingItemResponse item)
    {
        try
        {
            await Api.RemoveFromShoppingListAsync(item.Id);
            ShoppingState.RemoveItem(item.Id);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ClearCheckedAsync()
    {
        try
        {
            await Api.ClearCheckedShoppingItemsAsync();
            ShoppingState.RemoveChecked();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static string FormatDate(DateTime dt)
    {
        var days = (int)(DateTime.Today - dt.ToLocalTime().Date).TotalDays;
        if (days == 0) return "idag";
        if (days == 1) return "1 dag sen";
        return $"{days} dagar sen";
    }

    /// <summary>Extract meal name from Notes like "Pasta Carbonara v22" → "Pasta Carbonara".</summary>
    private static string? ExtractMealName(string? notes)
    {
        if (string.IsNullOrEmpty(notes)) return null;
        var first = notes.Split(',')[0].Trim();
        var vIdx = first.LastIndexOf(" v");
        if (vIdx > 0 && vIdx < first.Length - 2 && int.TryParse(first[(vIdx + 2)..], out _))
            return first[..vIdx];
        return first;
    }

    private void ToggleGroup(string key)
    {
        if (!_expandedGroups.Remove(key))
            _expandedGroups.Add(key);
    }

    /// <summary>Ensures all meal groups are expanded by default (new groups only; preserves manual collapse).</summary>
    private void ReinitGroups()
    {
        foreach (var key in ShoppingState.Items
            .Where(s => !s.IsChecked)
            .Select(s => ExtractMealName(s.Notes) ?? "Övrigt")
            .Distinct(StringComparer.OrdinalIgnoreCase))
        {
            _expandedGroups.Add(key);
        }
    }
}
