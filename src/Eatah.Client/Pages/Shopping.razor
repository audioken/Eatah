    private static string FormatDate(DateTime dt)
    {
        var days = (int)(DateTime.Today - dt.ToLocalTime().Date).TotalDays;
        if (days == 0) return "idag";
        if (days == 1) return "1 dag sen";
        return $"{days} dagar sen";
    }

    /// <summary>Count how many meals this ingredient is needed by, from Notes like "Pasta v22, Fisk v22" → 2.</summary>
    private static int GetMealCount(string? notes)
    {
        if (string.IsNullOrEmpty(notes)) return 0;
        return notes.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Length;
    }

    /// <summary>Extract the first meal name from Notes. Handles both "Pasta v22" and "Pasta v22d0" format.</summary>
    private static string? ExtractMealName(string? notes)
    {
        if (string.IsNullOrEmpty(notes)) return null;
        var (mealName, _, _) = ParseNoteEntry(notes.Split(',')[0].Trim());
        return string.IsNullOrEmpty(mealName) ? null : mealName;
    }

    /// <summary>Extracts all meal names from Notes. Works with both old ("Pasta v22") and new ("Pasta v22d0") format.</summary>
    private static List<string> ExtractAllMealNames(string? notes)
    {
        if (string.IsNullOrEmpty(notes)) return [];
        return notes.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(part =>
            {
                var (mealName, _, _) = ParseNoteEntry(part);
                return mealName;
            })
            .Where(n => !string.IsNullOrEmpty(n))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void ToggleGroup(string key)
    {
        if (!_expandedGroups.Remove(key))
            _expandedGroups.Add(key);
    }

    /// <summary>
    /// Auto-expand: find the earliest upcoming day (today + tomorrow first) that has unchecked
    /// items and expand that week section + its meal groups. Falls back to the next N days with
    /// pending items if today/tomorrow are all bought.
    /// </summary>
    private void ReinitGroups()
    {
        _expandedWeeks.Clear();
        _expandedGroups.Clear();

        var today = DateTime.Today;
        var todayDayIdx = GetDayIndexFromDate(today);
        var tomorrowDate = today.AddDays(1);
        var todayWeek = ISOWeek.GetWeekOfYear(today);
        var todayPair = (Week: todayWeek, Day: todayDayIdx);
        var tomorrowPair = (Week: ISOWeek.GetWeekOfYear(tomorrowDate), Day: GetDayIndexFromDate(tomorrowDate));

        // Collect all unchecked items with day info parsed from notes
        var pendingByDay = ShoppingState.Items
            .Where(s => !s.IsChecked)
            .SelectMany(s =>
            {
                if (string.IsNullOrEmpty(s.Notes)) return [];
                return s.Notes.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Select(part =>
                    {
                        var (meal, week, day) = ParseNoteEntry(part);
                        return (Week: week, Day: day, MealName: meal);
                    })
                    .Where(x => x.Week.HasValue && x.Day.HasValue)
                    .Select(x => (Week: x.Week!.Value, Day: x.Day!.Value, x.MealName));
            })
            .ToList();

        // Try today and tomorrow first
        var focusPairs = pendingByDay
            .Select(x => (x.Week, x.Day))
            .Where(p => (p.Week == todayPair.Week && p.Day == todayPair.Day) ||
                        (p.Week == tomorrowPair.Week && p.Day == tomorrowPair.Day))
            .Distinct()
            .ToList();

        if (!focusPairs.Any())
        {
            // Today+tomorrow are empty or all bought – find the next 2 days with pending items
            focusPairs = pendingByDay
                .Select(x => (x.Week, x.Day))
                .Distinct()
                .OrderBy(p => WeekDaySortKey(p.Week, p.Day, todayPair.Week, todayPair.Day))
                .Take(2)
                .ToList();
        }

        foreach (var (week, day) in focusPairs)
        {
            var weekKey = $"v{week}";
            _expandedWeeks.Add(weekKey);

            foreach (var meal in pendingByDay
                .Where(x => x.Week == week && x.Day == day)
                .Select(x => x.MealName)
                .Distinct(StringComparer.OrdinalIgnoreCase))
            {
                _expandedGroups.Add(GetMealGroupKey(meal, weekKey));
            }
        }
    }

    private async Task OpenChatDropdown(char type)
    {
        if (!_selectedShoppingItems.Any(id => ShoppingState.Items.Any(s => s.Id == id && !s.IsChecked)))
            return;

        if (WorkspaceState.Current?.Type != WorkspaceType.Household)
        {
            Toasts.Show("Chattknapparna används i ett hushåll.");
            return;
        }

        _pendingChatType = type;
        _showChatDropdown = true;

        // Lazy-load household members once
        if (!_householdMembers.Any())
        {
            _dropdownLoading = true;
            try { _householdMembers = await Api.GetWorkspaceMembersAsync(); }
            catch { }
            _dropdownLoading = false;
        }
    }

    private async Task SendToGroupAsync()
    {
        _showChatDropdown = false;
        var message = BuildChatMessage(_pendingChatType == 'i' ? "Jag köper" : "Kan du köpa");
        if (message is null) return;

        try
        {
            var groupThread = await Api.GetOrCreateGroupThreadAsync();
            if (groupThread is null) { Toasts.Show("Kunde inte hitta hushållschatten."); return; }

            await Api.SendChatMessageAsync(groupThread.Id, message);
            Toasts.Show("Meddelande skickat till Hushållschatten 💬");
            var summary = new ChatThreadSummaryResponse(groupThread.Id, groupThread.WorkspaceId, "Group", null, null, null, null);
            ChatState.Open(summary);
        }
        catch
        {
            Toasts.Show("Kunde inte skicka meddelande.");
        }
    }

    private async Task SendToMemberAsync(WorkspaceMemberResponse member)
    {
        _showChatDropdown = false;
        var message = BuildChatMessage(_pendingChatType == 'i' ? "Jag köper" : "Kan du köpa");
        if (message is null) return;

        try
        {
            var thread = await Api.GetOrCreateDirectThreadAsync(member.UserId);
            if (thread is null) { Toasts.Show("Kunde inte öppna chatten."); return; }

            await Api.SendChatMessageAsync(thread.Id, message);
            Toasts.Show($"Meddelande skickat till {member.DisplayName} 💬");
            ChatState.Open(thread);
        }
        catch
        {
            Toasts.Show("Kunde inte skicka meddelande.");
        }
    }

    private string? BuildChatMessage(string prefix)
    {
        var selected = ShoppingState.Items
            .Where(s => _selectedShoppingItems.Contains(s.Id) && !s.IsChecked)
            .Select(s => s.Name)
            .ToList();
        if (!selected.Any()) return null;
        return $"{prefix}: {string.Join(", ", selected)}";
    }
