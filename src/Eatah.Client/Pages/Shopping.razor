@page "/shopping"
@inject ApiClient Api
@inject ToastService Toasts
@inject HeaderState Header
@inject PantryStateService PantryState
@inject ShoppingStateService ShoppingState
@inject IngredientCheckState CheckState
@inject ShoppingSyncService ShoppingSync
@inject ChatState ChatState
@inject WorkspaceState WorkspaceState
@implements IDisposable

<div class="eatah-shopping-page">
    @if (_error is not null)
    {
        <div class="mb-3 p-3 rounded-md bg-red-50 border border-red-200 text-red-700 text-sm">@_error</div>
    }

    @if (_isLoading)
    {
        <div class="p-8 text-center text-white/70">Laddar köplista…</div>
    }
    else
    {
        <!-- Two-column layout -->
        <div class="eatah-shopping-columns">

            <!-- LEFT: Skafferi -->
            <div class="eatah-shopping-col">
                <div class="eatah-shopping-col__header">
                    <Icon Name="house" Size="16" CssClass="eatah-shopping-col__header-icon" />
                    <span>Skafferi</span>
                    <span class="eatah-shopping-col__count">@PantryState.Items.Count</span>
                </div>

                <div class="eatah-shopping-col__add">
                    <IngredientSearch Placeholder="Lägg till i skafferi…" OnSelected="AddToPantryAsync" />
                </div>

                <div class="eatah-shopping-col__list">
                    @if (!PantryState.Items.Any())
                    {
                        <p class="eatah-shopping-col__empty">Skafferiet är tomt.</p>
                    }
                    else
                    {
                        @foreach (var item in PantryState.Items)
                        {
                            var pantryCount = CheckState.GetSharedMealCount(item.Name);
                            <div class="eatah-shopping-item eatah-shopping-item--pantry">
                                <div class="eatah-shopping-item__body">
                                    <div class="eatah-shopping-item__name-row">
                                        <span class="eatah-shopping-item__name">@item.Name</span>
                                        @if (pantryCount > 1)
                                        {
                                            <span class="eatah-shopping-item__count-badge">(@pantryCount)</span>
                                        }
                                    </div>
                                    <span class="eatah-shopping-item__meta">Tillagt @FormatDate(item.AddedAt)</span>
                                </div>
                                <button type="button" class="eatah-shopping-item__remove" title="Ta bort från skafferiet"
                                        @onclick="() => RemoveFromPantryAsync(item)">
                                    <Icon Name="close" Size="12" />
                                </button>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- RIGHT: Köplista -->
            <div class="eatah-shopping-col">
                <div class="eatah-shopping-col__header">
                    <Icon Name="basket" Size="16" CssClass="eatah-shopping-col__header-icon" />
                    <span>Köplista</span>
                    <span class="eatah-shopping-col__count">@ShoppingState.Items.Count(s => !s.IsChecked)</span>
                </div>

                <div class="eatah-shopping-col__add">
                    <IngredientSearch Placeholder="Lägg till på köplistan…" OnSelected="AddToShoppingAsync" />
                </div>
                @if (_selectedShoppingItems.Count > 0)
                {
                    <div class="eatah-shopping-actions">
                        <button type="button" class="eatah-shopping-actions__btn eatah-shopping-actions__btn--primary"
                                @onclick="MoveSelectedToPantryAsync">
                            <Icon Name="arrow-left" Size="13" />
                            <span>Flytta till skafferi</span>
                        </button>
                        <button type="button" class="eatah-shopping-actions__btn eatah-shopping-actions__btn--chat"
                                @onclick="() => OpenChatDropdown('i')" title="Jag köper dessa">
                            <Icon Name="chat" Size="13" />
                            <span>Jag köper</span>
                        </button>
                        <button type="button" class="eatah-shopping-actions__btn eatah-shopping-actions__btn--chat"
                                @onclick="() => OpenChatDropdown('k')" title="Be någon köpa dessa">
                            <Icon Name="chat" Size="13" />
                            <span>Kan du köpa?</span>
                        </button>
                    </div>
                }

                <div class="eatah-shopping-col__list">
                    @if (ShoppingState.Items.Count == 0)
                    {
                        <p class="eatah-shopping-col__empty">Köplistan är tom.</p>
                    }
                    else
                    {
                        @* Unchecked items grouped by week (Denna veckan / Nästa vecka) then by meal *@
                        @foreach (var weekGroup in WeekGroups)
                        {
                            var weekKey = weekGroup.WeekKey;
                            var weekExpanded = _expandedWeeks.Contains(weekKey);
                            var weekPendingCount = weekGroup.MealGroups.Sum(m => m.Views.Count);
                            <div class="eatah-shopping-week">
                                <button type="button" class="eatah-shopping-week__header" @onclick="() => ToggleWeek(weekKey)">
                                    <Icon Name="@(weekExpanded ? "angle-down-solid" : "angle-right-solid")" Size="10"
                                          CssClass="eatah-shopping-week__chevron" />
                                    <span class="eatah-shopping-week__label">@weekGroup.Label</span>
                                    <span class="eatah-shopping-week__count">@weekPendingCount</span>
                                </button>
                                @if (weekExpanded)
                                {
                                    <div class="eatah-shopping-week__body">
                                        @foreach (var mealGroup in weekGroup.MealGroups)
                                        {
                                            var groupKey = GetMealGroupKey(mealGroup.MealName, weekKey);
                                            var isExpanded = _expandedGroups.Contains(groupKey);
                                            <div class="eatah-shopping-group">
                                                <button type="button" class="eatah-shopping-group__header" @onclick="() => ToggleGroup(groupKey)">
                                                    <Icon Name="@(isExpanded ? "angle-down-solid" : "angle-right-solid")" Size="10"
                                                          CssClass="eatah-shopping-group__chevron" />
                                                    <span class="eatah-shopping-group__name">@mealGroup.MealName</span>
                                                    @if (mealGroup.DayIndex.HasValue)
                                                    {
                                                        <span class="eatah-shopping-group__day">@GetDayName(mealGroup.DayIndex.Value)</span>
                                                    }
                                                    <span class="eatah-shopping-group__count">@mealGroup.Views.Count</span>
                                                </button>
                                                @if (isExpanded)
                                                {
                                                    <div class="eatah-shopping-group__items">
                                                        @foreach (var view in mealGroup.Views)
                                                        {
                                                            var item = view.Item;
                                                            var isSelected = _selectedShoppingItems.Contains(item.Id);
                                                            var itemSelClass = isSelected ? "eatah-shopping-item--selected" : "";
                                                            var btnSelClass = isSelected ? "eatah-shopping-item__select--active" : "";
                                                            var groupedCount = GetMealCount(item.Notes);
                                                            <div class="eatah-shopping-item eatah-shopping-item--unchecked @itemSelClass">
                                                                <button type="button" class="eatah-shopping-item__select @btnSelClass"
                                                                        @onclick="() => ToggleShoppingSelection(item.Id)">
                                                                    @if (isSelected)
                                                                    {
                                                                        <Icon Name="check" Size="10" />
                                                                    }
                                                                </button>
                                                                <div class="eatah-shopping-item__body">
                                                                    <div class="eatah-shopping-item__name-row">
                                                                        <span class="eatah-shopping-item__name">@item.Name</span>
                                                                        @if (groupedCount > 1)
                                                                        {
                                                                            <span class="eatah-shopping-item__count-badge">(@groupedCount)</span>
                                                                        }
                                                                    </div>
                                                                </div>
                                                                <button type="button" class="eatah-shopping-item__remove" title="Ta bort"
                                                                        @onclick="() => RemoveFromShoppingAsync(item)">
                                                                    <Icon Name="close" Size="12" />
                                                                </button>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }

                        <!-- Checked items (grayed out) -->
                        @if (ShoppingState.Items.Any(s => s.IsChecked))
                        {
                            <div class="eatah-shopping-checked-divider">
                                <span>Köpt</span>
                                <button type="button" class="eatah-shopping-clear-btn" @onclick="ClearCheckedAsync">
                                    Rensa
                                </button>
                            </div>
                            @foreach (var item in ShoppingState.Items.Where(s => s.IsChecked))
                            {
                                <div class="eatah-shopping-item eatah-shopping-item--checked">
                                    <button type="button" class="eatah-shopping-item__check eatah-shopping-item__check--done"
                                            title="Avmarkera" @onclick="() => UncheckItemAsync(item)">
                                        <Icon Name="check" Size="10" />
                                    </button>
                                    <div class="eatah-shopping-item__body">
                                        <span class="eatah-shopping-item__name">@item.Name</span>
                                    </div>
                                    <button type="button" class="eatah-shopping-item__remove" title="Ta bort"
                                            @onclick="() => RemoveFromShoppingAsync(item)">
                                        <Icon Name="close" Size="12" />
                                    </button>
                                </div>
                            }
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@* Coverage confirmation popup for shared ingredients *@
@if (_coveragePopupOpen)
{
    <div class="fixed inset-0 z-[60] flex items-end sm:items-center justify-center bg-black/50 p-4"
         style="padding-bottom: max(1rem, var(--navbar-height, 64px));" @onclick="() => _coveragePopupOpen = false">
        <div class="w-full max-w-[420px] rounded-[20px] border border-black/10 font-kanit overflow-hidden"
             style="background: linear-gradient(135deg, #839B7F 0%, #A8D1AA 91.83%); box-shadow: 0px 8px 24px rgba(0,0,0,0.35);"
             @onclick:stopPropagation="true">

            <div class="px-5 pt-4 pb-2">
                <div class="text-white font-medium text-[18px] uppercase tracking-tight leading-tight">
                    Räcker till fler rätter?
                </div>
                <div class="text-white/75 text-[13px] mt-1">
                    Bocka av vilka rätter ingrediensen räcker till.
                </div>
            </div>

            <div class="px-4 pb-2 max-h-[50vh] overflow-y-auto space-y-3">
                @foreach (var cov in _pendingCoverage)
                {
                    <div>
                        <div class="text-white font-semibold text-[14px] mb-1.5 px-1">@cov.Item.Name</div>
                        @foreach (var meal in cov.AllMeals)
                        {
                            var isCovered = cov.CoveredMeals.Contains(meal);
                            var rowClass = isCovered ? "bg-white/35 border-white/30" : "bg-white/15 border-white/10";
                            <label class="flex items-center gap-2.5 px-3 py-2 rounded-[10px] border cursor-pointer mb-1 @rowClass">
                                <input type="checkbox" class="w-4 h-4 accent-white cursor-pointer flex-shrink-0"
                                       checked="@isCovered" @onchange="@(() => ToggleCoverage(cov, meal))" />
                                <span class="text-dayCardText text-[13px] font-medium truncate">@meal</span>
                            </label>
                        }
                    </div>
                }
            </div>

            <div class="px-4 pb-5 pt-2 flex gap-2">
                <button type="button"
                        class="flex-1 py-2.5 rounded-[12px] bg-white/30 hover:bg-white/45 text-white font-semibold text-[13px] uppercase tracking-wide"
                        @onclick="CoverAllAndConfirmAsync">
                    Räcker till alla
                </button>
                <button type="button"
                        class="flex-1 py-2.5 rounded-[12px] bg-white/15 hover:bg-white/25 text-white font-medium text-[13px]"
                        @onclick="ConfirmCoverageAsync">
                    Spara urval
                </button>
            </div>
        </div>
    </div>
}

@* Chat recipient picker dropdown *@
@if (_showChatDropdown)
{
    <div class="eatah-chat-recipient-overlay" @onclick="() => _showChatDropdown = false">
        <div class="eatah-chat-recipient-picker" @onclick:stopPropagation="true">
            <div class="eatah-chat-recipient-picker__title">Skicka till&hellip;</div>

            @* Household group chat *@
            <button type="button" class="eatah-chat-recipient-item" @onclick="SendToGroupAsync">
                <div class="eatah-chat-recipient-item__avatar eatah-chat-recipient-item__avatar--group">
                    <Icon Name="house" Size="14" />
                </div>
                <span class="eatah-chat-recipient-item__name">Hush&aring;llschatten</span>
            </button>

            @* Individual household members *@
            @foreach (var member in _householdMembers)
            {
                var m = member;
                <button type="button" class="eatah-chat-recipient-item" @onclick="() => SendToMemberAsync(m)">
                    <div class="eatah-chat-recipient-item__avatar">
                        <Icon Name="profile" Size="14" />
                    </div>
                    <span class="eatah-chat-recipient-item__name">@m.DisplayName</span>
                </button>
            }

            @if (_dropdownLoading)
            {
                <div class="eatah-chat-recipient-picker__loading">Laddar&hellip;</div>
            }
        </div>
    </div>
}

@using System.Globalization

@code {
    private HashSet<Guid> _selectedShoppingItems = [];
    private HashSet<string> _expandedGroups = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _expandedWeeks = new(StringComparer.OrdinalIgnoreCase);

    // Chat recipient picker state
    private bool _showChatDropdown;
    private bool _dropdownLoading;
    private char _pendingChatType; // 'i' = Jag köper, 'k' = Kan du köpa
    private List<WorkspaceMemberResponse> _householdMembers = [];

    // A single parsed entry from Notes: "Pasta Carbonara v22d0" → (item, "Pasta Carbonara", 22, 0)
    private record NoteEntry(ShoppingItemResponse Item, string MealName, int? WeekNumber, int? DayIndex);
    private record MealGroupView(string MealName, int? DayIndex, List<NoteEntry> Views);
    private record WeekGroupView(string WeekKey, string Label, List<MealGroupView> MealGroups);

    // Coverage popup: confirm which meals a shared ingredient covers when moved to pantry.
    private record PendingCoverage(ShoppingItemResponse Item, List<string> AllMeals)
    {
        public HashSet<string> CoveredMeals { get; } = new(AllMeals, StringComparer.OrdinalIgnoreCase);
    }

    private bool _coveragePopupOpen;
    private List<PendingCoverage> _pendingCoverage = [];

    private IList<WeekGroupView> WeekGroups
    {
        get
        {
            var today = DateTime.Today;
            var currentWeek = ISOWeek.GetWeekOfYear(today);
            var nextWeek = ISOWeek.GetWeekOfYear(today.AddDays(7));

            var entries = ShoppingState.Items
                .Where(s => !s.IsChecked)
                .SelectMany(s =>
                {
                    if (string.IsNullOrEmpty(s.Notes))
                        return (IEnumerable<NoteEntry>)[new NoteEntry(s, "Övrigt", null, null)];
                    return s.Notes.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .Select(part =>
                        {
                            var (meal, week, day) = ParseNoteEntry(part);
                            return new NoteEntry(s, meal, week, day);
                        });
                })
                .ToList();

            return entries
                .GroupBy(e => e.WeekNumber)
                .Select(weekG =>
                {
                    var weekNum = weekG.Key;
                    var weekKey = weekNum.HasValue ? $"v{weekNum}" : "null";
                    var label = weekNum switch
                    {
                        var w when w == currentWeek => "Denna veckan",
                        var w when w == nextWeek    => "Nästa vecka",
                        null                        => "Övrigt",
                        _                           => $"Vecka {weekNum}"
                    };
                    var mealGroups = weekG
                        .GroupBy(e => e.MealName, StringComparer.OrdinalIgnoreCase)
                        .Select(mealG =>
                        {
                            var minDay = mealG.Min(e => e.DayIndex);
                            var views = mealG.DistinctBy(e => e.Item.Id).ToList();
                            return new MealGroupView(mealG.Key, minDay, views);
                        })
                        .OrderBy(m => m.DayIndex ?? 99)
                        .ThenBy(m => m.MealName)
                        .ToList();
                    return new WeekGroupView(weekKey, label, mealGroups);
                })
                .OrderBy(w => w.WeekKey switch
                {
                    var k when k == $"v{currentWeek}" => 0,
                    var k when k == $"v{nextWeek}"    => 1,
                    "null"                            => 2,
                    _                                 => 3
                })
                .ToList();
        }
    }

    private static string GetMealGroupKey(string mealName, string weekKey) => $"{mealName}|{weekKey}";

    private void ToggleWeek(string weekKey)
    {
        if (!_expandedWeeks.Remove(weekKey))
            _expandedWeeks.Add(weekKey);
    }

    private static string GetDayName(int dayIdx) => dayIdx switch
    {
        0 => "Mån",
        1 => "Tis",
        2 => "Ons",
        3 => "Tor",
        4 => "Fre",
        5 => "Lör",
        _ => "Sön"
    };

    private static int GetDayIndexFromDate(DateTime date) => date.DayOfWeek switch
    {
        DayOfWeek.Monday    => 0,
        DayOfWeek.Tuesday   => 1,
        DayOfWeek.Wednesday => 2,
        DayOfWeek.Thursday  => 3,
        DayOfWeek.Friday    => 4,
        DayOfWeek.Saturday  => 5,
        _                   => 6
    };

    private static int WeekDaySortKey(int week, int day, int currentWeek, int todayDayIdx)
    {
        var weekOffset = (week - currentWeek) * 7;
        var dayOffset = day - todayDayIdx;
        if (dayOffset < 0) dayOffset += 7;
        return weekOffset + dayOffset;
    }

    private static (string MealName, int? Week, int? Day) ParseNoteEntry(string part)
    {
        var vIdx = part.LastIndexOf(" v");
        if (vIdx <= 0) return (part.Trim(), null, null);
        var mealName = part[..vIdx].Trim();
        var suffix = part[(vIdx + 2)..].Trim();
        var dIdx = suffix.IndexOf('d');
        if (dIdx > 0 && int.TryParse(suffix[..dIdx], out var week) && int.TryParse(suffix[(dIdx + 1)..], out var day))
            return (mealName, week, day);
        if (int.TryParse(suffix, out week))
            return (mealName, week, null);
        return (part.Trim(), null, null);
    }

    private bool _isLoading = true;
    private string? _error;

    protected override void OnInitialized()
    {
        Header.Set(center: @<span>Köplista</span>);
        PantryState.OnChanged += OnPantryChanged;
        ShoppingState.OnChanged += OnShoppingChanged;
    }

    public void Dispose()
    {
        Header.Clear();
        PantryState.OnChanged -= OnPantryChanged;
        ShoppingState.OnChanged -= OnShoppingChanged;
    }

    private void OnPantryChanged() => InvokeAsync(StateHasChanged);
    private void OnShoppingChanged() { ReinitGroups(); InvokeAsync(StateHasChanged); }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var pantryTask = Api.GetPantryAsync();
            var shoppingTask = Api.GetShoppingListAsync();

            await Task.WhenAll(pantryTask, shoppingTask);

            PantryState.SetPantry(await pantryTask);
            ShoppingState.SetShopping(await shoppingTask);
            ReinitGroups();
        }
        catch (Exception ex)
        {
            _error = $"Kunde inte ladda data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }

        // Auto-sync from meal plan silently after initial data is shown
        ShoppingSync.TriggerSync();
    }

    private async Task AddToPantryAsync(IngredientResponse ing)
    {
        // If this ingredient is on the shopping list with multiple meal notes, ask which meals it covers.
        var shoppingItem = ShoppingState.Items.FirstOrDefault(s => s.IngredientId == ing.Id && !s.IsChecked);
        if (shoppingItem is not null && GetMealCount(shoppingItem.Notes) > 1)
        {
            _pendingCoverage = [new PendingCoverage(shoppingItem, ExtractAllMealNames(shoppingItem.Notes))];
            _coveragePopupOpen = true;
            return;
        }

        try
        {
            var item = await Api.AddToPantryAsync(ing.Id);
            if (item is not null)
            {
                PantryState.AddItem(item);
                CheckState.AddPantryName(ing.Name);
                // Remove from shopping list if it was queued there
                if (shoppingItem is not null)
                {
                    await Api.RemoveFromShoppingListAsync(shoppingItem.Id);
                    ShoppingState.RemoveItem(shoppingItem.Id);
                }
            }
        }
        catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists)
        {
            Toasts.Show($"{ing.Name} finns redan i skafferiet.");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RemoveFromPantryAsync(PantryItemResponse item)
    {
        try
        {
            await Api.RemoveFromPantryAsync(item.Id);
            PantryState.RemoveItem(item.Id);

            // Re-sync so any newly missing ingredient appears on the shopping list immediately
            ShoppingSync.TriggerSync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task AddToShoppingAsync(IngredientResponse ing)
    {
        try
        {
            var item = await Api.AddToShoppingListAsync(ing.Id);
            if (item is not null)
                ShoppingState.AddOrUpdateItem(item);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void ToggleShoppingSelection(Guid itemId)
    {
        if (!_selectedShoppingItems.Remove(itemId))
            _selectedShoppingItems.Add(itemId);
    }

    private async Task MoveSelectedToPantryAsync()
    {
        var toMove = ShoppingState.Items
            .Where(s => _selectedShoppingItems.Contains(s.Id) && !s.IsChecked)
            .ToList();
        _selectedShoppingItems.Clear();

        var normalItems = toMove.Where(s => GetMealCount(s.Notes) <= 1).ToList();
        var sharedItems = toMove.Where(s => GetMealCount(s.Notes) > 1).ToList();

        // Move non-shared items directly to pantry
        foreach (var item in normalItems)
        {
            try
            {
                PantryItemResponse? pantryItem = null;
                try { pantryItem = await Api.AddToPantryAsync(item.IngredientId); }
                catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists) { }

                await Api.RemoveFromShoppingListAsync(item.Id);
                ShoppingState.RemoveItem(item.Id);

                if (pantryItem is not null)
                {
                    PantryState.AddItem(pantryItem);
                    CheckState.AddPantryName(item.Name);
                }
            }
            catch (Exception ex) { _error = ex.Message; }
        }

        // Show coverage popup for shared items
        if (sharedItems.Count > 0)
        {
            _pendingCoverage = sharedItems
                .Select(s => new PendingCoverage(s, ExtractAllMealNames(s.Notes)))
                .ToList();
            _coveragePopupOpen = true;
        }
    }

    private void ToggleCoverage(PendingCoverage coverage, string meal)
    {
        if (!coverage.CoveredMeals.Remove(meal))
            coverage.CoveredMeals.Add(meal);
    }

    private async Task CoverAllAndConfirmAsync()
    {
        foreach (var cov in _pendingCoverage)
            foreach (var meal in cov.AllMeals)
                cov.CoveredMeals.Add(meal);
        await ConfirmCoverageAsync();
    }

    private async Task ConfirmCoverageAsync()
    {
        _coveragePopupOpen = false;
        foreach (var coverage in _pendingCoverage)
        {
            try
            {
                PantryItemResponse? pantryItem = null;
                try { pantryItem = await Api.AddToPantryAsync(coverage.Item.IngredientId); }
                catch (ApiException ex) when (ex.ErrorCode == ApiErrorCodes.PantryItemAlreadyExists) { }

                if (pantryItem is not null)
                {
                    PantryState.AddItem(pantryItem);
                    CheckState.AddPantryName(coverage.Item.Name);
                }

                var remainingNotes = BuildRemainingNotes(coverage.Item.Notes, coverage.CoveredMeals);
                if (remainingNotes is null)
                {
                    // All meals covered: remove shopping item entirely
                    await Api.RemoveFromShoppingListAsync(coverage.Item.Id);
                    ShoppingState.RemoveItem(coverage.Item.Id);
                }
                else
                {
                    // Some meals remain: update Notes to keep only uncovered meal entries
                    await Api.AddToShoppingListAsync(coverage.Item.IngredientId, remainingNotes);
                    ShoppingState.AddOrUpdateItem(coverage.Item with { Notes = remainingNotes });
                }
            }
            catch (Exception ex) { _error = ex.Message; }
        }
        _pendingCoverage.Clear();
    }

    /// <summary>Rebuilds Notes keeping only entries NOT in coveredMeals. Returns null if all are covered.</summary>
    private static string? BuildRemainingNotes(string? originalNotes, HashSet<string> coveredMeals)
    {
        if (string.IsNullOrEmpty(originalNotes)) return null;
        var remaining = originalNotes
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(part =>
            {
                var (mealName, _, _) = ParseNoteEntry(part);
                return !coveredMeals.Contains(mealName);
            })
            .ToList();
        return remaining.Count > 0 ? string.Join(", ", remaining) : null;
    }

